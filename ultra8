  );
  pidx >= 0 ? (
    prec = mem_stlist + pidx * st_num;
    prec[st_undo_len] > 0 ? (
      memcpy(prec[st_redo_buf], prec[st_buf], prec[st_dirty]);
      prec[st_redo_len]      = prec[st_dirty];
      prec[st_redo_loop_len] = prec[st_loop_len];
      memcpy(prec[st_buf], prec[st_undo_buf], prec[st_undo_len]);
      prec[st_dirty]     = prec[st_undo_len];
      prec[st_loop_len]  = prec[st_undo_loop_len]; // Phase 7
      prec[st_disp_mult] = 0;
      <? loop(x=0;nch, printf("pidx == %d ? ch%d.dirty_top = prec[st_undo_len] - 1 :\n",x,x+1); x+=1;) ?> 0;
    );
  );
  updatechfromrec();
  g_sysex_dirty = 1; // Unit 3.4: undo restores content; schedule snapshot
);

// Re-apply the most recently undone overdub for both lanes of a pair. (Unit 2.1)
// Restores from the redo buffer and clears it (redo is consumed after one use).
// After redo_pair(), the undo snapshot remains valid — pressing UNDO again cycles back.
// Redo is a no-op if st_redo_len == 0.
function redo_pair(idx) local(oidx pidx orec prec) (
  oidx = pair_owner_idx(idx);
  pidx = pair_partner_idx(oidx);
  orec = mem_stlist + oidx * st_num;
  orec[st_redo_len] > 0 ? (
    memcpy(orec[st_buf], orec[st_redo_buf], orec[st_redo_len]);
    orec[st_dirty]     = orec[st_redo_len];
    orec[st_loop_len]  = orec[st_redo_loop_len]; // Phase 7: restore Flex lane length
    orec[st_disp_mult] = 0; // buffer changed; recompute display multiplier
    <? loop(x=0;nch, printf("oidx == %d ? ch%d.dirty_top = orec[st_redo_len] - 1 :\n",x,x+1); x+=1;) ?> 0;
    orec[st_redo_len]      = 0; // consume the redo snapshot
    orec[st_redo_loop_len] = 0;
  );
  pidx >= 0 ? (
    prec = mem_stlist + pidx * st_num;
    prec[st_redo_len] > 0 ? (
      memcpy(prec[st_buf], prec[st_redo_buf], prec[st_redo_len]);
      prec[st_dirty]     = prec[st_redo_len];
      prec[st_loop_len]  = prec[st_redo_loop_len]; // Phase 7
      prec[st_disp_mult] = 0;
      <? loop(x=0;nch, printf("pidx == %d ? ch%d.dirty_top = prec[st_redo_len] - 1 :\n",x,x+1); x+=1;) ?> 0;
      prec[st_redo_len]      = 0;
      prec[st_redo_loop_len] = 0;
    );
  );
  updatechfromrec();
  g_sysex_dirty = 1;
);

// MON: two-state toggle — disabled (0) ↔ always-monitor (2).
// Auto/selected (1) is treated as "not always" — next press promotes it to always.
// Mirrors the new mode to the linked partner lane when applicable.
// Defined here (after updatechfromrec) to avoid a forward-reference error.
function common_mon_pair(idx) local(oidx pidx orec prec newmode) (
  oidx = pair_owner_idx(idx);
  pidx = pair_partner_idx(oidx);
  orec = mem_stlist + oidx * st_num;

  newmode = orec[st_monmode] == 2 ? 0 : 2;

  orec[st_monmode] = newmode;

  pidx >= 0 ? (
    prec = mem_stlist + pidx * st_num;
    prec[st_monmode] = newmode;
  );

  updatechfromrec();
  g_mon_changed = 1;
  g_sysex_dirty = 1; // Unit 3.4: monmode changed; schedule snapshot
);

// ── Central command executor (Phase 2) ──────────────────────────────────────
// All looper commands — from MIDI, UI, or latch queue — should pass through
// this function. It resolves the pair owner and dispatches to the appropriate
// pair-aware helper.
// cmd:      one of the CMD_* constants above
// lane_idx: any lane index (owner or partner — pair_owner_idx normalises it)
// source:   one of the SRC_* constants (informational; not used for routing yet)
//
// Callers that need latch-queue support must check g_latchmode and call
// latchq_add() themselves BEFORE calling this function, because the latch
// queue stores raw MIDI bytes and cannot yet store CMD_* payloads directly.
// (That migration is a future step; for now only common-mode callers latch.)
//
// CMD_SEL is special: it does not call a pair-aware helper directly but
// injects a translated note into the MIDI stream via nextmsg_2 / common_dispatch.
// The caller must set those fields itself; execute_lane_command is a no-op for SEL.
function execute_lane_command(cmd, lane_idx, source) (
  cmd == CMD_RECPLY    ? common_recply_pair(lane_idx) :
  cmd == CMD_PLYSTP    ? common_plystp_pair(lane_idx) :
  cmd == CMD_CLR       ? clear_pair(lane_idx) :
  cmd == CMD_UNDO_REDO ? (
    (mem_stlist + pair_owner_idx(lane_idx) * st_num)[st_redo_len] > 0 ?
      redo_pair(lane_idx) : undo_pair(lane_idx);
  ) :
  cmd == CMD_REV       ? reverse_pair(lane_idx) :
  cmd == CMD_MON       ? common_mon_pair(lane_idx) :
  cmd == CMD_PLAY_ALL  ? play_or_stop_all() :
  0; // CMD_SEL and unknown commands: no-op here; caller handles
);

function reset() local(lp)
(
  g_chan_selected=-1;
  // setstate() will latch dirty_top to st_dirty
  <? loop(x=0;nch, x+=1; printf("ch%d.setstate(0); ch%d.rev_stop(); ch%d.rev_active=0; ch%d.dirty_top=-1;\n",x,x,x,x)) ?>
  lp = mem_stlist;
  loop(g_nchan,
    lp[st_dirty] > 0 ? (
      memset(lp[st_buf], 0, lp[st_dirty]);
      lp[st_dirty] = 0;
    );
    lp[st_loop_len]      = 0; // Phase 1: clear Flex lane length on kill-all
    lp[st_undo_loop_len] = 0;
    lp[st_redo_loop_len] = 0;
    lp[st_loop_phase]    = 0;
    lp += st_num;
  );
  g_firstrec=g_offs=g_length=g_pos=0;
  // Phase 1: reset Flex Mode transport state (g_flex_enabled itself is preserved)
  g_flex_base_len      = 0;
  g_flex_pos           = 0;
  g_flex_rec_owner_idx = -1;
  g_flex_rec_raw_len   = 0;
);


function estbpm(len) local(bpm, tsnum) global(ts_num, srate, cfgp_clickcnt)
(
  bpm = 240.0 * srate / len;
  (tsnum = (cfgp_clickcnt[]|0)) < 2 ? tsnum = ts_num;
  tsnum >= 2 ? bpm *= tsnum * .25;

  while (bpm < 60) ( bpm*=2; );
  while (bpm > 240) ( bpm/=2; );
  bpm;
);


// ── SysEx Snapshot Builder — Protocol v0.1 (Unit 3.3) ───────────────────────
//
// build_sysex_snapshot()
//   Fills g_sysex_buf[0..32] with a complete 33-byte v0.1 SysEx packet using the
//   current Ultra8 state. Does NOT increment the sequence counter or send MIDI.
//   Packet layout: docs/protocol_sysex_v0_1.md
//
// emit_sysex_snapshot()
//   Increments g_sysex_seq (14-bit, wraps at 16383), calls build_sysex_snapshot(),
//   then sends via midisend_buf(). Optionally printf-dumps each packet when
//   g_sysex_debug_enabled == 1. All SysEx output must go through this function.
//
// Initialization (inside ext_noinit guard, below):
//   g_sysex_enabled       — master gate: set to 0 to silence without removing code
//   g_sysex_debug_enabled — print each packet to Reaper console (for verification)
//   g_sysex_seq           — 14-bit counter, starts at 0; first emitted packet = seq 1
//   g_sysex_buf           — 33-float alloc block; each slot holds one packet byte
//   g_sysex_dirty         — set by setstate/undo_pair/common_mon_pair; @block emits
//                           one snapshot per block when set, then clears it

function build_sysex_snapshot()
  local(i, rec, lane_state, lane_dirty, lane_sel, lane_rev_active, lane_undo_redo, lane_flags, loop_phase)
(
  // ── Header (bytes 0–3) ──────────────────────────────────────────────────────
  g_sysex_buf[0] = 0xF0;   // SysEx start
  g_sysex_buf[1] = 0x7D;   // Non-commercial / educational manufacturer ID
  g_sysex_buf[2] = 0x55;   // Ultra8 NANO4 protocol identifier
  g_sysex_buf[3] = 0x01;   // Protocol version 1

  // ── Sequence number (bytes 4–5) — 14-bit counter, split into two 7-bit bytes ─
  g_sysex_buf[4] = g_sysex_seq & 0x7F;          // seq_lo: bits 6:0
  g_sysex_buf[5] = (g_sysex_seq >> 7) & 0x7F;   // seq_hi: bits 13:7

  // ── Global flags (byte 6) — bit 0 = any_active, bit 1 = flex_mode (Phase 9) ─
  g_sysex_buf[6] = ((g_active_mask != 0) ? 1 : 0)
                 | (g_flex_enabled ? 2 : 0); // bit 1: Flex Mode active

  // ── Selected lane (byte 7) — 0x7F = no selection ───────────────────────────
  g_sysex_buf[7] = (g_chan_selected >= 0 && g_chan_selected < g_nchan)
                   ? g_chan_selected : 0x7F;

  // ── Eight lane blocks (bytes 8–31, 3 bytes each) ────────────────────────────
  i   = 0;
  rec = mem_stlist;
  loop(g_nchan,
    lane_state = rec[st_state];

    // st_state==2 means "recording" in Ultra8 but covers two protocol states:
    //   RECORDING (2)  = first-pass, g_firstrec > 0 (loop length not yet set)
    //   OVERDUBBING (3) = subsequent pass, g_firstrec == 0 (loop length is fixed)
    lane_state == 2 ? (
      lane_state = (g_firstrec > 0) ? 2 : 3;
    );

    // Safety: map any unknown/out-of-range value to STOPPED (safe fallback)
    (lane_state < 0 || lane_state > 3) ? lane_state = 0;

    lane_dirty      = rec[st_dirty] > 0 ? 1 : 0;
    lane_sel        = (g_chan_selected == i) ? 1 : 0;
    lane_rev_active = (<? loop(x=0;nch, printf("i==%d?ch%d.rev_active:\n",x,x+1); x+=1) ?> 0) & 0x01;

    // undo_redo_state (2-bit, packed into bits 4:3 of lane_info byte):
    //   0 = neither available
    //   1 = undo available  (st_undo_len > 0, redo not pending)
    //   2 = redo available  (st_redo_len > 0; redo takes priority — matches toggle dispatch)
    // See docs/protocol_sysex_v0_1.md §Undo/Redo State.
    lane_undo_redo = rec[st_redo_len] > 0 ? 2
                   : rec[st_undo_len] > 0 ? 1
                   : 0;

    lane_flags = (lane_state      & 0x03)         // bits 1:0 — state enum
               | ((lane_dirty      & 0x01) << 2)  // bit 2    — dirty
               | ((lane_sel        & 0x01) << 3)  // bit 3    — selected
               | ((lane_rev_active & 0x01) << 6); // bit 6    — reverse active (monmode removed)
    // bits 5:4 = 0 (monmode removed in v0.2), bit 7 = 0 (7-bit MIDI safety)

    // Loop phase 0–127: fractional position through the loop.
    // Phase 9: In Flex Mode each lane uses its own length for phase calculation so
    // a 4x lane and a 1x lane produce independent progress values on the NANO4.
    // In non-Flex Mode (or when the lane has no committed length), use the shared
    // g_pos / g_length as before.
    is_flex_mode() && rec[st_loop_len] > 0 && rec[st_state] != 0 ? (
      loop_phase = min(127, ((g_flex_pos - get_effective_loop_phase(i)) % rec[st_loop_len]) / rec[st_loop_len] * 127 | 0);
    ) : (
      loop_phase = (g_length > 0 && rec[st_state] != 0)
                   ? min(127, g_pos / g_length * 127 | 0)
                   : 0;
    );

    g_sysex_buf[8 + i*3]     = i | ((lane_undo_redo & 0x03) << 3); // lane_info: index + undo_redo_state
    g_sysex_buf[8 + i*3 + 1] = lane_flags;
    g_sysex_buf[8 + i*3 + 2] = loop_phase;

    rec += st_num;
    i   += 1;
  );

  // ── SysEx end (byte 32) ─────────────────────────────────────────────────────
  g_sysex_buf[32] = 0xF7;
);

function emit_sysex_snapshot()
  local(di)
(
  // Advance sequence counter (14-bit, wraps 16383 → 0)
  g_sysex_seq = (g_sysex_seq + 1) & 0x3FFF;

  build_sysex_snapshot();
  midisend_buf(0, g_sysex_buf, 33);

  // Console hex dump — leave enabled during Unit 3.3 verification; set
  // g_sysex_debug_enabled = 0 in production (generates ~120 chars per packet)
  g_sysex_debug_enabled ? (
    printf("U8 SYSEX seq=%d: ", g_sysex_seq);
    di = 0;
    loop(33,
      printf("%02X ", g_sysex_buf[di] | 0);
      di += 1;
    );
    printf("\n");
  );
);
// ─────────────────────────────────────────────────────────────────────────────

// ── SysEx Assignment Message Builder/Emitter (Unit 6.3) ─────────────────────
//
// decode_assignment(raw, out_buf, offset)
//   Decodes a packed Ultra8 assignment integer into the two protocol bytes
//   (msg_type + msg_number) and writes them at out_buf[offset..offset+1].
//   Packed encoding: 0–127 = Note, 128 = Off, 129–257 = CC (n−129),
//   258–386 = PC (n−258). See docs/ultra8_assignment_map.md §Packed Encoding.
//
// build_assign_snapshot()
//   Fills g_assign_buf[0..22] with a complete 23-byte v0.1 assignment message.
//   Does NOT increment the sequence counter or send MIDI.
//   Packet layout: docs/protocol_assignment_metadata_v0_1.md
//
// emit_assign_snapshot()
//   Increments g_assign_seq (14-bit, wraps at 16383), calls
//   build_assign_snapshot(), sends via midisend_buf(). Reuses
//   g_sysex_debug_enabled for optional console hex dump.
//
// Initialization (inside ext_noinit guard, below):
//   g_assign_seq — separate 14-bit counter from g_sysex_seq; 0 on boot
//   g_assign_buf — 23-float alloc block; one slot per MIDI byte

function decode_assignment(raw, out_buf, offset)
  local(atype, anum)
(
  raw >= 258 ? ( atype = 3; anum = raw - 258; ) :  // PC
  raw >= 129 ? ( atype = 2; anum = raw - 129; ) :  // CC
  raw == 128 ? ( atype = 0; anum = 0;         ) :  // Off
              ( atype = 1; anum = raw;         );   // Note
  out_buf[offset]     = atype & 0x7F;
  out_buf[offset + 1] = anum  & 0x7F;
);

function build_assign_snapshot()
(
  // ── Header (bytes 0–6) ──────────────────────────────────────────────────────
  g_assign_buf[0] = 0xF0;   // SysEx start
  g_assign_buf[1] = 0x7D;   // Non-commercial / educational manufacturer ID
  g_assign_buf[2] = 0x55;   // Ultra8 NANO4 protocol identifier
  g_assign_buf[3] = 0x02;   // msg_type: assignment message (0x01 = state snapshot)

  // Sequence number — 14-bit counter, split into two 7-bit bytes
  g_assign_buf[4] = g_assign_seq & 0x7F;          // seq_lo: bits 6:0
  g_assign_buf[5] = (g_assign_seq >> 7) & 0x7F;   // seq_hi: bits 13:7

  g_assign_buf[6] = 6;   // num_controls: always 6 (added REV as control ID 5)

  // ── Control blocks (bytes 7–24, 6 × 3 bytes) ───────────────────────────────
  // Format per block: [control_id, msg_type_byte, msg_number]
  // Source pointers: per-lane st_note* for g_chan_selected (packed integer encoding)

  // Use per-lane values for g_chan_selected so that per-lane tweaker overrides
  // are reflected in the snapshot.  draw_global_tweaker keeps per-lane values
  // equal to the globals in common mode, so this is always at least as correct
  // as reading cfgp_common_* directly.
  g_snap_sel = (g_chan_selected >= 0 ? g_chan_selected : 0) * st_num + mem_stlist;

  g_assign_buf[7]  = 0;   // Control 0: REC_PLY — control_id
  decode_assignment(g_snap_sel[st_note_recply], g_assign_buf, 8);

  g_assign_buf[10] = 1;   // Control 1: PLY_STP — control_id
  decode_assignment(g_snap_sel[st_note_plystp], g_assign_buf, 11);

  g_assign_buf[13] = 2;   // Control 2: CLR — control_id
  decode_assignment(g_snap_sel[st_note_clr], g_assign_buf, 14);

  g_assign_buf[16] = 3;   // Control 3: MON — control_id
  decode_assignment(g_snap_sel[st_note_mon], g_assign_buf, 17);

  g_assign_buf[19] = 4;   // Control 4: UNDO_REDO — control_id
  decode_assignment(g_snap_sel[st_note_undo], g_assign_buf, 20);

  g_assign_buf[22] = 5;   // Control 5: REV — control_id
  decode_assignment(g_snap_sel[st_note_rev], g_assign_buf, 23);

  // ── SysEx end (byte 25) ─────────────────────────────────────────────────────
  g_assign_buf[25] = 0xF7;
);

function emit_assign_snapshot()
  local(di)
(
  // Advance sequence counter (14-bit, wraps 16383 → 0)
  g_assign_seq = (g_assign_seq + 1) & 0x3FFF;

  build_assign_snapshot();
  midisend_buf(0, g_assign_buf, 26);

  g_sysex_debug_enabled ? (
    printf("U8 ASSIGN seq=%d: ", g_assign_seq);
    di = 0;
    loop(26,
      printf("%02X ", g_assign_buf[di] | 0);
      di += 1;
    );
    printf("\n");
  );
);
