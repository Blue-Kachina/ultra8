    i[st_undo_buf] = alloc(g_maxlen);
    i += st_num;
  );

  // Register JSFX sliders with the PR library (required before any PR display calls)
  pr_sync     = PR.NewSlider(1, 0, 0, 2);   // slider1: sync mode (0=off, 1=project, 2=playback)
  pr_clickcnt = PR.NewSlider(4, 0, 0, 64);  // slider4: click count / loop length

  // ── Debug feedback emitter (Unit 2.2) ────────────────────────────────────────
  // Emits a CC on MIDI channel 16 whenever per-lane state changes.
  // Format: CC (100 + lane_index), value = st_state*8 + (dirty?4:0) + st_monmode
  //   st_state 0/1/2 × 8 = 0/8/16; dirty bit = +4; monmode 0/1/2 = +0/+1/+2
  // Channel 16 is safe: no NANO4 sends on ch16; Ultra8 common-mode gates on
  //   st_midichan (default 1–8), so these CCs cannot trigger any lane action.
  // CC 100–107 remap to note 229–236 in @sample — no Ultra8 assignment uses these.
  // Set g_dbg_fb_enabled = 0 to silence the emitter without removing the code.
  g_dbg_fb_enabled  = 1;
