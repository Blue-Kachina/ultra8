  pr_clickcnt = PR.NewSlider(4, 0, 0, 64);  // slider4: click count / loop length

  // ── Debug feedback emitter (Unit 2.2) ────────────────────────────────────────
  // Emits a CC on MIDI channel 16 whenever per-lane state changes.
  // Format: CC (100 + lane_index), value = st_state*8 + (dirty?4:0) + st_monmode
  //   st_state 0/1/2 × 8 = 0/8/16; dirty bit = +4; monmode 0/1/2 = +0/+1/+2
  // Channel 16 is safe: no NANO4 sends on ch16; Ultra8 common-mode gates on
  //   st_midichan (default 1–8), so these CCs cannot trigger any lane action.
  // CC 100–107 remap to note 229–236 in @sample — no Ultra8 assignment uses these.
  // Set g_dbg_fb_enabled = 0 to silence the emitter without removing the code.
  g_dbg_fb_enabled  = 0;  // PRODUCTION DEFAULT: 0. Set to 1 to emit per-lane state CCs on ch16.
  g_dbg_fb_chan     = 15;  // 0-indexed → MIDI channel 16
  g_dbg_fb_cc_base  = 100; // CC 100 = lane 0, CC 101 = lane 1, …
  g_dbg_fb_last     = alloc(g_nchan);
  memset(g_dbg_fb_last, 255, g_nchan); // 255 = "not yet emitted" → force first emit
  // ─────────────────────────────────────────────────────────────────────────────

  // ── Production vs development defaults ─────────────────────────────────────
  // See docs/sysex_production_config.md for the full configuration reference.
  // PRODUCTION defaults (ship with these):
  //   g_sysex_enabled       = 1   master gate — always on for NANO4 rigs
  //   g_sysex_debug_enabled = 0   verbose console logging OFF
  //   g_sysex_period_rate   = 0   heartbeat OFF (user enables via PULSE button)
  //   g_dbg_fb_enabled      = 0   debug CC emitter OFF
  // DEVELOPMENT overrides (revert before commit):
  //   g_sysex_debug_enabled = 1   prints ~120 chars/packet to Reaper console
  //   g_dbg_fb_enabled      = 1   emits CC 100-107 on ch16 for state tracing
  // ─────────────────────────────────────────────────────────────────────────────

  // ── SysEx Snapshot Builder — init (Units 3.3 / 3.4) ─────────────────────────
  // g_sysex_enabled:       1 = emit snapshots; 0 = silence without removing code
  // g_sysex_debug_enabled: 1 = printf each packet to Reaper console (verbose!)
  // g_sysex_seq:           14-bit sequence counter; 0 on boot, incremented before each emit
  // g_sysex_buf:           33-byte output buffer (one float slot per MIDI byte)
  // g_sysex_dirty:         set to 1 by setstate/undo_pair/common_mon_pair; @block
  //                        emits one snapshot per block when set, then clears it
  g_sysex_enabled       = 1;
  g_sysex_debug_enabled = 0;   // PRODUCTION DEFAULT: 0. Set to 1 to printf each SysEx packet.
  g_sysex_seq           = 0;
  g_sysex_buf           = alloc(33);
  g_sysex_dirty         = 0;
  // Periodic heartbeat (Unit 3.5): emit a snapshot at this rate even with no
  // state changes, so a NANO4 that power-cycled can recover automatically.
  // g_sysex_period_rate = 0 disables the heartbeat (state-change path still works).
  g_sysex_period_rate    = 0;          // off by default; restored from mem_gen_cfg[29] via @serialize
  g_sysex_period_counter = srate | 0; // countdown in samples; first fire ~1 s after boot
  // ─────────────────────────────────────────────────────────────────────────────

  // ── Assignment Message Emitter — init (Unit 6.3) ────────────────────────────
  // g_assign_seq:    separate 14-bit counter from g_sysex_seq; 0 on boot; first
  //                  emitted packet = seq 1 (incremented before each emit)
  // g_assign_buf:    26-float alloc block; one slot per MIDI byte (6 controls)
  // g_assign_shadow: 6-float shadow of per-lane st_note_recply/2/5/7/6/4 for the
  //                  currently selected lane (g_chan_selected), used by @block
  //                  to detect assignment changes between heartbeats.  Covers
  //                  both global header-row tweakers and per-lane row tweakers.
  //                  Initialised to -1 so the very first @block always emits.
  // g_assign_dirty:  set to 1 by the on-change detector in @block; cleared
  //                  after emit_assign_snapshot().
  // Shares g_sysex_enabled and g_sysex_debug_enabled with the snapshot emitter.
  g_assign_seq = 0;
  g_assign_buf = alloc(26);
  g_assign_shadow    = alloc(6);
  g_assign_shadow[0] = -1;   // rec  — -1 forces emit on first block
  g_assign_shadow[1] = -1;   // ply
  g_assign_shadow[2] = -1;   // clr
  g_assign_shadow[3] = -1;   // mon
  g_assign_shadow[4] = -1;   // undo
  g_assign_shadow[5] = -1;   // rev
  g_assign_dirty = 0;
  // ─────────────────────────────────────────────────────────────────────────────

  // ── UI open detection — init (IG-1) ─────────────────────────────────────────
  // Tracks whether the @gfx window was open (gfx_w > 0) in the previous frame.
  // Initialised to 0 so the first frame where gfx_w > 0 is detected as an open.
  g_prev_gfx_open = 0;

  // Pre-zeroed silence block for Add-to-Project offset padding (Unit A.2).
  // Size covers the maximum possible rotation (g_maxlen) on both channels.
  // Written once here; never modified -- export() reads it as silence source.
  mem_silence_buf = alloc(g_maxlen * 2);
  memset(mem_silence_buf, 0, g_maxlen * 2);
  // ─────────────────────────────────────────────────────────────────────────────
);

