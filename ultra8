function setstate(st) instance(fpos_slope, fpos2_slope, rec) local(dt)
(
  rec[st_state] ? (
    st==0 ? (
      g_active_mask &= -1 ~ (1<<this.idx);  // -1 = all-ones; XOR clears only bit idx
    ) : g_length > 0 ? (
      g_firstrec = 0;
      g_prevent_processing &= 0xe;
      this.extra_recording = (g_pos == 0 || g_pos == g_length) ? (0|min(srate*.5, g_maxlen-g_length)) : 0;

      // Phase 3: when Flex Mode is on and this is the very first recording commit
      // (no base length exists yet), establish g_flex_base_len and store st_loop_len
      // on the recording lane/pair.  g_flex_pos is reset to 0 so all subsequent
      // modulo calculations start from a clean phase boundary.
      is_flex_mode() && g_flex_base_len == 0 ? (
        g_flex_base_len = g_length;
        set_effective_loop_len(this.idx, g_flex_base_len);
        g_flex_pos = 0;
      );

      // Phase 4: if this commit ends a Flex variable-length empty-lane recording,
      // quantize the raw length, pad silence, and store st_loop_len.
      // g_flex_rec_owner_idx == pair_owner_idx(this.idx) identifies the lane pair.
      is_flex_mode() && g_flex_base_len > 0 &&
          g_flex_rec_owner_idx >= 0 &&
          g_flex_rec_owner_idx == pair_owner_idx(this.idx) ? (
        flex_commit_empty_lane_recording(this.idx, g_flex_rec_raw_len);
        g_flex_rec_owner_idx = -1;
        g_flex_rec_raw_len   = 0;
      );
    );
  ) : (
    st>0 ? (
      st == 2 && (dt = max(rec[st_dirty], this.dirty_top+1)) > 0 ? (
        this.set_need_zero(dt);
        this.dirty_top=-1;
        rec[st_dirty]=0;
      );

      (g_active_mask |= (1<<this.idx)) == (1<<this.idx) ? (
        st == 2 ? (
          cfgp_gate[] > g_infthreshdb && cfgp_sync[] == 0 ? (
            g_recstart_gate = 10^(cfgp_gate[]/20);
            g_prevent_processing |= 1;
          ) : (
            g_prevent_processing &= 0xe;
          );

          cfgp_sync[] == 0 ? (
            g_pos = g_offs = g_length = 0;
            g_firstrec = 1+this.idx;
            // Phase 3: reset flex cursor at the start of the first flex recording
            is_flex_mode() ? g_flex_pos = 0;
          );
        );
      ) : (
        // Phase 4: second (or later) lane starting recording in Flex Mode.
        // If Flex Mode is on, a base exists, and this lane is empty, this is a
        // variable-length Flex recording — record the owner idx and reset the
        // raw-length counter.  process() uses these to bypass the modulo wrap.
        is_flex_mode() && has_flex_base() && st == 2 && rec[st_dirty] == 0 ? (
          g_flex_rec_owner_idx = pair_owner_idx(this.idx);
          g_flex_rec_raw_len   = 0;
          set_effective_loop_phase(this.idx, g_flex_pos);
          // Buffer at linear positions 0..g_maxlen may hold stale content from
          // a prior recording (dt==0 so set_need_zero was skipped above). Schedule
          // a full defensive zero so process_need_zero clears each position before
          // the advancing Flex read pointer reaches it.  Zeroing runs 8x faster
          // than l_pos advances, so it always stays ahead of the read pointer.
          this.set_need_zero(g_maxlen);
        );
      );
    );
  );
  rec[st_state] == 2 && st != 2 ? rec[st_disp_mult] = 0; // overdub/commit: recompute display multiplier
  rec[st_state] = st;
  rec[st_dirty] = max(max(rec[st_dirty],this.dirty_top+1),st==2);

  st == 2 ? (
    fpos_slope = g_slope_recin;
    fpos2_slope = g_slope_playin;
  ) : (
    fpos_slope = g_slope_recout;
    fpos2_slope = st > 0 ? g_slope_playin :
                  (rec[st_fade_size]>0) ? -1/(rec[st_fade_size]*g_length) :
                  g_slope_playout;
  );
  g_sysex_dirty = 1; // Unit 3.4: schedule a snapshot on the next @block
);

function setstate_for_rec(rec, state) (
  rec = (rec-mem_stlist)/st_num;
  <? loop(x=0;nch, printf("rec == %d ? ch%d.setstate(state) :\n",x,x+1); x+=1) ?> 0;
