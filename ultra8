// ── Pair-aware command wrappers ───────────────────────────────────────────────
// Apply a state transition to both lanes of a pair (or just the one if unlinked).
// Resolves idx to the pair owner before dispatching.
function setstate_pair(idx, state) local(oidx pidx) (
  oidx = pair_owner_idx(idx);
  pidx = pair_partner_idx(oidx);
  setstate_for_rec(mem_stlist + oidx * st_num, state);
  pidx >= 0 ? setstate_for_rec(mem_stlist + pidx * st_num, state);
