// Save pre-overdub undo snapshot for both lanes of a pair.
// Unit 2.1: also clears the redo stack — a new overdub discards any pending redo.
// Phase 7: also saves st_loop_len so undo/redo can restore Flex lane lengths.
function snapshot_pair(idx) local(oidx pidx orec prec) (
  oidx = pair_owner_idx(idx);
  pidx = pair_partner_idx(oidx);
  orec = mem_stlist + oidx * st_num;
  orec[st_state] == 1 && orec[st_dirty] > 0 && orec[st_dirty] <= g_maxlen ? (
    memcpy(orec[st_undo_buf], orec[st_buf], orec[st_dirty]);
    orec[st_undo_len]      = orec[st_dirty];
    orec[st_undo_loop_len] = orec[st_loop_len]; // Phase 7: save Flex lane length
    orec[st_redo_len] = 0; // new overdub invalidates the redo stack
    orec[st_redo_loop_len] = 0;
  );
  pidx >= 0 ? (
    prec = mem_stlist + pidx * st_num;
    prec[st_state] == 1 && prec[st_dirty] > 0 && prec[st_dirty] <= g_maxlen ? (
      memcpy(prec[st_undo_buf], prec[st_buf], prec[st_dirty]);
      prec[st_undo_len]      = prec[st_dirty];
      prec[st_undo_loop_len] = prec[st_loop_len]; // Phase 7
