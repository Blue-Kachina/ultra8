    tmpo = buf + l_length - 1 - rev_p0;
    old=buf[rev_p0];
    buf[rev_p0] = tmpo[];
    tmpo[] = old;
    (rev_p0 += 1) == rev_p1 ? rev_p0 = rev_p2;
    rev_pos -= 1;
