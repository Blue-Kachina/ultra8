// PLY/STP: recording→play; playing→stop; stopped+content→play; empty→no-op.
// Uses pair_has_content so the empty-lane guard covers both lanes of a linked pair.
function common_plystp_pair(idx) local(oidx orec newstate) (
  oidx = pair_owner_idx(idx);
  orec = mem_stlist + oidx * st_num;

  orec[st_state] == 2 ? (
    // Recording → commit and enter playback.
    newstate = 1;
  ) : orec[st_state] == 1 ? (
    // Playing → stop.
    newstate = 0;
  ) : (
    // Stopped → play only when the pair has recorded content; otherwise no-op.
    newstate = pair_has_content(oidx) ? 1 : 0;
  );

  newstate != orec[st_state] ? (
    setstate_pair(oidx, newstate);
    select_pair(oidx);
  );
);

