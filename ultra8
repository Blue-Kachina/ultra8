          g_dbg_cmn_dirty0 = g_cmn_rec[st_dirty];
          common_plystp_pair(g_cmn_i);
          g_dbg_cmn_state1 = (mem_stlist + pair_owner_idx(g_cmn_i)*st_num)[st_state];
          g_dbg_cmn_dirty1 = (mem_stlist + pair_owner_idx(g_cmn_i)*st_num)[st_dirty];
