// ─────────────────────────────────────────────────────────────────────────────

// ── SysEx Snapshot — periodic heartbeat (Unit 3.5) ───────────────────────────
// Fires emit_sysex_snapshot() at g_sysex_period_rate Hz regardless of state.
// Allows a NANO4 that power-cycled or missed a packet to recover automatically
// within one period without any button press.
// Set g_sysex_period_rate = 0 to disable (state-change emission still active).
// Default rate: 1 Hz. Tested safe rates: see docs/test_logs/unit_8_3 (future).
g_sysex_enabled && g_sysex_period_rate > 0 ? (
  (g_sysex_period_counter -= samplesblock) <= 0 ? (
    emit_sysex_snapshot();
