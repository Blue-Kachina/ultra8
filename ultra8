// draws it right-aligned to xpos, returns width used
function draw_value_tweaker(xpos,ypos,midimem,draw, lbl)
  local(t w tw th do_overlay cap_cnt rec2)
(
  w = 45;
  xpos < 0 ? xpos = (-xpos)-w;
  cap_mode == midimem ? (
    t = (mouse_y-cap_last_y)/4;
    lbl == "RDC" ? (
      t ? (
        cap_last_y = mouse_y;
        midimem[0] = min(max(midimem[0]-t*(.1*4),0),500);
        rec2 = get_linked_rec(((midimem-mem_stlist)/st_num)|0);
        rec2 >= 0 ? (
          rec2[st_rdc]=midimem[0];
          lastchanlink |= (1<<40); // trigger redraw
        );
        updatechfromrec();
        draw=1;
      );
    ) : lbl == "DIV" ? (
      (tw=(t|0)) ? (
        cap_last_y = mouse_y - (t - tw)*4;
        t = min(max(midimem[0] - tw,1),64);
        midimem[0] != t ? (
          midimem[0] = t;
          // Propagate to linked partner
          rec2 = get_linked_rec(((midimem-mem_stlist)/st_num)|0);
          rec2 >= 0 ? rec2[st_div] = t;
          updatechfromrec();
          draw=1;
          lastchanlink |= (1<<40); // trigger redraw
        );
      );
    ) : lbl == "CH" ? (
      // Channel tweaker: integer 1–16, no MIDI type cycling
      (tw=(t|0)) ? (
        cap_last_y = mouse_y - (t - tw)*4;
        t = min(max(midimem[0] - tw, 1), 16);
        midimem[0] != t ? (
          midimem[0] = t;
          draw=1;
        );
      );
      !(mouse_cap&2) && !cap_cnt ? draw=1;
    ) : lbl == "FAD" ? (
      (tw=-(t|0)) ? (
        cap_last_y = mouse_y - (t + tw)*4;
        t = max(midimem[0],0);
        t==0 && tw > 0 ? t = 1/16;
        tw > 0 ? ( t >= 2 ? t+=1 : t*=2; ) : ( t<2 ? t/=2 : t -= 1 );
        t < 1/16 ? t=0;
        t > 32 ? t=32;
        midimem[0] != t ? (
          midimem[0] = t;
          lm = get_linked_rec((midimem-mem_stlist)/st_num);
          lm >= 0 ? lm[st_fade_size] = midimem[0];
          updatechfromrec();
          draw=1;
          lastchanlink |= (1<<40); // trigger redraw
        );
      );
    ) : (
      (tw=(t|0)) ? (
        cap_last_y = mouse_y - (t - tw)*4;
        t = (t = (midimem[0]%129) - tw) < 0 ? 128 : t > 128 ? 0 : t;
        (midimem[0]%129) != t ? (
          midimem[0] =  (midimem[0] >= 129*3 ? 0 : midimem[0] - (midimem[0]%129)) + t;
          updatechfromrec();
          draw=1;
          cap_cnt += 1;
        );
      );
      !(mouse_cap&2) && !cap_cnt ? (
        (last_mouse_cap&4) ? (
          g_lastmsg>=0 ? midimem[0] = g_lastmsg;
        ) : (
          midimem[0] = (midimem[0]%129)==128 ? 0 : (midimem[0]+129)%(129*4);
        );
        updatechfromrec();
        draw=1;
      );
    );
  );
  cap_mode == 0 &&  mouse_in(xpos,ypos,w,42) ? (
    (mouse_cap & 1) && !(last_mouse_cap&1) ? (
      midimem >= mem_stlist && midimem < mem_stlist+st_num*g_nchan ? (
        t = (midimem-mem_stlist)%st_num;
        t == st_note_recply || t == st_note_plystp || t == st_note_rev || t == st_note_clr || t == st_note_undo || t == st_note_mon ? (
          t != st_note_rev || g_latchmode ? (
            g_inject_midinote = 1024+midimem;
          ) : (
            t = ((midimem-mem_stlist)/st_num)|0;
            reverse_pair(t);
          );
        ) : t == st_fade_size ? (
          midimem[0] = midimem[0] ? -midimem[0] : 1;
          lm = get_linked_rec((midimem-mem_stlist)/st_num);
          lm >= 0 ? lm[st_fade_size] = midimem[0];
          updatechfromrec();
          draw=1;
          lastchanlink |= (1<<40); // trigger redraw
        );
      );
    ) : (mouse_cap & 2) && !(last_mouse_cap&2) ? (
      cap_mode = midimem;
      cap_cnt = 0;
      cap_last_y = mouse_y;
    );
  );
  draw ? (
    t=midimem[0];
    gfx_set(0.18, 0.18, 0.25);
    gfx_setfont(1, "Arial", 13);
    gfx_rect(xpos, ypos, w, 42);
    lbl == "RDC" ? (
      do_overlay=0;
      t=floor(t*10)*.1;
      t = t<0.1 ? "0mS" : sprintf(#str, t<10?"%.1f":"%d",t);
    ) : lbl == "CH" ? (
      do_overlay=0;
      t=sprintf(#str, "%d", midimem[0]|0);
    ) : lbl == "FAD" ? (
      t >= 1 ? (
        t=sprintf(#,"%d",t);
      ) : t > 0 ? (
        t=sprintf(#,"1/%d",ceil(1/t));
      ) : t="off";
    ) : (
      (do_overlay=format_note(#str,t)) ? (
        do_overlay = do_overlay==1?"CC":"PC";
        gfx_measurestr(do_overlay,tw,th);
        gfx_y=ypos + (lbl?(35-th):(37-th)*.5)- 4;
        gfx_x=xpos + (w-tw)*.5;
        do_overlay=="CC" ? gfx_set(0.9,.5,.2) : gfx_set(0.5,.5,.9);
        gfx_drawstr(do_overlay);
        do_overlay=3;
      );
      t=#str;
    );
    gfx_measurestr(t,tw,th);
    gfx_y=ypos + min((lbl?(40-th):(42-th)*.5) + do_overlay, 42-th);
    gfx_x=xpos + (w-tw)*.5;
    gfx_set(0.9, 0.9, 1.0);
    gfx_drawstr(t);
    lbl ? (
      gfx_set(0.55, 0.55, 0.65);
      gfx_measurestr(lbl, tw, th);
      gfx_x = xpos + (w - tw) * 0.5;
      gfx_y = ypos + 2;
      gfx_drawstr(lbl);
    );
    gfx_setfont(0);
  );
  w;
);


