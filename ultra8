(
  // Action button strip at bottom
  w = ((gfx_w - gap*7) / 8)|0;
  lx = 0;
  t = 0;
  force_redraw ? (
    // Clear the full area from action strip to window bottom (hides old tweakers)
    set_color(C_BG_BASE);
    gfx_rect(0, action_y, gfx_w, gfx_h - action_y);
    // Strip background
    PR.Color.Panel = "0C0C14FF";
    PR.Color.Contour = "181826FF";
    PR.DisplayPanel(
      gfx_w * 0.5 / pr_s * 100,
      (action_y + action_h * 0.5) / pr_s * 100,
      gfx_w / pr_s * 100,
      action_h / pr_s * 100
    );
  );
  while ((i = mem_gen_order[t]) >= 0) (
    force_redraw ? (
      // Button panel: dark bg + visible border (same draw style as topbar pills)
      gfx_set(0.10, 0.10, 0.16);
      gfx_rect(lx + 1, action_y + 1, w - 2, action_h - 4);
      set_color(0x303048);
      gfx_rect(lx + 1,         action_y + 1,              w - 2, 1);
      gfx_rect(lx + 1,         action_y + action_h - 4,   w - 2, 1);
      gfx_rect(lx + 1,         action_y + 1,              1,     action_h - 4);
      gfx_rect(lx + w - 2,     action_y + 1,              1,     action_h - 4);
      // In Flex mode, halve/double are no-ops (adjustsizes() early-exits).
      // Dim those buttons so the performer knows they are inactive.
      is_flex_mode() && (i+mem_gen_cfg == cfgp_halve || i+mem_gen_cfg == cfgp_double || i+mem_gen_cfg == cfgp_double_norep)
        ? gfx_set(1,1,1,0.30) : gfx_set(1);
      gfx_measurestr(mem_gen_names[i], tw, th);
      gfx_x = lx + (w - tw) * 0.5;
      gfx_y = min(action_y + (action_h - th) * 0.5, gfx_h - 28);
      gfx_drawstr(mem_gen_names[i]);
      i == 11 ? fadesz_button.draw_topbar_button(lx+4, action_y+4,
                  sprintf(#, "%s%.0f mS",
                    w<98 ? "" : w<160 ? "fade " : "halve fade: ", lasthalve));
    );
    i += mem_gen_cfg;
    // MIDI assignment button: centered horizontally, half inside strip / half in empty space below
    g_show_controls ? draw_value_tweaker(lx + ((w - 45)/2)|0, action_y + action_h - 21, i, force_redraw, 0);
    !(last_mouse_cap&1) && (mouse_cap&1) && mouse_in(lx, action_y, w, action_h) ? (
      i == cfgp_reset        ? strcat(#mainthread_todo, "r") :
      i == cfgp_halve        && !is_flex_mode() ? strcat(#mainthread_todo, "h") :
      i == cfgp_double       && !is_flex_mode() ? strcat(#mainthread_todo, "d") :
      i == cfgp_double_norep && !is_flex_mode() ? strcat(#mainthread_todo, "D") :
      i == cfgp_export       ? strcat(#mainthread_todo, "e") :
      i == cfgp_xfade        ? strcat(#mainthread_todo, "x") :
      i == cfgp_playall || i == cfgp_playsel ? g_inject_midinote = 1024 + i;
    );
    t += 1;
    lx += w + gap;
  );
);
// ─────────────────────────────────────────────────────────────────────────────

// ── draw() — main per-frame renderer (Phase 4 decomposition notes) ──────────
// JSFX does not support closures or struct passing, so the lane loop cannot be
// split into fully independent sub-functions without converting layout locals
// to globals. Instead the render is organised into labelled conceptual passes:
//   Pass A — Mouse input / hit-testing (link, lane select, lane PLY/STP click)
//   Pass B — Lane background and container panel
//   Pass C — Waveform + per-lane progress fill
//   Pass D — Controls (value tweakers, monitor icon)
//   Pass E — Link button icon and linked-pair overlay
//   Pass 5 — Action button strip at bottom (extracted to draw_action_strip())
// Fully extracted sub-functions: draw_topbar(), draw_position(), draw_action_strip().
// ─────────────────────────────────────────────────────────────────────────────
function draw(ixpos, ypos) local(i gap rec mode force_redraw
  mx my mw t lx ty tw th rec2 wl
  now dropfile last_show_controls last_pulse tx
  lane_h avail_lanes action_y action_h
  pr_s state_w peak_w wave_w sub_w mon_w
  state_x peak_x wave_x sub_x mon_x midi_x
  row_y row_cy wantr w
  g_curpk g_curpk_h gs_x gs_y gs_sz gi
  lasthalve lastlen lastoffs lastchanlink last_flex last_flex_rec
  tweaker_w tweaker_h link_area_w extra_gap content_right r_pos
  mon_sz mon_btn_x rec_x ply_x rev_x clr_x undo_x sel_x fad_x div_x rdc_x ch_x t_ypos
  lane_ypos state_hover own_rec id_text
  num_w mult_w mult_font_sz
  link_btn_w link_btn_h link_x link_cx link_cy lk_r lk_sep
  spk_hi spk_icon_sz spk_icon_x spk_icon_y
  frac split wave_draw_w
  pair_wantr mon_hit_y mon_hit_h mon_hit_rec)
(
  // ── Ultra8 Design Palette ─────────────────────────────────────────────────────
  C_BG_BASE        = 0x13171C;   // overall background
  C_BG_TOPBAR      = 0x13171C;   // top bar background
  C_LANE_REC       = 0x2B1415;   // recording/overdub: dark red
  C_LANE_PLAY      = 0x152116;   // playing: dark green
  C_LANE_STOP_CONT = 0x13171C;   // stopped with content: main UI
  C_LANE_EMPTY     = 0x13171C;   // empty lane: main UI
  C_CONT_REC       = 0x44191B;   // recording highlight
  C_CONT_PLAY      = 0x1F341C;   // playback highlight
  C_CONT_STOP      = 0x1D242C;   // stopped contour: main UI highlight
  C_CONT_SEL       = 0x7080E0;   // selected contour
  C_WAVE_TROUGH    = 0x0E0E1E;   // waveform sub-panel bg
  C_WAVE_PLAYED    = 0xCCCCCC;   // played: near-white
  C_WAVE_UNPLAYED  = 0x404060;   // unplayed: dim blue-grey
  C_PROG_PLAY      = 0x1F341C;   // playing progress fill (playback highlight)
  C_PROG_REC       = 0x44191B;   // recording progress fill (recording highlight)
  C_PROG_STOP      = 0x1D242C;   // stopped progress fill (main UI highlight)
  C_MON_OFF_BG  = 0x0C0C12;   // monitor off: near-black bg
  C_MON_OFF_FG  = 0x2A2A3C;   // monitor off: barely-visible border + icon
  C_MON_REC_FG  = 0xD83535;   // monitor on + recording: vivid red
  C_MON_PLAY_FG = 0x35D050;   // monitor on + playing: vivid green
  C_MON_STOP_FG = 0x3878C0;   // monitor on + stopped: vivid blue
  C_LINK_ON_BG     = 0x1A3A6A;   // linked fill
  C_LINK_ON_FG     = 0x88BBFF;   // linked icon
  C_LINK_OFF_BG    = 0x141420;   // unlinked bg
  C_LINK_OFF_FG    = 0x3A3A58;   // unlinked icon
  C_MULT_LABEL     = 0xDDEEFF;   // multiplier text active
  C_MULT_INACTIVE  = 0x3A3A50;   // multiplier text empty
  C_PILL_ON_DOT    = 0x30DD80;   // topbar ON dot
  C_PILL_OFF_DOT   = 0x404050;   // topbar OFF dot
  C_PILL_LABEL     = 0x909090;   // topbar label text
  C_PILL_VALUE     = 0xFFFFFF;   // topbar value text
  // ────────────────────────────────────────────────────────────────────────────

  force_redraw = gfx_w != last_w || gfx_h != last_h ||
    lasthalve != cfgp_fade[] || lastlen != g_length ||
    lastoffs != g_offs || lastchanlink != cfgp_link[] ||
    last_show_controls != g_show_controls ||
    last_show_controls != g_show_controls ||
    last_pulse != (g_sysex_period_rate > 0) ||
    last_flex != g_flex_enabled ||         // Phase 8: redraw on Flex Mode toggle
    last_flex_rec != g_flex_rec_owner_idx; // Phase 8: redraw during live flex recording
  lasthalve = cfgp_fade[];
  lastlen = g_length;
  lastoffs = g_offs;
  lastchanlink = cfgp_link[];
  last_show_controls = g_show_controls;
  last_show_controls = g_show_controls;
  last_pulse = (g_sysex_period_rate > 0);
  last_flex = g_flex_enabled;           // Phase 8
  last_flex_rec = g_flex_rec_owner_idx; // Phase 8
  // Per-lane redraws (including the per-lane progress fills added in ultra_redesign.md)
  // use the peak-meter 20 Hz timer (`now > rec[st_lastpkupd] + 0.05`) rather than a
  // g_pos-driven force_redraw on every sample block.  This keeps UI CPU low while
  // still giving fluid progress animation during playback and recording.
  // force_redraw covers layout changes, resize, Flex-toggle, and recording transitions.

  gap = 5;
  now = time_precise();
  pr_s = min(gfx_w, gfx_h);
  pr_s < 1 ? pr_s = 1;

  gfx_getdropfile(0, dropfile=#) ? (
    gfx_getdropfile(-1);
    force_redraw = 1;
  ) : (
    dropfile = 0;
  );

  // Horizontal row-per-lane layout and control columns.
  // Compute this before drawing Globals so global controls can share the exact
  // same x coordinates as their lane siblings.
  action_h = 72;
  action_y = gfx_h - action_h - 21;  // 21px empty space below action strip
  lane_ypos = ypos + (g_show_controls ? 56 : 0);
  avail_lanes = action_y - lane_ypos;
  lane_h = max((avail_lanes / g_nchan)|0, 20);

  tweaker_w    = 45;
  tweaker_h    = 42;
  link_btn_w   = 26;   // link button width
  link_btn_h   = 30;   // link button height
  extra_gap    = 10;

  num_w   = 40;           // lane number column
  mult_w  = 52;           // multiplier label column
  state_w = num_w + mult_w;
  peak_w  = 5;
  state_x = ixpos;
  content_right = gfx_w;

  mon_sz = min(tweaker_h, max(lane_h - 6, 16));

  r_pos = content_right - extra_gap;
  mon_x = r_pos - mon_sz;
  r_pos = mon_x - gap;

  g_show_controls ? (
    // SHOW CONTROLS ON: compute all tweaker positions right-to-left
    gfx_w > 900 ? ( fad_x = r_pos - tweaker_w; r_pos = fad_x - gap; ) : fad_x = -1;
    gfx_w > 820 ? ( div_x = r_pos - tweaker_w; r_pos = div_x - gap; ) : div_x = -1;
    gfx_w > 740 ? ( rdc_x = r_pos - tweaker_w; r_pos = rdc_x - gap; ) : rdc_x = -1;
    sel_x = r_pos - tweaker_w;
    r_pos = sel_x - extra_gap;
    clr_x = r_pos - tweaker_w;
    r_pos = clr_x - gap;
    undo_x = r_pos - tweaker_w;
    r_pos = undo_x - gap;
    rev_x = r_pos - tweaker_w;
    r_pos = rev_x - gap;
    ply_x = r_pos - tweaker_w;
    r_pos = ply_x - gap;
    rec_x = r_pos - tweaker_w;
    r_pos = rec_x - extra_gap;
    ch_x = r_pos - tweaker_w;
    r_pos = ch_x - gap;
    mon_btn_x = r_pos - tweaker_w;
    r_pos = mon_btn_x - extra_gap;
  ) : (
    // SHOW CONTROLS OFF: hide all tweakers; waveform expands
    fad_x = -1; div_x = -1; rdc_x = -1; sel_x = -1;
    clr_x = -1; undo_x = -1; rev_x = -1; ply_x = -1;
    rec_x = -1; ch_x = -1; mon_btn_x = -1;
  );

  wave_x = state_x + state_w;
  wave_w = max(r_pos - wave_x - gap, 30);

  // Common mode global strip
  g_show_controls ? (
    force_redraw ? (
      // Overall strip background
      PR.Color.Panel = "181030FF";
      PR.Color.Contour = "302050FF";
      PR.DisplayPanel(
        (ixpos + (gfx_w - ixpos) * 0.5) / pr_s * 100,
        (ypos + 27) / pr_s * 100,
        (gfx_w - ixpos) / pr_s * 100,
        54 / pr_s * 100
      );
    );

    // Draw globals at the same x coordinates as lane siblings.
    // No CH in Globals; it remains lane-local only.
    rec_x >= 0 ? draw_global_tweaker(rec_x,  ypos+6, cfgp_common_rec,  st_note_recply, force_redraw, "REC/PLY");
    ply_x >= 0 ? draw_global_tweaker(ply_x,  ypos+6, cfgp_common_ply,  st_note_plystp, force_redraw, "PLY/STP");
    rev_x >= 0 ? draw_global_tweaker(rev_x,  ypos+6, cfgp_common_rev,  st_note_rev, force_redraw, "REV");
    undo_x >= 0 ? draw_global_tweaker(undo_x, ypos+6, cfgp_common_undo, st_note_undo, force_redraw, "UNDO/REDO"); // Unit 2.2
    clr_x >= 0 ? draw_global_tweaker(clr_x,  ypos+6, cfgp_common_clr,  st_note_clr, force_redraw, "CLR");

    g_show_controls ? (
      sel_x >= 0 ? draw_global_tweaker(sel_x,  ypos+6, cfgp_common_sel,  st_note_sel, force_redraw, "SEL");
      rdc_x >= 0 ? draw_global_lane_tweaker(rdc_x, ypos+6, st_rdc, force_redraw, "RDC");
      div_x >= 0 ? draw_global_lane_tweaker(div_x, ypos+6, st_div, force_redraw, "DIV");
      fad_x >= 0 ? draw_global_lane_tweaker(fad_x, ypos+6, st_fade_size, force_redraw, "FAD");
    );

    mon_btn_x >= 0 ? draw_global_tweaker(mon_btn_x, ypos+6, cfgp_common_mon,  st_note_mon, force_redraw, "MON");

    // Global monitor speaker button: 2-state (0=off, 2=always-on). Styled like per-lane.
    gs_x = mon_x; gs_y = ypos + 6; gs_sz = mon_sz;
    force_redraw ? (
      g_global_monmode == 2 ? (
        // Always-on: vivid blue border + icon (mirrors per-lane "on" style)
        set_color(C_MON_OFF_BG);
        gfx_rect(gs_x, gs_y, gs_sz, gs_sz);
        set_color(C_MON_STOP_FG);
        gfx_rect(gs_x, gs_y, gs_sz, 1);
        gfx_rect(gs_x, gs_y+gs_sz-1, gs_sz, 1);
        gfx_rect(gs_x, gs_y, 1, gs_sz);
        gfx_rect(gs_x+gs_sz-1, gs_y, 1, gs_sz);
      ) : (
        // Off: near-black bg, barely-visible border + icon (mirrors per-lane "off" style)
        set_color(C_MON_OFF_BG);
        gfx_rect(gs_x, gs_y, gs_sz, gs_sz);
        set_color(C_MON_OFF_FG);
        gfx_rect(gs_x, gs_y, gs_sz, 1);
        gfx_rect(gs_x, gs_y+gs_sz-1, gs_sz, 1);
        gfx_rect(gs_x, gs_y, 1, gs_sz);
        gfx_rect(gs_x+gs_sz-1, gs_y, 1, gs_sz);
      );
      spk_icon_sz = gs_sz * 0.5;
      spk_icon_x = gs_x + (gs_sz - spk_icon_sz) * 0.5;
      spk_icon_y = gs_y + (gs_sz - spk_icon_sz) * 0.5;
      draw_speaker_clean(spk_icon_x, spk_icon_y, spk_icon_sz, spk_icon_sz);
    );
    (mouse_cap&1) && !(last_mouse_cap&1) && !cap_mode && mouse_in(gs_x, gs_y, gs_sz, gs_sz) ? (
      // 2-state toggle: off (0) ↔ always-on (2); never lands on auto/selected (1)
      g_global_monmode = g_global_monmode == 2 ? 0 : 2;
      gi = mem_stlist;
      loop(g_nchan,
        gi[st_monmode] = g_global_monmode;
        gi += st_num;
      );
      updatechfromrec();
      sliderchange(-1);
      last_w = 0;
    );
    ypos = lane_ypos;

    // ── DEBUG TELEMETRY BAR ──────────────────────────────────────────────────
    // Shows last common-mode action received: name, channel, lane, state change.
    // Remove this block once behavior is confirmed correct.
    0 && g_dbg_cmn_ch > 0 ? (
      gfx_set(0.05, 0.05, 0.12);
      gfx_rect(ixpos, ypos, gfx_w - ixpos, 14);
      gfx_setfont(1, "Arial", 10);
      gfx_set(0.6, 0.9, 0.6);
      gfx_x = ixpos + 4;
      gfx_y = ypos + 2;
      // For MON, state0/state1 hold monmode values, not loop state.
      strcmp(g_dbg_cmn_name, "MON") == 0 ? (
        gfx_printf("COMMON %s  ch=%d lane=%d  mon %d→%d",
          g_dbg_cmn_name, g_dbg_cmn_ch, g_dbg_cmn_idx+1,
          g_dbg_cmn_state0, g_dbg_cmn_state1);
      ) : strcmp(g_dbg_cmn_name, "") != 0 ? (
        gfx_printf("COMMON %s  ch=%d lane=%d  state %d→%d  dirty %d→%d  firstrec=%d",
          g_dbg_cmn_name, g_dbg_cmn_ch, g_dbg_cmn_idx+1,
          g_dbg_cmn_state0, g_dbg_cmn_state1,
          g_dbg_cmn_dirty0, g_dbg_cmn_dirty1, g_firstrec);
      ) : (
        gfx_printf("COMMON  ch=%d lane=%d  %s",
          g_dbg_cmn_ch, g_dbg_cmn_idx+1, g_dbg_cmn_name);
      );
      gfx_setfont(0);
      ypos += 16;
    );
    // ────────────────────────────────────────────────────────────────────────
  );

  rec = mem_stlist;
  i = 0;
  loop(g_nchan,
    row_y  = ypos + i * lane_h;
    row_cy = row_y + (lane_h/2)|0;

    // ── Pass A: Mouse input / hit-testing ──────────────────────────────────
    dropfile && mouse_in(state_x, row_y, gfx_w - 16, lane_h) ? load_file(dropfile, i);

    !cap_mode && (mouse_cap&1) && !(last_mouse_cap&1) ? (
      // Link button hit zone: centered in state_w, straddling pair boundary
      link_x = state_x + ((state_w - link_btn_w) * 0.5)|0;
      (i&1) && mouse_in(link_x, row_y - link_btn_h/2, link_btn_w, link_btn_h) ? (
        cfgp_link[] ~= 1<<(i>>1);
        // Phase 3: when just linked, normalize partner state from owner
        cfgp_link[] & (1<<(i>>1)) ? (
          // rec points to partner (i, odd); rec2 = owner (i-1, even)
          rec2 = mem_stlist + (i-1) * st_num;
          rec[st_state]     = rec2[st_state];
          rec[st_monmode]   = rec2[st_monmode];
          rec[st_rdc]       = rec2[st_rdc];
          rec[st_div]       = rec2[st_div];
          rec[st_fade_size] = rec2[st_fade_size];
          updatechfromrec();
          // Canonicalize selection: if partner was selected, redirect to owner
          g_chan_selected == i ? g_chan_selected = i - 1;
        );
      ) : mouse_in(state_x, row_y, state_w, lane_h) ? (
        // Lane identifier click: inject PLY/STP toggle for the pair owner
        g_inject_midinote = 1024 + pair_owner_rec(i) + st_note_plystp;
      ) : mouse_in(state_x + state_w, row_y, gfx_w - state_w, lane_h) ? (
        select_pair(i);
      );
    );

    mode = rec[st_state];
    is_chan_selected(i) ? mode |= 8;
    rec[st_dirty] ? mode |= 16;
    mode |= rec[st_monmode] << 8;
    g_firstrec ? mode |= 1<<30;

    force_redraw || rec[st_lastd] != mode || now > rec[st_lastpkupd] + 0.05 ? (
      rec[st_lastd] = mode;
      rec[st_lastpkupd] = now;
      wantr = 1;

      // Linked pair sync: when Lane A fires wantr, zero Lane B's timer so it
      // fires in the same @gfx frame.  This keeps the boundary monitor icon
      // and the selected-lane blue outline redrawn atomically.
      !(i&1) && (cfgp_link[] & (1<<(i>>1))) ? (rec+st_num)[st_lastpkupd] = 0;

      // ── Pass B: Lane background and container panel ────────────────────────
      // Lane container panel (full width minus link area, colored by state)
      // State 2 = recording: vivid red so it's unmistakable vs stopped/playing.
      // State 1 = playing:   visible green.
      // Dirty   = stopped with content: dim blue-violet.
      // Empty   = off: very dark.
      rec[st_state] >= 2 ? PR.Color.Panel = "2B1415FF" :
      rec[st_state] == 1 ? PR.Color.Panel = "152116FF" :
                           PR.Color.Panel = "13171CFF";
      rec[st_state] >= 2 ? PR.Color.Contour = "44191BFF" :
      rec[st_state] == 1 ? PR.Color.Contour = "1F341CFF" :
                           PR.Color.Contour = "1D242CFF";
      (mode&8) ? PR.Color.Contour = "7080E0FF";
      PR.DisplayPanel(
        (state_x + (content_right - state_x) * 0.5) / pr_s * 100,
        (row_y + lane_h * 0.5) / pr_s * 100,
        (content_right - state_x) / pr_s * 100,
        lane_h / pr_s * 100
      );

      // Linked pair: erase the shared edge so the two lanes don't show a double-thick border.
      // laneA erases its own bottom 2px; laneB erases its own top 2px.
      // Both happen in the wantr block; the laneA→laneB sync (line 2831) ensures they
      // redraw together so neither half of the seam is left behind.
      is_linked_idx(i) ? (
        set_color(C_BG_BASE);
        !(i & 1) ? (
          gfx_rect(state_x, row_y + lane_h - 2, content_right - state_x, 2); // laneA: erase bottom border
        ) : (
          gfx_rect(state_x, row_y, content_right - state_x, 2);               // laneB: erase top border
        );
      );

      // State area fill: full state_w gets the dark lane color.
      rec[st_state] >= 2 ? set_color(C_LANE_REC) :
      rec[st_state] == 1 ? set_color(C_LANE_PLAY) :
                           set_color(C_LANE_STOP_CONT);
      gfx_rect(state_x + 2, row_y + 2, state_w - 2, lane_h - 4);
      // Lane number box: highlight-color border (top/bottom/right edges)
      rec[st_state] >= 2 ? set_color(C_CONT_REC) :
      rec[st_state] == 1 ? set_color(C_CONT_PLAY) :
                           set_color(C_CONT_STOP);
      gfx_rect(state_x + 2, row_y + 2, num_w - 3, 1);          // top
      gfx_rect(state_x + 2, row_y + lane_h - 5, num_w - 3, 1); // bottom
      gfx_rect(state_x + num_w - 2, row_y + 2, 1, lane_h - 6); // right
      // Multiplier box border (same highlight color, 1px outline)
      gfx_rect(state_x + num_w, row_y + 3, 1, lane_h - 6);           // left edge
      gfx_rect(state_x + num_w + 1, row_y + 2, mult_w - 3, 1);       // top edge
      gfx_rect(state_x + num_w + 1, row_y + lane_h - 5, mult_w - 3, 1); // bottom edge

      // Lane number / hover play-stop symbol (left portion of container)
      PR.Color.Text = "FFFFFFFF";
      state_hover = mouse_in(state_x, row_y, state_w, lane_h);
      own_rec = pair_owner_rec(i);
      state_hover ? (
        own_rec[st_state] == 1 ? id_text = "■" :
        own_rec[st_dirty]  > 0 ? id_text = "▶" :
                                  id_text = sprintf(#, "%d", i+1);
      ) : (
        id_text = sprintf(#, "%d", i+1);
      );
      PR.DisplayText(
        (state_x + num_w * 0.5) / pr_s * 100,
        (row_y + lane_h * 0.5) / pr_s * 100,
        3.5,
        id_text
      );

      // Multiplier label — large and bold in mult_w column (Phase 3 redesign).
      mult_font_sz = max(min((lane_h * 0.55)|0, 22), 10);
      gfx_setfont(1, "Arial", mult_font_sz, 'b');
      rec[st_dirty] ? set_color(C_MULT_LABEL) : set_color(C_MULT_INACTIVE);
      is_flex_mode() ? (
        i == g_flex_rec_owner_idx ? (
          g_flex_base_len > 0 ? (
            sprintf(#_mtxt, "→%dx", max(1, ceil(g_flex_rec_raw_len / g_flex_base_len)));
          ) : (
            strcpy(#_mtxt, "REC");
          );
        ) : rec[st_loop_len] > 0 && g_flex_base_len > 0 ? (
          sprintf(#_mtxt, "%dx", max(1, (rec[st_loop_len] / g_flex_base_len + 0.5) | 0));
        ) : rec[st_dirty] == 0 ? (
          strcpy(#_mtxt, "--");
        ) : (
          strcpy(#_mtxt, "1x");
        );
      ) : (
        rec[st_dirty] ? strcpy(#_mtxt, "1x") : strcpy(#_mtxt, "--");
      );
      gfx_measurestr(#_mtxt, tw, th);
      gfx_x = state_x + num_w + (mult_w - tw) * 0.5;
      gfx_y = row_y + (lane_h - th) * 0.5;
      gfx_drawstr(#_mtxt);
      gfx_setfont(0);

      // ── Pass C: Waveform + progress fill ────────────────────────────────────
      // Waveform sub-panel — inset 2 px top/bottom so the PR contour border
      // remains visible between lanes (matching the ~4 px border on the right side).
      set_color(C_WAVE_TROUGH);
      gfx_rect(wave_x, row_y + 2, wave_w, lane_h - 4);
      // thin left separator between lane number area and waveform
      set_color(0x303050);
      gfx_rect(wave_x, row_y + 2, 1, lane_h - 4);

      // Per-lane progress fill (ultra_redesign.md Phase 1+2).
      // Drawn after the trough background and before the waveform so the waveform
      // renders on top.  Covers the area right of the peak meter slot.
      // Color tracks lane state: green=playing, red=recording/overdub, dim=stopped.
      rec[st_dirty] > 0 ? (
        wl = floor((wave_w - 1 - peak_w) * get_lane_progress_frac(i) + 0.5);
        wl > 0 ? (
          // Progress fill: vivid colors per state
          rec[st_state] == 1 ? set_color(C_PROG_PLAY) :  // playing: green
          rec[st_state] >= 2 ? set_color(C_PROG_REC)  :  // rec/overdub: red
                               set_color(C_PROG_STOP);    // stopped: dim blue
          gfx_rect(wave_x + 1 + peak_w, row_y + 2, wl, lane_h - 4);
        );
      );


      // Phase 6: Base-loop multiple tick marks.
      // For Flex lanes longer than 1x, draw a thin vertical line at each base-loop
      // boundary so the player can see the multiple structure at a glance.
      // Marks sit between the progress fill and the waveform (both drawn on top).
      is_flex_mode() && rec[st_loop_len] > 0 && g_flex_base_len > 0 ? (
        wl = max(1, (rec[st_loop_len] / g_flex_base_len + 0.5) | 0);
        wl > 1 ? (
          gfx_set(0.38, 0.38, 0.62);
          t = 1;
          loop(wl - 1,
            mx = wave_x + 1 + peak_w + floor((wave_w - 1 - peak_w) * t / wl + 0.5);
            gfx_rect(mx, row_y + 2, 1, lane_h - 4);
            t += 1;
          );
        );
      );

      // Input peak meter — draw within the inset inner area
      g_curpk = max(min(log10(rec[st_peak_in] + 0.000001) * 20, 0), -68);
      g_curpk_h = ((g_curpk + 68) / 68 * (lane_h - 4))|0;
      gfx_set(0);
      gfx_rect(wave_x + 2, row_y + 2, peak_w, (lane_h - 4) - g_curpk_h);
      gfx_set(0.75, 0.75, 0);
      gfx_rect(wave_x + 2, row_y + 2 + ((lane_h - 4) - g_curpk_h), peak_w, g_curpk_h);

      // Waveform: single colour drawn over the progress bar background.
      // Splitting played/unplayed required two expensive draw_waveform calls per
      // lane and caused sluggish/shaky animation; the solid progress fill already
      // communicates position clearly.
      rec[st_dirty] && (wl = get_lane_waveform_display_len(i, rec)) > 0 ? (
        set_color(C_WAVE_UNPLAYED);
        rec[st_disp_mult] == 0 ? rec[st_disp_mult] = compute_disp_mult(rec[st_buf], wl);
        draw_waveform(wave_x + peak_w + gap, row_cy,
                      wave_w - peak_w - gap * 2, (lane_h-4)*0.45 * rec[st_disp_mult],
                      rec[st_buf], get_lane_waveform_start_offset(wl), wl, i);
      );

      // Monitor icon: drawn here only for unlinked lanes.
      // Linked pairs: monitor is drawn during Lane B's iteration at the pair boundary.
      !is_linked_idx(i) ? (
        mx = mon_x;
        my = row_cy - (mon_sz/2)|0;
        rec[st_monmode] > 0 ? (
          rec[st_state] >= 2 ? set_color(C_LANE_REC) :
          rec[st_state] == 1 ? set_color(C_LANE_PLAY) :
                               set_color(C_LANE_STOP_CONT);
          gfx_rect(mx, my, mon_sz, mon_sz);
          rec[st_state] >= 2 ? set_color(C_MON_REC_FG) :
          rec[st_state] == 1 ? set_color(C_MON_PLAY_FG) :
                               set_color(C_MON_STOP_FG);
        ) : (
          set_color(C_MON_OFF_BG);
          gfx_rect(mx, my, mon_sz, mon_sz);
          set_color(C_MON_OFF_FG);
        );
        gfx_rect(mx, my, mon_sz, 1);
        gfx_rect(mx, my+mon_sz-1, mon_sz, 1);
        gfx_rect(mx, my, 1, mon_sz);
        gfx_rect(mx+mon_sz-1, my, 1, mon_sz);
        spk_icon_sz = mon_sz * 0.5;
        spk_icon_x = mx + (mon_sz - spk_icon_sz) * 0.5;
        spk_icon_y = my + (mon_sz - spk_icon_sz) * 0.5;
        draw_speaker_clean(spk_icon_x, spk_icon_y, spk_icon_sz, spk_icon_sz);
      );

    ) : (
      wantr = 0;
    );

    // Sub-controls: CH, REC/PLY, PLY/STP, REV, UNDO, CLR, advanced SEL/RDC/DIV/FAD, MON, speaker
    t = mem_stlist + i * st_num;
    t_ypos = row_cy - (tweaker_h / 2)|0;

    // Unlinked lane: draw controls at this lane's vertical centre.
    !is_linked_idx(i) ? (
      ch_x >= 0 ? draw_value_tweaker(ch_x, t_ypos, t + st_midichan, wantr, "CH");
      rec_x >= 0 ? draw_value_tweaker(rec_x, t_ypos, t + st_note_recply, wantr,
              rec[st_state]==2 && !g_firstrec ? "PLY" : "REC");
      ply_x >= 0 ? draw_value_tweaker(ply_x, t_ypos, t + st_note_plystp, wantr,
              rec[st_state]==1 ? "STP" : "PLY");
      rev_x >= 0 ? draw_value_tweaker(rev_x, t_ypos, t + st_note_rev, wantr, "REV");
      undo_x >= 0 ? draw_value_tweaker(undo_x, t_ypos, t + st_note_undo, wantr,
              t[st_redo_len] > 0 ? "REDO" : "UNDO"); // Unit 2.2: multi-state label
      clr_x >= 0 ? draw_value_tweaker(clr_x, t_ypos, t + st_note_clr, wantr, "CLR");

      g_show_controls ? (
        sel_x >= 0 ? draw_value_tweaker(sel_x, t_ypos, t + st_note_sel, wantr, "SEL");
        rdc_x >= 0 ? draw_value_tweaker(rdc_x, t_ypos, t + st_rdc, wantr, "RDC");
        div_x >= 0 ? draw_value_tweaker(div_x, t_ypos, t + st_div, wantr, "DIV");
        fad_x >= 0 ? draw_value_tweaker(fad_x, t_ypos, t + st_fade_size, wantr, "FAD");
      );

      mon_btn_x >= 0 ? draw_value_tweaker(mon_btn_x, t_ypos, t + st_note_mon, wantr, "MON");
    );

    // ── Pass D: Controls (tweakers, monitor icon) ───────────────────────────
    // Linked laneA: no controls drawn here — they are drawn during laneB's iteration
    // so laneB panel/waveform draws cannot overwrite them.

    // Linked pair overlay: draw laneA controls centered on the pair boundary, only during laneB.
    // Uses rec2 for laneA record; pair_wantr = wantr (laneA sync guaranteed by line 2823).
    should_draw_pair_overlay(i) ? (
      t = mem_stlist + (i - 1) * st_num;   // laneA mem slot
      rec2 = rec - st_num;                 // laneA record
      t_ypos = row_y - (tweaker_h / 2)|0;  // centered on pair boundary
      pair_wantr = wantr;

      ch_x >= 0 ? draw_value_tweaker(ch_x, t_ypos, t + st_midichan, pair_wantr, "CH");
      rec_x >= 0 ? draw_value_tweaker(rec_x, t_ypos, t + st_note_recply, pair_wantr,
              rec2[st_state]==2 && !g_firstrec ? "PLY" : "REC");
      ply_x >= 0 ? draw_value_tweaker(ply_x, t_ypos, t + st_note_plystp, pair_wantr,
              rec2[st_state]==1 ? "STP" : "PLY");
      rev_x >= 0 ? draw_value_tweaker(rev_x, t_ypos, t + st_note_rev, pair_wantr, "REV");
      undo_x >= 0 ? draw_value_tweaker(undo_x, t_ypos, t + st_note_undo, pair_wantr,
              t[st_redo_len] > 0 ? "REDO" : "UNDO");
      clr_x >= 0 ? draw_value_tweaker(clr_x, t_ypos, t + st_note_clr, pair_wantr, "CLR");

      g_show_controls ? (
        sel_x >= 0 ? draw_value_tweaker(sel_x, t_ypos, t + st_note_sel, pair_wantr, "SEL");
        rdc_x >= 0 ? draw_value_tweaker(rdc_x, t_ypos, t + st_rdc, pair_wantr, "RDC");
        div_x >= 0 ? draw_value_tweaker(div_x, t_ypos, t + st_div, pair_wantr, "DIV");
        fad_x >= 0 ? draw_value_tweaker(fad_x, t_ypos, t + st_fade_size, pair_wantr, "FAD");
      );

      mon_btn_x >= 0 ? draw_value_tweaker(mon_btn_x, t_ypos, t + st_note_mon, pair_wantr, "MON");

      // Phase 6: draw laneA monitor icon at boundary (moved out of link-button block)
      pair_wantr ? (
        mx = mon_x;
        my = row_y - (mon_sz/2)|0;
        rec2[st_monmode] > 0 ? (
          rec2[st_state] >= 2 ? set_color(C_LANE_REC) :
          rec2[st_state] == 1 ? set_color(C_LANE_PLAY) :
                               set_color(C_LANE_STOP_CONT);
          gfx_rect(mx, my, mon_sz, mon_sz);
          rec2[st_state] >= 2 ? set_color(C_MON_REC_FG) :
          rec2[st_state] == 1 ? set_color(C_MON_PLAY_FG) :
                               set_color(C_MON_STOP_FG);
        ) : (
          set_color(C_MON_OFF_BG);
          gfx_rect(mx, my, mon_sz, mon_sz);
          set_color(C_MON_OFF_FG);
        );
        gfx_rect(mx, my, mon_sz, 1);
        gfx_rect(mx, my+mon_sz-1, mon_sz, 1);
        gfx_rect(mx, my, 1, mon_sz);
        gfx_rect(mx+mon_sz-1, my, 1, mon_sz);
        spk_icon_sz = mon_sz * 0.5;
        spk_icon_x = mx + (mon_sz - spk_icon_sz) * 0.5;
        spk_icon_y = my + (mon_sz - spk_icon_sz) * 0.5;
        draw_speaker_clean(spk_icon_x, spk_icon_y, spk_icon_sz, spk_icon_sz);
      );
    );

    // Monitor hit test — Phase 7: outer guard suppresses linked laneA entirely.
    // Without it, neither branch would fire for linked laneA, leaving mon_hit_*
    // stale from the previous lane and risking a spurious click.
    (!is_linked_idx(i) || (i & 1)) ? (
      !is_linked_idx(i) ? (
        mon_hit_y   = row_y;
        mon_hit_h   = lane_h;
        mon_hit_rec = rec;
      ) : (
        // linked laneB: icon sits on the pair boundary
        mon_hit_y   = row_y - (mon_sz / 2)|0;
        mon_hit_h   = mon_sz;
        mon_hit_rec = rec - st_num;
      );
      ((mouse_cap&1) && !(last_mouse_cap&1) || (mouse_cap&2) && !(last_mouse_cap&2)) && !cap_mode &&
          mouse_in(mon_x, mon_hit_y, mon_sz, mon_hit_h) ? (
        mon_hit_rec[st_monmode] = (mon_hit_rec[st_monmode] + 1) % 3;
        rec2 = get_linked_rec(i);
        rec2 >= 0 ? rec2[st_monmode] = mon_hit_rec[st_monmode];
        updatechfromrec();
        sliderchange(-1);
      );
    );

    // ── Pass E: Link button icon and pair overlay ────────────────────────────
    // Link button: chain-link icon, centered in state_w, straddling pair boundary
    (i&1) && wantr ? (
      link_x = state_x + ((state_w - link_btn_w) * 0.5)|0;
      link_y = row_y - (link_btn_h / 2)|0;
      link_cx = link_x + link_btn_w * 0.5;
      link_cy = link_y + link_btn_h * 0.5;
      t = get_linked_rec(i) >= 0;
      // Background: always dark GUI colour
      set_color(C_BG_BASE);
      gfx_rect(link_x, link_y, link_btn_w, link_btn_h);
      // Border: lane-status highlight colour
      rec[st_state] >= 2 ? set_color(C_CONT_REC) :
      rec[st_state] == 1 ? set_color(C_CONT_PLAY) :
                           set_color(C_CONT_STOP);
      gfx_rect(link_x, link_y, link_btn_w, 1);
      gfx_rect(link_x, link_y + link_btn_h - 1, link_btn_w, 1);
      gfx_rect(link_x, link_y, 1, link_btn_h);
      gfx_rect(link_x + link_btn_w - 1, link_y, 1, link_btn_h);
      // Horizontal chain-link icon: two rings connected by a centre bar
      t ? set_color(0xFFFFFF) : set_color(C_LINK_OFF_FG);
      lk_r = max(3, (link_btn_h * 0.14)|0);    // ring radius
      lk_sep = max(5, (link_btn_w * 0.30)|0);  // horizontal offset from centre
      gfx_circle(link_cx - lk_sep, link_cy, lk_r, 0, 1);
      gfx_circle(link_cx + lk_sep, link_cy, lk_r, 0, 1);
      t ? (
        // Linked: horizontal bar connecting the two rings
        gfx_rect((link_cx - lk_sep + lk_r)|0, (link_cy - 1)|0,
                 (lk_sep * 2 - lk_r * 2)|0, 3);
      ) : (
        // Unlinked: leave gap — no bar, rings appear broken apart
        set_color(C_BG_BASE);
        gfx_rect((link_cx - 2)|0, (link_cy - 1)|0, 5, 3);
      );
      // Monitor icon for linked pair is now drawn in the pair overlay block above (Phase 6).
    );

    i += 1;
    rec += st_num;
  );

  // ── Pass 5: Action button strip ─────────────────────────────────────────
  draw_action_strip(action_y, action_h, gap, force_redraw);
);

// ultra_redesign.md Phase 5: in Flex mode the bar now clearly labels itself as the
// BASE/sync loop reference.  Classic mode is visually unchanged.
function draw_position(ypos) local(last_pos, last_len, bar_h, lbl_w, lh, bar_x, bpm_val, ms_val)
(
  last_w != gfx_w || last_h != gfx_h || last_pos != g_pos || last_len != g_length ? (
    last_len = g_length;
    last_pos = g_pos;
    bar_h = 22;
    bpm_val = cfgp_sync[] ? tempo : estbpm(last_len);
    ms_val  = last_len / srate * 1000;

    // Trough background
    set_color(0x080810);
    gfx_rect(0, ypos, gfx_w, bar_h);

    // Measure label to compute bar start offset
    gfx_setfont(1, "Arial", 10);
    is_flex_mode() ? (
      gfx_measurestr(sprintf(#_pb, "BASE  %d mS  %.1f BPM", ms_val, bpm_val), lbl_w, lh);
    ) : (
      gfx_measurestr(sprintf(#_pb, "BPM  %.1f   TIMEBASE  %d mS", bpm_val, ms_val), lbl_w, lh);
    );
    bar_x = lbl_w + 16;

    // Progress fill (right of label)
    set_color(0x1040A0);
    last_len > 0 ? gfx_rect(bar_x, ypos, (last_pos / last_len) * (gfx_w - bar_x), bar_h);

    // Label text
    is_flex_mode() ? set_color(0x8DC88D) : set_color(0xCCCCDD);
    gfx_x = 4; gfx_y = ypos + (bar_h - lh) * 0.5;
    gfx_drawstr(#_pb);
    gfx_setfont(0);
  );
);

function draw_pill_toggle(xp, yp, label, is_on)
  instance(x, y, w, h)
  globals(gfx_x, gfx_y, C_PILL_LABEL, C_PILL_ON_DOT, C_PILL_OFF_DOT)
  local(lw lh dot_sz gap_inner total_w total_h)
(
  gfx_setfont(1, "Arial", 13);
  gfx_measurestr(label, lw, lh);
  dot_sz = 8;
  gap_inner = 5;
  total_w = lw + dot_sz + gap_inner + 8;
  total_h = lh + 8;
  x = xp; y = yp; w = total_w; h = total_h;
  // Background
  gfx_set(0.10, 0.10, 0.16);
  gfx_rect(x, y, w, h);
  // 1px border
  set_color(0x303048);
  gfx_rect(x, y, w, 1); gfx_rect(x, y+h-1, w, 1);
  gfx_rect(x, y, 1, h); gfx_rect(x+w-1, y, 1, h);
  // Label text (muted)
  set_color(C_PILL_LABEL);
  gfx_x = x + 4; gfx_y = y + (total_h - lh) * 0.5;
  gfx_drawstr(label);
  // Status dot
  is_on ? set_color(C_PILL_ON_DOT) : set_color(C_PILL_OFF_DOT);
  gfx_circle(x + 4 + lw + gap_inner + dot_sz * 0.5, y + total_h * 0.5, dot_sz * 0.5, 1, 1);
  gfx_x = x + total_w + 8;
  gfx_setfont(0);
);

function draw_pill_value(xp, yp, label, valstr)
  instance(x, y, w, h)
  globals(gfx_x, gfx_y, C_PILL_LABEL, C_PILL_VALUE)
  local(lw lh vw vh total_w total_h sep)
(
  gfx_setfont(1, "Arial", 13);
  gfx_measurestr(label, lw, lh);
  gfx_setfont(1, "Arial", 13, 'b');
  gfx_measurestr(valstr, vw, vh);
  sep = 5;
  total_w = lw + sep + vw + 10;
  total_h = max(lh, vh) + 8;
  x = xp; y = yp; w = total_w; h = total_h;
  gfx_set(0.10, 0.10, 0.16);
  gfx_rect(x, y, w, h);
  set_color(0x303050);
  gfx_rect(x, y, w, 1); gfx_rect(x, y+h-1, w, 1);
  gfx_rect(x, y, 1, h); gfx_rect(x+w-1, y, 1, h);
  gfx_setfont(1, "Arial", 13);
  set_color(C_PILL_LABEL);
  gfx_x = x + 5; gfx_y = y + (total_h - lh) * 0.5;
  gfx_drawstr(label);
  gfx_setfont(1, "Arial", 13, 'b');
  set_color(C_PILL_VALUE);
  gfx_x = x + 5 + lw + sep; gfx_y = y + (total_h - vh) * 0.5;
  gfx_drawstr(valstr);
  gfx_x = x + total_w + 8;
  gfx_setfont(0);
);

function draw_topbar(need_ref) local(s,i,t, lastlen, lastgate, lastlatch, lastclickcount, lastvclickoffs, lastoffs, lastsync, last_show_controls, last_pulse, last_flex)
(
  need_ref == 0 ? (
    need_ref = (lastlen != g_length ||
                lastsync != cfgp_sync[] ||
                lastoffs != g_offs ||
                lastgate != cfgp_gate[] ||
                lastlatch != g_latchmode ||
                lastclickcount != (cfgp_clickcnt[]|0) ||
                lastvclickoffs != cfgp_vclick[] ||
                last_show_controls != g_show_controls ||
                last_pulse != (g_sysex_period_rate > 0) ||
                last_flex != g_flex_enabled);  // Phase 8
  );

  need_ref ? (
    set_color(C_BG_TOPBAR);
    gfx_rect(0, 0, gfx_w, 34);
    set_color(0x202030);  // separator line
    gfx_rect(0, 33, gfx_w, 1);

    gfx_x = 60;

    lastsync = cfgp_sync[];
    projsync_button.draw_pill_value(gfx_x + 4, 6,
      "SYNC", lastsync == 2 ? "PLAY" : lastsync == 0 ? "OFF" : "PROJ");

    lastlen = g_length;
    lastoffs = g_offs;
    lastgate = cfgp_gate[];
    lastvclickoffs = cfgp_vclick[];

    lastsync == 0 ? (
      offs_button.draw_pill_value(gfx_x + 4, 6, "OFFSETS", sprintf(#, "%.0f", g_offs));
      length_button.draw_pill_value(gfx_x + 4, 6, "SPLS", sprintf(#, "%.0f", g_length));
    );

    lastclickcount = cfgp_clickcnt[] | 0;

    clickcnt_button.draw_pill_value(gfx_x + 4, 6,
      lastsync ? "LENGTH" : "CLK CNT",
      lastsync ? (lastclickcount == 0 ? "MEAS" : sprintf(#, "%d", lastclickcount))
               : sprintf(#, "%d", lastclickcount));

    lastclickcount > 0 || lastsync ? vclick_button.draw_pill_value(gfx_x + 4, 6,
      "VCLICK", lastvclickoffs > 0 ? sprintf(#, "+%.1f", lastvclickoffs) : "OFF");

    lastsync == 0 ? gate_button.draw_pill_value(gfx_x + 4, 6,
      "GATE", cfgp_gate[] < g_infthreshdb ? "-inf" : sprintf(#, "%.0fdB", lastgate));

    latch_button.draw_pill_toggle(gfx_x + 4, 6, "LATCH", (lastlatch = g_latchmode));
    flex_button.draw_pill_toggle(gfx_x + 4, 6, "FLEX", (last_flex = g_flex_enabled));
    advanced_button.draw_pill_toggle(gfx_x + 4, 6, "SHOW CONTROLS", (last_show_controls = g_show_controls));
    pulse_button.draw_pill_toggle(gfx_x + 4, 6, "PULSE", (last_pulse = (g_sysex_period_rate > 0)));
  );

  (mouse_cap&1) && !(mouse_cap&2) ? (
    !(last_mouse_cap&1) ? (

      projsync_button.hit_topbar_button(mouse_x,mouse_y,-1) ? (
        cfgp_sync[] = (cfgp_sync[]+1)%3;
        g_slider_sync = cfgp_sync[];
        g_offs = 0;
      ) : latch_button.hit_topbar_button(mouse_x,mouse_y,-1) ? (
        // toggle
        cfgp_latch[] = g_latchmode = !g_latchmode;
      ) : advanced_button.hit_topbar_button(mouse_x,mouse_y,-1) ? (
        g_show_controls = !g_show_controls;
        // Globals bar is shown/hidden together with CTRL
        // g_show_globals is always 1 -- CTRL no longer controls common-mode dispatch
        mem_gen_cfg[24] = g_show_controls;
        sliderchange(-1); // persist to @serialize
        last_w = 0;       // force full redraw to show/hide advanced controls + globals
      ) : flex_button.hit_topbar_button(mouse_x,mouse_y,-1) ? (
        // Phase 8: toggle Flex Mode; reset transport state so a fresh start is clean.
        g_flex_enabled = !g_flex_enabled;
        g_flex_base_len = 0;
        g_flex_pos = 0;
        g_flex_rec_owner_idx = -1;
        g_flex_rec_raw_len = 0;
        sliderchange(-1); // persist g_flex_enabled via @serialize
        last_w = 0;       // force full redraw
      ) : pulse_button.hit_topbar_button(mouse_x,mouse_y,-1) ? (
        g_sysex_period_rate = g_sysex_period_rate > 0 ? 0 : 1.0;
        mem_gen_cfg[29] = g_sysex_period_rate > 0;
        sliderchange(-1); // persist to @serialize
      ) : (
        (lastsync==0 && (gate_button.hit_topbar_button(mouse_x,mouse_y,cfgp_gate)||
                         length_button.hit_topbar_button(mouse_x,mouse_y,cfgp_length)||
                         offs_button.hit_topbar_button(mouse_x,mouse_y,cfgp_offs))
        ) ||
        clickcnt_button.hit_topbar_button(mouse_x,mouse_y,cfgp_clickcnt)||
        ((lastclickcount||lastsync)&&vclick_button.hit_topbar_button(mouse_x,mouse_y,cfgp_vclick))||
        fadesz_button.hit_topbar_button(mouse_x,mouse_y,cfgp_fade);
      );
    ) : (cap_mode >= mem_gen_cfg && cap_mode < mem_gen_cfg+mem_gen_sz && (dy = mouse_y - cap_last_y)) ? (
      cap_mode == cfgp_gate ? (
        cap_mode[0] = min(max(cap_mode[0]-dy*.2,g_infthreshdb),-1);
      ) : cap_mode == cfgp_fade ? (
        cap_mode[0] = min(max(cap_mode[0]-dy*0.05,0),500);
      ) : cap_mode == cfgp_length ? (
        t = g_length - dy*((mouse_cap&8)?4:100);
        (t=max(t|0,1)) != g_length ? (
          g_length = t;
          g_pos %= g_length;
          g_edgetrim_drawstate=1;
        );
      ) : cap_mode == cfgp_clickcnt ? (
        g_slider_click_cnt = (cap_mode[0] = min(max(cap_mode[0]-dy*0.05,0),64))|0;
      ) : cap_mode == cfgp_vclick ? (
        cap_mode[0] = min(max(cap_mode[0]-dy*0.05,0),100);
      ) : cap_mode == cfgp_offs ? (
        t = (dy*((mouse_cap&8)?4:100))|0;
        t ? (
          i = g_offs+g_length;
          g_offs = min(max(g_offs-t,0),i-1);
          t = (i-g_length) - g_offs;
          g_length = i - g_offs;
          g_pos = (g_pos + t) % g_length;
          g_edgetrim_drawstate=1;
        );
      );
      cap_last_y=mouse_y;
    );
  );

  // animated logo
  gfx_x=0;
  gfx_y=4;
  t=time_precise();
  s="Ultra<?printf("%d",nch)?>";
  i=0;
  loop(strlen(s),
    gfx_set(sin(t+i*0.2)*0.3+0.5, cos(t*.61+i*0.5)*.7+0.3, sin(t*2.1-i*0.6)*.3+0.7);
    gfx_drawchar(str_getchar(s,i));
    i+=1;
  );
);

function get_vclick_pos(latms) local(tmp)
(
  tmp=cfgp_sync[];
  (vclick_len = cfgp_clickcnt[]|0)<1 && tmp ? vclick_len=ts_num;
  vclick_len >= 1 && (
    tmp ? (
      (tmp!=2 && g_active_mask) || (play_state&1);
    ) : (
      g_active_mask && !g_firstrec
    );
  ) ? (
    tmp = g_pos - latms*srate*0.001;
    tmp < 0 ? tmp += g_length;
    (tmp >= 0) ? (
      floor(g_pos * vclick_len / g_length)
    ) : -1;
  ) : -1;
);

function draw_vclick(pos,clen) 
  global(gfx_w,gfx_h,gfx_x,gfx_y)
  local(sw,sh,str)
(
  str=sprintf(#,"%d",1 + pos);

  gfx_w > gfx_h * 2 ? (
    gfx_setfont(2,"Arial",gfx_h);
    gfx_measurestr(str,sw,sh);
    gfx_x = (gfx_w-sw*.8) * pos / clen;
    gfx_y = 0;
  ) : gfx_w < gfx_h * .5 ? (
    gfx_setfont(2,"Arial",gfx_w*.7);
    gfx_measurestr(str,sw,sh);
    gfx_y = (gfx_h-sh*.5) * pos / clen;
    gfx_x = gfx_w*.5 - sw*.5;
  ) : (
    gfx_setfont(2,"Arial",min(gfx_h,gfx_w)*.5);
    gfx_measurestr(str,sw,sh);
    gfx_x=gfx_w*.5 + ((pos&1)?sw*.3:-sw*1.3);
    gfx_y=gfx_h*.5 + ((pos&2)?0:-sh);
  );
  gfx_set(1);
  gfx_drawstr(str);
  gfx_setfont(0);
);

function draw_trim_waveform(xpos, ypos, w, h, chan, isend)
  global(g_length mem_stlist st_num st_dirty st_buf g_offs srate) 
  local(rec buf len maxl linepos xpos2 w2)
(
  rec = mem_stlist + chan*st_num;
  gfx_set(0.25);
  gfx_rect(xpos,ypos,w,h);
  
  gfx_set(1);
  len = (w * 0.0005 * srate)|0; // 0.5ms/pixel
  xpos2 = xpos;
  w2=w;

  isend ? (
    buf = g_offs + g_length - len*.8;
  ) : (
    buf = g_offs - len*.2;
  );

  buf < 0 ? (
    xpos2 -= buf*w/len;
    len += buf;
    w2 -= xpos2-xpos;
    buf = 0;
  );
  
  g_length && rec[st_dirty] ? 
    draw_waveform(xpos2,ypos+h*.5,w2,h*.25,rec[st_buf],buf,len,chan);
    
  gfx_set(0,.5,.7,.5);
  xpos += (w*(isend?.8:.2))|0;
  gfx_line(xpos,ypos,xpos,ypos+h);
);

