  peak_in = max(abs(s),peak_in);

  // Phase 2: use per-lane helpers so Flex Mode can supply per-lane length/position.
  // In non-Flex Mode (g_flex_enabled==0) both helpers return g_length / g_pos unchanged.
  // During the initial first-recording pass (g_firstrec > 0) the lane has no committed
  // length yet, so get_lane_play_len() falls back to g_length — same as before.
  l_length = get_lane_play_len(idx);
  l_pos    = get_lane_play_pos(idx);
  l_offs   = is_flex_mode() ? 0 : g_offs; // no user-offset in Flex Mode

  // Phase 4: Flex variable-length empty-lane recording.
  // When this lane is the designated Flex rec lane (g_flex_rec_owner_idx matches),
  // override l_pos to the raw linear sample count so the write pointer never wraps.
  // l_length is set large enough to suppress the modulo and rdc paths below.
  // The raw-length counter advances here (inside process) so it counts every sample
  // regardless of RDC or other adjustments.  Auto-stop at g_maxlen.
  is_flex_mode() && pair_owner_idx(idx) == g_flex_rec_owner_idx && g_flex_rec_owner_idx >= 0 ? (
    g_flex_rec_raw_len < g_maxlen ? (
      // Only the pair owner increments the raw-length counter; the linked partner
      // reads back (raw_len - 1) so both channels write to the SAME sample position.
      // Without this guard, both channels increment per-sample → 2× count, interleaved audio.
      idx == g_flex_rec_owner_idx ? (
        l_pos = g_flex_rec_raw_len;
        g_flex_rec_raw_len += 1;
      ) : (
        l_pos = g_flex_rec_raw_len - 1;  // owner already incremented; mirror same position
      );
      l_length = g_maxlen;          // suppress modulo; real length committed on stop
    ) : (
      // Buffer full: auto-commit by pretending the user stopped recording.
      // The commit will happen in the next setstate call (triggered from @block or @sample).
      // For safety, freeze the write pointer at the last valid position.
      l_pos    = g_maxlen - 1;
      l_length = g_maxlen;
    );
  );

  div < 1 ? (
    l_length = max((l_length*div+0.5)|0,1);
    g_firstrec === 0 ? (
      l_pos %= l_length;
      l_offs %= l_length;
    );
  );
  wrpos = l_pos;
  buf = this.buf + l_offs;
  g_firstrec === 0 ? (
    this.extra_recording > 0 ? (
      buf[l_length + l_pos] = s; // write past the end of the loop (in case we want to trim later)
      this.dirty_top = max(this.dirty_top,l_length + l_pos + l_offs);
      this.extra_recording -= 1;
    );

    this.rdc < l_length ? (
      wrpos -= this.rdc;
      wrpos < 0 ? wrpos += l_length;
    );
  );
  this.need_zero > 0 ? this.process_need_zero(l_offs+wrpos,l_offs+l_pos);

  r = this.rev_state!==0 ? this.process_rev(buf)*sc : sc > 0.0001 ? buf[l_pos]*sc;
  monmode === 0 ? (
    // no monitoring
    fpos > 0.0001 ? (
      this.dirty_top = max(this.dirty_top,wrpos + l_offs);
      buf[wrpos] += s*fpos;
    );
    r;
  ) : (
    this.monmode_sel ? (
      monvol = 1 + (monvol-1)*g_fadespeed;
    ) : (
      monvol *= g_fadespeed;
    );

    fpos > 0.0001 ? (
      this.dirty_top = max(this.dirty_top,wrpos + l_offs);
      wrpos == l_pos ? (
        buf[l_pos] += s*fpos;
        r + s*max(fpos*sc, monvol);
      ) : (
        buf[wrpos] += s*fpos;
        r + s * monvol;
      );
    ) : (
      r + s*monvol;
    );
  );
);

