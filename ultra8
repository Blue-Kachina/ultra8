function play_or_stop_all() local(want_state rec i)
(
  want_state = 0;
  i = 0;
  rec = mem_stlist;
  loop(g_nchan,
    // Skip partner lanes when evaluating desired play state
    !(is_linked_idx(i) && (i & 1)) ? (
      rec[st_state] != 1 && rec[st_dirty]>0 ? want_state = 1;
    );
    rec += st_num;
    i += 1;
  );
  i = g_nchan;
  loop(g_nchan,
    i -= 1;
    rec -= st_num;
