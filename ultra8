function draw_speaker_clean(xpos, ypos, w, h)
  local(bx by bw bh hx1 hx2 htop1 hbot1 htop2 hbot2 angle da r1 r2 sx sy arc_steps)
(
  // Speaker body: filled rect (left ~28%)
  bw = w * 0.28;
  bh = h * 0.40;
  bx = xpos + w * 0.06;
  by = ypos + (h - bh) * 0.5;
  gfx_rect(bx|0, by|0, bw|0, bh|0);

  // Horn: filled trapezoid via two triangles (wider toward right)
  hx1 = (bx + bw)|0;
  htop1 = by|0;
  hbot1 = (by + bh)|0;
  hx2 = (xpos + w * 0.58)|0;
  htop2 = (ypos + h * 0.08)|0;
  hbot2 = (ypos + h * 0.92)|0;
  gfx_triangle(hx1, htop1, hx2, htop2, hx2, hbot2);
  gfx_triangle(hx1, htop1, hx1, hbot1, hx2, hbot2);

  // Sound arcs: two arcs, double-thick lines
  r1 = w * 0.14;
  r2 = w * 0.24;
  arc_steps = 9;
  da = $pi * 0.60 / arc_steps;
  sx = xpos + w * 0.68;
  sy = ypos + h * 0.5;
  angle = -$pi * 0.30;
  loop(arc_steps,
    gfx_line(sx + r1*cos(angle),       sy + r1*sin(angle),
             sx + r1*cos(angle+da),     sy + r1*sin(angle+da), 0);
    gfx_line(sx + (r1+1)*cos(angle),   sy + (r1+1)*sin(angle),
             sx + (r1+1)*cos(angle+da), sy + (r1+1)*sin(angle+da), 0);
    gfx_line(sx + r2*cos(angle),       sy + r2*sin(angle),
             sx + r2*cos(angle+da),     sy + r2*sin(angle+da), 0);
    gfx_line(sx + (r2+1)*cos(angle),   sy + (r2+1)*sin(angle),
             sx + (r2+1)*cos(angle+da), sy + (r2+1)*sin(angle+da), 0);
    angle += da;
  );
);

