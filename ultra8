          strcpy(g_dbg_cmn_name, "PLY/STP");
          g_dbg_cmn_ch = g_msg_chan; g_dbg_cmn_idx = g_cmn_i;
          nextmsg_3 = 0; // suppress further dispatch
        ) :
        nextmsg_2 == g_cmn_rec[st_note_rev] ? (
          // REV: pair-aware reverse toggle
          strcpy(g_dbg_cmn_name, "REV");
          g_dbg_cmn_ch = g_msg_chan; g_dbg_cmn_idx = g_cmn_i;
          execute_lane_command(CMD_REV, g_cmn_i, SRC_MIDI_COMMON);
          nextmsg_3 = 0; // suppress further dispatch
        ) :
        nextmsg_2 == g_cmn_rec[st_note_undo] ? (
          // Unit 2.1: toggle — REDO if redo stack is available, otherwise UNDO.
          // Both paths are pair-aware and restore both lanes when linked.
          // execute_lane_command(CMD_UNDO_REDO) toggles redo-first internally.
          g_cmn_rec[st_redo_len] > 0 ? strcpy(g_dbg_cmn_name, "REDO") : strcpy(g_dbg_cmn_name, "UNDO");
          g_dbg_cmn_ch = g_msg_chan; g_dbg_cmn_idx = g_cmn_i;
          execute_lane_command(CMD_UNDO_REDO, g_cmn_i, SRC_MIDI_COMMON);
          nextmsg_3 = 0; // suppress further dispatch
        ) :
        nextmsg_2 == g_cmn_rec[st_note_sel] ? (
          strcpy(g_dbg_cmn_name, "SEL");
          g_dbg_cmn_ch = g_msg_chan; g_dbg_cmn_idx = g_cmn_i;
          nextmsg_2 = 1024 + pair_owner_rec(g_cmn_i) + st_note_sel;
          common_dispatch = 1; // translated: allow lane dispatch
        ) :
        nextmsg_2 == g_cmn_rec[st_note_mon] ? (
          // MON: disabled↔always-monitor (auto/selected treated as not-always).
          g_dbg_cmn_state0 = g_cmn_rec[st_monmode];
          execute_lane_command(CMD_MON, g_cmn_i, SRC_MIDI_COMMON);
          g_dbg_cmn_state1 = (mem_stlist + pair_owner_idx(g_cmn_i)*st_num)[st_monmode];
          strcpy(g_dbg_cmn_name, "MON");
          g_dbg_cmn_ch = g_msg_chan; g_dbg_cmn_idx = g_cmn_i;
          nextmsg_3 = 0; // suppress further dispatch
        );
      );
      g_cmn_i += 1;
    );
  );

  (nextmsg_1 & 0xF0) == 0x90 && nextmsg_3 != 0  ? (
    // Lane dispatch is exclusive when common mode is on:
    // only translated common commands (common_dispatch=1) reach chan_onmsg / latch queue.
    // Raw per-lane assignments are blocked while g_show_globals is enabled (Option A).
    // Global controls (reset, halve, etc.) are checked below regardless of common mode.
    (!g_show_globals || common_dispatch || g_ui_dispatch) ? (
      (!g_latchmode || g_pos == 0 || g_firstrec) ? (
        chan_onmsg(nextmsg_1,nextmsg_2,nextmsg_3);
      ) : (
        latchq_add(nextmsg_1,nextmsg_2,nextmsg_3);
      );
    );

    nextmsg_2 == cfgp_reset[]        ? (strlen(#mainthread_todo)<100 ? strcat(#mainthread_todo, "r")) :
    nextmsg_2 == cfgp_halve[]        ? (strlen(#mainthread_todo)<100 ? strcat(#mainthread_todo, "h")) :
    nextmsg_2 == cfgp_double[]       ? (strlen(#mainthread_todo)<100 ? strcat(#mainthread_todo, "d")) :
    nextmsg_2 == cfgp_double_norep[] ? (strlen(#mainthread_todo)<100 ? strcat(#mainthread_todo, "D")) :
    nextmsg_2 == cfgp_export[]       ? (strlen(#mainthread_todo)<100 ? strcat(#mainthread_todo, "e")) :
    nextmsg_2 == cfgp_xfade[]        ? (strlen(#mainthread_todo)<100 ? strcat(#mainthread_todo, "x"));

    nextmsg_2 < 1024 ? g_lastmsg = nextmsg_2;
  );
  nextmsg_offs=-1;
  midirecv(nextmsg_offs,nextmsg_1,nextmsg_2,nextmsg_3) ? midisend(nextmsg_offs,nextmsg_1,nextmsg_2,nextmsg_3);
);

