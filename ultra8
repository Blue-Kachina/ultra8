            g_inject_midinote = 1024+midimem;
          ) : (
            t = ((midimem-mem_stlist)/st_num)|0;
            reverse_pair(t);
          );
        ) : t == st_fade_size ? (
          midimem[0] = midimem[0] ? -midimem[0] : 1;
          lm = get_linked_rec((midimem-mem_stlist)/st_num);
          lm >= 0 ? lm[st_fade_size] = midimem[0];
          updatechfromrec();
          draw=1;
          lastchanlink |= (1<<40); // trigger redraw
        );
      );
    ) : (mouse_cap & 2) && !(last_mouse_cap&2) ? (
      cap_mode = midimem;
      cap_cnt = 0;
      cap_last_y = mouse_y;
    );
  );
  draw ? (
    t=midimem[0];
    gfx_set(.35);
    gfx_setfont(1,"Arial",13);
    gfx_rect(xpos,ypos,w,42);
    lbl == "RDC" ? (
      do_overlay=0;
      t=floor(t*10)*.1;
      t = t<0.1 ? "0mS" : sprintf(#str, t<10?"%.1f":"%d",t);
    ) : lbl == "CH" ? (
      do_overlay=0;
      t=sprintf(#str, "%d", midimem[0]|0);
    ) : lbl == "FAD" ? (
      t >= 1 ? (
        t=sprintf(#,"%d",t);
      ) : t > 0 ? (
        t=sprintf(#,"1/%d",ceil(1/t));
      ) : t="off";
    ) : (
      (do_overlay=format_note(#str,t)) ? (
        do_overlay = do_overlay==1?"CC":"PC";
        gfx_measurestr(do_overlay,tw,th);
        gfx_y=ypos + (lbl?(35-th):(37-th)*.5)- 4;
        gfx_x=xpos + (w-tw)*.5;
        do_overlay=="CC" ? gfx_set(0.9,.5,.2) : gfx_set(0.5,.5,.9);
        gfx_drawstr(do_overlay);
        do_overlay=3;
      );
      t=#str;
    );
    gfx_measurestr(t,tw,th);
    gfx_y=ypos + min((lbl?(40-th):(42-th)*.5) + do_overlay, 42-th);
    gfx_x=xpos + (w-tw)*.5;
    gfx_set(0.1);
    gfx_drawstr(t);
    lbl ? (
      gfx_set(.5);
      gfx_measurestr(lbl,tw,th);
      gfx_x=xpos+(w-tw)*.5;
      gfx_y=ypos+2;
      gfx_drawstr(lbl);
    );
    gfx_setfont(0);
  );
  w;
);


function draw_global_tweaker(xpos,ypos,globalmem,lane_offs,draw,lbl)
  local(before used i rec)
(
  before = globalmem[0];
  used = draw_value_tweaker(xpos,ypos,globalmem,draw,lbl);
  before != globalmem[0] ? (
    rec = mem_stlist;
    i = 0;
    loop(g_nchan,
      rec[lane_offs] = globalmem[0];
      rec += st_num;
      i += 1;
    );
    updatechfromrec();
    last_w = 0;
  );
  used;
);

function draw_global_lane_tweaker(xpos,ypos,lane_offs,draw,lbl)
  local(before used i rec src)
(
  src = mem_stlist + lane_offs;
  before = src[0];
  used = draw_value_tweaker(xpos,ypos,src,draw,lbl);
  before != src[0] ? (
    rec = mem_stlist;
    i = 0;
    loop(g_nchan,
      rec[lane_offs] = src[0];
      rec += st_num;
      i += 1;
    );
    updatechfromrec();
    last_w = 0;
  );
  used;
);

function draw_waveform(xpos,ycent,w,amp,start_offs,bptr,srclen,chan_idx)
  local(minv,maxv, i,v, di, dbptr z0 z0e z1 z1e z2 z2e)
(
  bptr += start_offs;
  <?
    0 /*enable this if you want to show/debug zeroing logic*/ ? printf("z2e = 0;") :
    loop(i=0; nch,
      printf("chan_idx == %d ? ( (z2e = ch%d.need_zero)>0 ? (
                  z0 = ch%d.nz_0; z0e = ch%d.nz_0e;
                  z1 = ch%d.nz_1; z1e = ch%d.nz_1e;
                  z2 = ch%d.nz_2;
                )) %s\n",i,i+1,i+1,i+1,i+1,i+1,i+1,
                i == nch-1 ? ";" : ":");
                i+=1;
      );
  ?>
  z2e > 0 ? (
    z0 += start_offs; z1 += start_offs; z2 += start_offs;
    z0e += start_offs; z1e += start_offs; z2e += start_offs;
  );
  minv=100;
  maxv=-100;
  i=xpos|0;
  dbptr = 1;
  while (srclen > 100000) ( srclen*=0.5; dbptr *= 2.0; );
  di = w / srclen;
  ycent|=0;
  loop(srclen,
    v = z2e <= 0 || (
        (bptr < z0 || bptr >= z0e) &&
        (bptr < z1 || bptr >= z1e) &&
        (bptr < z2 || bptr >= z2e)) ? bptr[0] : 0;
    minv=min(v,minv);
    maxv=max(v,maxv);
    bptr+=dbptr;
    v=0|(i+=di);
    v>xpos ? (
      gfx_line(xpos=v,ycent+amp*max(min(minv,1),-1),v,ycent+amp*max(min(maxv,1),-1),0);
      minv=100; maxv=-100;
    );
  );
);

function draw_topbar_button(xp, yp, str)
  instance(w,h,x,y)
  globals(gfx_x,gfx_y)
(
  gfx_measurestr(str, w, h);
  x=xp;
  y=yp;
  w+=3;
  h+=3;
  gfx_set(.5,.7,1);
  gfx_line(x,y,x+w,y);
  gfx_line(x+w,y,x+w,y+h);
  gfx_line(x,y+h,x+w,y+h);
  gfx_line(x,y,x,y+h);
  h+=1;
  w+=1;
  gfx_x=xp+2; gfx_y=yp+2;
  gfx_drawstr(str);
  gfx_x = xp+w;
);

function hit_topbar_button(xp,yp,cm)
  instance(w,h,x,y)
  globals(cap_mode, cap_last_y)
(
  xp>=x&&yp>=y&&xp<x+w&&yp<y+h ? (
    cap_last_y = yp;
    cap_mode=cm;
  );
);

function load_file(filename, channel) local(fh nch sr len rec rec2 buf buf2 v i)
(
  rec = mem_stlist + st_num * channel;
  buf = rec[st_buf];

  rec2 = (channel & 1) == 0 ? get_linked_rec(channel) : -1;
  buf2 = rec2 >= 0 ? rec2[st_buf] : -1;

  (fh = file_open(filename)) >= 0 ? (
    // REAPER 6.29+ will take nch='rqsr' sr>0 as a hint for desired samplerate
    file_riff(fh, nch='rqsr', sr=srate) > 0 ? (
      len = min((file_avail(fh) / nch)|0,g_maxlen);
      len > 0 ? (
        cfgp_sync[] != 0 && len > g_length ? len = g_length;

        // load samples, if channel is even and linked, load to second channel too
        i=0;
        loop(len,
          file_var(fh,v);
          buf[i]=v;
          nch>1 ? (
            file_var(fh,v);
            nch>2 ? loop(nch-2,file_var(fh,0));
          );
          buf2 >= 0 ? buf2[i]=v;
          i+=1;
        );
        cfgp_sync[] == 0 ? (
          !(g_active_mask & (-1 - (1<<channel) - (rec2>=0 ? 1<<(channel+1) : 0))) ? (
            g_length > 0 ? adjustsizes(len / g_length, 1) : g_length = len;
          );
        );
        len > 0 ? while (len < g_length) ? (
          memcpy(buf+len, buf, i=min(g_length-len, len));
          buf2 >= 0 ? memcpy(buf2+len, buf2, i);
          len += i;
        );
        rec[st_dirty] = max(rec[st_dirty],len);
        rec[st_state]==0 ? setstate_for_rec(rec, 1);
        rec2 >= 0 ? (
          rec2[st_dirty] = max(rec2[st_dirty],len);
          rec2[st_state]==0 ? setstate_for_rec(rec2, 1);
        );
      );
    );
    file_close(fh);
  );
);

function draw(ixpos, ypos) local(i gap rec mode force_redraw
  mx my mw t lx ty tw th rec2 wl
  now dropfile last_show_globals last_show_advanced last_pulse tx
  lane_h avail_lanes action_y action_h
  pr_s state_w peak_w wave_w sub_w mon_w
  state_x peak_x wave_x sub_x mon_x midi_x
  row_y row_cy wantr w
  g_curpk g_curpk_h gs_x gs_y gs_sz gi
  lasthalve lastlen lastoffs lastchanlink
  tweaker_w tweaker_h link_area_w extra_gap content_right r_pos
  mon_sz mon_btn_x rec_x ply_x rev_x clr_x undo_x sel_x fad_x div_x rdc_x ch_x t_ypos
  lane_ypos state_hover own_rec id_text)
(
  force_redraw = gfx_w != last_w || gfx_h != last_h ||
    lasthalve != cfgp_fade[] || lastlen != g_length ||
    lastoffs != g_offs || lastchanlink != cfgp_link[] ||
    last_show_globals != g_show_globals ||
    last_show_advanced != g_show_advanced ||
    last_pulse != (g_sysex_period_rate > 0);
  lasthalve = cfgp_fade[];
  lastlen = g_length;
  lastoffs = g_offs;
  lastchanlink = cfgp_link[];
  last_show_globals = g_show_globals;
  last_show_advanced = g_show_advanced;
  last_pulse = (g_sysex_period_rate > 0);

  gap = 4;
  now = time_precise();
  pr_s = min(gfx_w, gfx_h);
  pr_s < 1 ? pr_s = 1;

  gfx_getdropfile(0, dropfile=#) ? (
    gfx_getdropfile(-1);
    force_redraw = 1;
  ) : (
    dropfile = 0;
  );

  // Horizontal row-per-lane layout and control columns.
  // Compute this before drawing Globals so global controls can share the exact
  // same x coordinates as their lane siblings.
  action_h = 72;
  action_y = gfx_h - action_h - 21;  // 21px empty space below action strip
  lane_ypos = ypos + (g_show_globals ? 56 : 0);
  avail_lanes = action_y - lane_ypos;
  lane_h = max((avail_lanes / g_nchan)|0, 20);

  tweaker_w    = 45;
  tweaker_h    = 42;
  link_area_w  = 25;
  extra_gap    = 10;

  state_w = max((gfx_w * 0.06)|0, 46);
  peak_w  = 7;
  state_x = ixpos;
  content_right = gfx_w - link_area_w;

  mon_sz = min(tweaker_h, max(lane_h - 6, 16));

  r_pos = content_right - extra_gap;
  mon_x = r_pos - mon_sz;
  r_pos = mon_x - gap;

  mon_btn_x = r_pos - tweaker_w;
  r_pos = mon_btn_x - extra_gap;

  g_show_advanced ? (
    gfx_w > 900 ? ( fad_x = r_pos - tweaker_w; r_pos = fad_x - gap; ) : fad_x = -1;
    gfx_w > 820 ? ( div_x = r_pos - tweaker_w; r_pos = div_x - gap; ) : div_x = -1;
    gfx_w > 740 ? ( rdc_x = r_pos - tweaker_w; r_pos = rdc_x - gap; ) : rdc_x = -1;
    sel_x = r_pos - tweaker_w;
    r_pos = sel_x - extra_gap;
  ) : (
    fad_x = -1; div_x = -1; rdc_x = -1; sel_x = -1;
  );

  clr_x = r_pos - tweaker_w;
  r_pos = clr_x - gap;
  undo_x = r_pos - tweaker_w;
  r_pos = undo_x - gap;
  rev_x = r_pos - tweaker_w;
  r_pos = rev_x - gap;
  ply_x = r_pos - tweaker_w;
  r_pos = ply_x - gap;
  rec_x = r_pos - tweaker_w;
  r_pos = rec_x - extra_gap;
  ch_x = r_pos - tweaker_w;
  r_pos = ch_x - gap;

  wave_x = state_x + state_w;
  wave_w = max(r_pos - wave_x - gap, 30);

  // Common mode global strip
  g_show_globals ? (
    force_redraw ? (
      // Overall strip background
      PR.Color.Panel = "201A40FF";
      PR.Color.Contour = "403060FF";
      PR.DisplayPanel(
        (ixpos + (gfx_w - ixpos) * 0.5) / pr_s * 100,
        (ypos + 27) / pr_s * 100,
        (gfx_w - ixpos) / pr_s * 100,
        54 / pr_s * 100
      );
    );

    // Draw globals at the same x coordinates as lane siblings.
    // No CH in Globals; it remains lane-local only.
    rec_x >= 0 ? draw_global_tweaker(rec_x,  ypos+6, cfgp_common_rec,  st_note1, force_redraw, "REC/PLY");
    ply_x >= 0 ? draw_global_tweaker(ply_x,  ypos+6, cfgp_common_ply,  st_note2, force_redraw, "PLY/STP");
    rev_x >= 0 ? draw_global_tweaker(rev_x,  ypos+6, cfgp_common_rev,  st_note4, force_redraw, "REV");
    undo_x >= 0 ? draw_global_tweaker(undo_x, ypos+6, cfgp_common_undo, st_note6, force_redraw, "UNDO");
    clr_x >= 0 ? draw_global_tweaker(clr_x,  ypos+6, cfgp_common_clr,  st_note5, force_redraw, "CLR");

    g_show_advanced ? (
      sel_x >= 0 ? draw_global_tweaker(sel_x,  ypos+6, cfgp_common_sel,  st_note3, force_redraw, "SEL");
      rdc_x >= 0 ? draw_global_lane_tweaker(rdc_x, ypos+6, st_rdc, force_redraw, "RDC");
      div_x >= 0 ? draw_global_lane_tweaker(div_x, ypos+6, st_div, force_redraw, "DIV");
      fad_x >= 0 ? draw_global_lane_tweaker(fad_x, ypos+6, st_fade_size, force_redraw, "FAD");
    );

    mon_btn_x >= 0 ? draw_global_tweaker(mon_btn_x, ypos+6, cfgp_common_mon,  st_note7, force_redraw, "MON");

    // Global speaker icon: mouse-click cycles all lanes through the three speaker states.
    gs_x = mon_x; gs_y = ypos + 6; gs_sz = mon_sz;
    force_redraw ? (
      g_global_monmode == 0 ? gfx_set(0.2) :
      g_global_monmode == 1 ? gfx_set(0.3,0.3,0.7) :
                              gfx_set(0.9,0.8,0);
      gfx_rect(gs_x, gs_y, gs_sz, gs_sz);

      g_global_monmode == 0 ? gfx_set(0) :
      g_global_monmode == 2 ? gfx_set(1,1,1,1) : gfx_set(1,1,1,.25);
      draw_speaker(gs_x + gs_sz/2, gs_y + gs_sz/2, gs_sz/2);

      g_global_monmode == 0 ? (
        gfx_set(0);
        gfx_line(gs_x, gs_y, gs_x+gs_sz, gs_y+gs_sz);
        gfx_line(gs_x+gs_sz, gs_y, gs_x, gs_y+gs_sz);
      );
    );
    (mouse_cap&1) && !(last_mouse_cap&1) && !cap_mode && mouse_in(gs_x, gs_y, gs_sz, gs_sz) ? (
      g_global_monmode = (g_global_monmode + 1) % 3;
      gi = mem_stlist;
      loop(g_nchan,
        gi[st_monmode] = g_global_monmode;
        gi += st_num;
      );
      updatechfromrec();
      sliderchange(-1);
      last_w = 0;
    );
    ypos = lane_ypos;

    // ── DEBUG TELEMETRY BAR ──────────────────────────────────────────────────
    // Shows last common-mode action received: name, channel, lane, state change.
    // Remove this block once behavior is confirmed correct.
    0 && g_dbg_cmn_ch > 0 ? (
      gfx_set(0.05, 0.05, 0.12);
      gfx_rect(ixpos, ypos, gfx_w - ixpos, 14);
      gfx_setfont(1, "Arial", 10);
      gfx_set(0.6, 0.9, 0.6);
      gfx_x = ixpos + 4;
      gfx_y = ypos + 2;
      // For MON, state0/state1 hold monmode values, not loop state.
      strcmp(g_dbg_cmn_name, "MON") == 0 ? (
        gfx_printf("COMMON %s  ch=%d lane=%d  mon %d→%d",
          g_dbg_cmn_name, g_dbg_cmn_ch, g_dbg_cmn_idx+1,
          g_dbg_cmn_state0, g_dbg_cmn_state1);
      ) : strcmp(g_dbg_cmn_name, "") != 0 ? (
        gfx_printf("COMMON %s  ch=%d lane=%d  state %d→%d  dirty %d→%d  firstrec=%d",
          g_dbg_cmn_name, g_dbg_cmn_ch, g_dbg_cmn_idx+1,
          g_dbg_cmn_state0, g_dbg_cmn_state1,
          g_dbg_cmn_dirty0, g_dbg_cmn_dirty1, g_firstrec);
      ) : (
        gfx_printf("COMMON  ch=%d lane=%d  %s",
          g_dbg_cmn_ch, g_dbg_cmn_idx+1, g_dbg_cmn_name);
      );
      gfx_setfont(0);
      ypos += 16;
    );
    // ────────────────────────────────────────────────────────────────────────
  );

  rec = mem_stlist;
  i = 0;
  loop(g_nchan,
    row_y  = ypos + i * lane_h;
    row_cy = row_y + (lane_h/2)|0;

    dropfile && mouse_in(state_x, row_y, gfx_w - 16, lane_h) ? load_file(dropfile, i);

    !cap_mode && (mouse_cap&1) && !(last_mouse_cap&1) ? (
      // Link button hit zone: right 22px, spanning both lanes of a pair
      (i&1) && mouse_in(gfx_w - 25, row_y - lane_h, 25, lane_h*2) ? (
        cfgp_link[] ~= 1<<(i>>1);
        // Phase 3: when just linked, normalize partner state from owner
        cfgp_link[] & (1<<(i>>1)) ? (
          // rec points to partner (i, odd); rec2 = owner (i-1, even)
          rec2 = mem_stlist + (i-1) * st_num;
          rec[st_state]     = rec2[st_state];
          rec[st_monmode]   = rec2[st_monmode];
          rec[st_rdc]       = rec2[st_rdc];
          rec[st_div]       = rec2[st_div];
          rec[st_fade_size] = rec2[st_fade_size];
          updatechfromrec();
          // Canonicalize selection: if partner was selected, redirect to owner
          g_chan_selected == i ? g_chan_selected = i - 1;
        );
      ) : mouse_in(state_x, row_y, state_w, lane_h) ? (
        // Lane identifier click: inject PLY/STP toggle for the pair owner
        g_inject_midinote = 1024 + pair_owner_rec(i) + st_note2;
      ) : mouse_in(state_x + state_w, row_y, gfx_w - 22 - state_w, lane_h) ? (
        select_pair(i);
      );
    );

    mode = rec[st_state];
    is_chan_selected(i) ? mode |= 8;
    rec[st_dirty] ? mode |= 16;
    mode |= rec[st_monmode] << 8;
    g_firstrec ? mode |= 1<<30;

    force_redraw || rec[st_lastd] != mode || now > rec[st_lastpkupd] + 0.05 ? (
      rec[st_lastd] = mode;
      rec[st_lastpkupd] = now;
      wantr = 1;

      // Lane container panel (full width minus link area, colored by state)
      // State 2 = recording: vivid red so it's unmistakable vs stopped/playing.
      // State 1 = playing:   visible green.
      // Dirty   = stopped with content: dim blue-violet.
      // Empty   = off: very dark.
      rec[st_state] == 2 ? PR.Color.Panel = "6A1A1AFF" :
      rec[st_state] == 1 ? PR.Color.Panel = "1A4A1AFF" :
      rec[st_dirty]      ? PR.Color.Panel = "2A2A40FF" :
                           PR.Color.Panel = "252530FF";
      rec[st_state] == 2 ? PR.Color.Contour = "C04040FF" :
      rec[st_state] == 1 ? PR.Color.Contour = "40C040FF" :
                           PR.Color.Contour = "5060A0FF";
      (mode&8) ? PR.Color.Contour = "8090E0FF";
      PR.DisplayPanel(
        (state_x + (content_right - state_x) * 0.5) / pr_s * 100,
        (row_y + lane_h * 0.5) / pr_s * 100,
        (content_right - state_x) / pr_s * 100,
        lane_h / pr_s * 100
      );

      // State area fill: explicit raw rect painted after the PR panel so any
      // floating-point rounding in PR.DisplayPanel can't leave a gap at wave_x.
      // Covers from inside the left contour border (x+2) to exactly wave_x.
      rec[st_state] == 2 ? gfx_set(0x6A/255.0, 0x1A/255.0, 0x1A/255.0) :
      rec[st_state] == 1 ? gfx_set(0x1A/255.0, 0x4A/255.0, 0x1A/255.0) :
      rec[st_dirty]      ? gfx_set(0x2A/255.0, 0x2A/255.0, 0x40/255.0) :
                           gfx_set(0x25/255.0, 0x25/255.0, 0x30/255.0);
      gfx_rect(state_x + 2, row_y + 2, state_w - 2, lane_h - 4);

      // Lane number / hover play-stop symbol (left portion of container)
      PR.Color.Text = "FFFFFFFF";
      state_hover = mouse_in(state_x, row_y, state_w, lane_h);
      own_rec = pair_owner_rec(i);
      state_hover ? (
        own_rec[st_state] == 1 ? id_text = "■" :
        own_rec[st_dirty]  > 0 ? id_text = "▶" :
                                  id_text = sprintf(#, "%d", i+1);
      ) : (
        id_text = sprintf(#, "%d", i+1);
      );
      PR.DisplayText(
        (state_x + state_w*0.5) / pr_s * 100,
        (row_y + lane_h*0.5) / pr_s * 100,
        3.5,
        id_text
      );

      // Waveform sub-panel — inset 2 px top/bottom so the PR contour border
      // remains visible between lanes (matching the ~4 px border on the right side).
      gfx_set(0x14/255.0, 0x14/255.0, 0x20/255.0);
      gfx_rect(wave_x, row_y + 2, wave_w, lane_h - 4);
      // thin left separator between lane number area and waveform
      gfx_set(0x30/255.0, 0x30/255.0, 0x50/255.0);
      gfx_rect(wave_x, row_y + 2, 1, lane_h - 4);

      // Input peak meter — draw within the inset inner area
      g_curpk = max(min(log10(rec[st_peak_in] + 0.000001) * 20, 0), -68);
      g_curpk_h = ((g_curpk + 68) / 68 * (lane_h - 4))|0;
      gfx_set(0);
      gfx_rect(wave_x + 2, row_y + 2, peak_w, (lane_h - 4) - g_curpk_h);
      gfx_set(0.75, 0.75, 0);
      gfx_rect(wave_x + 2, row_y + 2 + ((lane_h - 4) - g_curpk_h), peak_w, g_curpk_h);

      // Waveform content
      gfx_set(0.5);
      rec[st_dirty] && (wl = floor(g_length / rec[st_div] + 0.5)) > 0 ?
        draw_waveform(wave_x + peak_w + gap, row_cy, wave_w - peak_w - gap*2, (lane_h-4)*0.4,
                      rec[st_buf], (g_offs % wl), wl, i);

      // Monitor icon (speaker, 3-state) — right-aligned
      mx = mon_x;
      my = row_cy - (mon_sz/2)|0;

      rec[st_monmode] == 0 ? gfx_set(0.2) :
      rec[st_monmode] == 1 ? ((mode&8) ? gfx_set(0.3,0.3,1.0) : gfx_set(0.3,0.3,0.7)) :
                              gfx_set(0.9,0.8,0);
      gfx_rect(mx, my, mon_sz, mon_sz);

      rec[st_monmode] == 0 ? gfx_set(0) :
      (rec[st_monmode] == 2 || (mode&8)) ? gfx_set(1,1,1,1) : gfx_set(1,1,1,.25);
      draw_speaker(mx + mon_sz/2, my + mon_sz/2, mon_sz/2);

      rec[st_monmode] == 0 ? (
        gfx_set(0);
        gfx_line(mx, my, mx+mon_sz, my+mon_sz);
        gfx_line(mx+mon_sz, my, mx, my+mon_sz);
      );

    ) : (
      wantr = 0;
    );

    // Sub-controls: CH, REC/PLY, PLY/STP, REV, UNDO, CLR, advanced SEL/RDC/DIV/FAD, MON, speaker
    t = mem_stlist + i * st_num;
    t_ypos = row_cy - (tweaker_h / 2)|0;
    // Partner lanes in a linked pair show a "linked" label instead of independent controls.
    is_linked_idx(i) && (i & 1) ? (
      wantr ? (
        gfx_set(0.18, 0.18, 0.28);
        ch_x >= 0 ? gfx_rect(ch_x, t_ypos, tweaker_w, tweaker_h);
        rec_x >= 0 ? gfx_rect(rec_x, t_ypos, tweaker_w, tweaker_h);
        ply_x >= 0 ? gfx_rect(ply_x, t_ypos, tweaker_w, tweaker_h);
        rev_x >= 0 ? gfx_rect(rev_x, t_ypos, tweaker_w, tweaker_h);
        undo_x >= 0 ? gfx_rect(undo_x, t_ypos, tweaker_w, tweaker_h);
        clr_x >= 0 ? gfx_rect(clr_x, t_ypos, tweaker_w, tweaker_h);
        sel_x >= 0 ? gfx_rect(sel_x, t_ypos, tweaker_w, tweaker_h);
        mon_btn_x >= 0 ? gfx_rect(mon_btn_x, t_ypos, tweaker_w, tweaker_h);
        rdc_x >= 0 ? gfx_rect(rdc_x, t_ypos, tweaker_w, tweaker_h);
        div_x >= 0 ? gfx_rect(div_x, t_ypos, tweaker_w, tweaker_h);
        fad_x >= 0 ? gfx_rect(fad_x, t_ypos, tweaker_w, tweaker_h);
        gfx_set(0.38, 0.38, 0.55);
        gfx_setfont(1,"Arial",9);
        gfx_measurestr("linked",tw,th);
        gfx_x = max(rec_x, 0) + (tweaker_w - tw) * 0.5;
        gfx_y = t_ypos + (tweaker_h - th) * 0.5;
        gfx_drawstr("linked");
        gfx_setfont(0);
      );
    ) : (
      ch_x >= 0 ? draw_value_tweaker(ch_x, t_ypos, t + st_midichan, wantr, "CH");
      rec_x >= 0 ? draw_value_tweaker(rec_x, t_ypos, t + st_note1, wantr,
              rec[st_state]==2 && !g_firstrec ? "PLY" : "REC");
      ply_x >= 0 ? draw_value_tweaker(ply_x, t_ypos, t + st_note2, wantr,
              rec[st_state]==1 ? "STP" : "PLY");
      rev_x >= 0 ? draw_value_tweaker(rev_x, t_ypos, t + st_note4, wantr, "REV");
      undo_x >= 0 ? draw_value_tweaker(undo_x, t_ypos, t + st_note6, wantr, "UNDO");
      clr_x >= 0 ? draw_value_tweaker(clr_x, t_ypos, t + st_note5, wantr, "CLR");

      g_show_advanced ? (
        sel_x >= 0 ? draw_value_tweaker(sel_x, t_ypos, t + st_note3, wantr, "SEL");
        rdc_x >= 0 ? draw_value_tweaker(rdc_x, t_ypos, t + st_rdc, wantr, "RDC");
        div_x >= 0 ? draw_value_tweaker(div_x, t_ypos, t + st_div, wantr, "DIV");
        fad_x >= 0 ? draw_value_tweaker(fad_x, t_ypos, t + st_fade_size, wantr, "FAD");
      );

      mon_btn_x >= 0 ? draw_value_tweaker(mon_btn_x, t_ypos, t + st_note7, wantr, "MON");
    );

    // Monitor right-click: cycle 3 modes
    ((mouse_cap&1) && !(last_mouse_cap&1) || (mouse_cap&2) && !(last_mouse_cap&2)) && !cap_mode &&
        mouse_in(mon_x, row_y, mon_sz, lane_h) ? (
      rec[st_monmode] = (rec[st_monmode]+1)%3;
      rec2 = get_linked_rec(i);
      rec2 >= 0 ? rec2[st_monmode] = rec[st_monmode];
      updatechfromrec();
      sliderchange(-1);
    );

    // Link button on right edge, spanning both lanes of a pair
    (i&1) && force_redraw ? (
      ty = row_y - lane_h;
      t = get_linked_rec(i) >= 0;
      t ? (
        gfx_set(0.15, 0.35, 0.65);
        gfx_rect(gfx_w-23, ty+2, 21, lane_h*2-4);
        gfx_set(0.85, 0.92, 1.0);
      ) : (
        gfx_set(0.14, 0.14, 0.22);
        gfx_rect(gfx_w-23, ty+2, 21, lane_h*2-4);
        gfx_set(0.38, 0.38, 0.52);
      );
      gfx_setfont(1,"Arial",9);
      gfx_measurestr("lnk",tw,th);
      gfx_x = gfx_w-23 + (21-tw)*0.5;
      gfx_y = ty + lane_h - th*0.5;
      gfx_drawstr("lnk");
      gfx_setfont(0);
    );

    i += 1;
    rec += st_num;
  );

  // Action button strip at bottom
  w = ((gfx_w - gap*7) / 8)|0;
  lx = 0;
  t = 0;
  force_redraw ? (
    // Strip background
    PR.Color.Panel = "101018FF";
    PR.Color.Contour = "1A1A28FF";
    PR.DisplayPanel(
      gfx_w * 0.5 / pr_s * 100,
      (action_y + action_h * 0.5) / pr_s * 100,
      gfx_w / pr_s * 100,
      action_h / pr_s * 100
    );
  );
  while ((i = mem_gen_order[t]) >= 0) (
    force_redraw ? (
      // Per-button colored panel (PR library replaces draw_button)
      i == 1  ? (PR.Color.Panel = "005F73FF"; PR.Color.Contour = "208099FF") :
      i == 2  ? (PR.Color.Panel = "007360FF"; PR.Color.Contour = "209980FF") :
      i == 3  ? (PR.Color.Panel = "00734DFF"; PR.Color.Contour = "209966FF") :
      i == 7  ? (PR.Color.Panel = "5A3A5AFF"; PR.Color.Contour = "806080FF") :
      i == 11 ? (PR.Color.Panel = "006060FF"; PR.Color.Contour = "208080FF") :
      i == 14 ? (PR.Color.Panel = "007000FF"; PR.Color.Contour = "20A020FF") :
      i == 15 ? (PR.Color.Panel = "805F00FF"; PR.Color.Contour = "B08020FF") :
               (PR.Color.Panel = "600000FF"; PR.Color.Contour = "902020FF");
      PR.DisplayPanel(
        (lx + w * 0.5) / pr_s * 100,
        (action_y + (action_h - 2) * 0.5) / pr_s * 100,
        (w - 2) / pr_s * 100,
        (action_h - 4) / pr_s * 100
      );
      gfx_set(1);
      gfx_measurestr(mem_gen_names[i], tw, th);
      gfx_x = lx + (w - tw) * 0.5;
      gfx_y = min(action_y + (action_h - th) * 0.5, gfx_h - 28);
      gfx_drawstr(mem_gen_names[i]);
      i == 11 ? fadesz_button.draw_topbar_button(lx+4, action_y+4,
                  sprintf(#, "%s%.0f mS",
                    w<98 ? "" : w<160 ? "fade " : "halve fade: ", lasthalve));
    );
    i += mem_gen_cfg;
    // MIDI assignment button: centered horizontally, half inside strip / half in empty space below
    draw_value_tweaker(lx + ((w - 45)/2)|0, action_y + action_h - 21, i, force_redraw, 0);
    !(last_mouse_cap&1) && (mouse_cap&1) && mouse_in(lx, action_y, w, action_h) ? (
      i == cfgp_reset        ? strcat(#mainthread_todo, "r") :
      i == cfgp_halve        ? strcat(#mainthread_todo, "h") :
      i == cfgp_double       ? strcat(#mainthread_todo, "d") :
      i == cfgp_double_norep ? strcat(#mainthread_todo, "D") :
      i == cfgp_export       ? strcat(#mainthread_todo, "e") :
      i == cfgp_xfade        ? strcat(#mainthread_todo, "x") :
      i == cfgp_playall || i == cfgp_playsel ? g_inject_midinote = 1024 + i;
    );
    t += 1;
    lx += w + gap;
  );
);

function draw_position(ypos) local(last_pos,last_len)
(
  last_w != gfx_w || last_h != gfx_h || last_pos != g_pos || last_len != g_length ? (
    last_len = g_length;
    last_pos = g_pos;
    gfx_set(0.05, 0.05, 0.13);  // dark navy trough (§2.4)
    gfx_rect(0,ypos,gfx_w,20);
    gfx_set(0.10, 0.22, 0.55);  // blue playhead progress
    g_length > 0 ? gfx_rect(0,ypos,g_pos/g_length * gfx_w,20);
    gfx_x=2;
    gfx_y=ypos+2;
    gfx_set(1,1,1);
    gfx_printf("%d mS\n%.1f BPM",g_length/srate * 1000,
      cfgp_sync[] ? tempo : estbpm(last_len));
  );
);

function draw_topbar(need_ref) local(s,i,t, lastlen, lastgate, lastlatch, lastclickcount, lastvclickoffs, lastoffs, lastsync, last_show_globals, last_show_advanced, last_pulse)
(
  need_ref == 0 ? (
    need_ref = (lastlen != g_length ||
                lastsync != cfgp_sync[] ||
                lastoffs != g_offs ||
                lastgate != cfgp_gate[] ||
                lastlatch != g_latchmode ||
                lastclickcount != (cfgp_clickcnt[]|0) ||
                lastvclickoffs != cfgp_vclick[] ||
                last_show_globals != g_show_globals ||
                last_show_advanced != g_show_advanced ||
                last_pulse != (g_sysex_period_rate > 0));
  );

  need_ref ? (
    gfx_set(0, 0, 0.31);  // 00004FFF deep navy per §2.4
    gfx_rect(0,0,gfx_w,14);

    gfx_x=60;

    lastsync=cfgp_sync[];
    projsync_button.draw_topbar_button(gfx_x+4,2,lastsync == 2 ? "sync: playback" : lastsync == 0 ? "sync: off" : "sync: project");

    lastlen = g_length;
    lastoffs = g_offs;
    lastgate = cfgp_gate[];
    lastvclickoffs = cfgp_vclick[];

    lastsync==0 ? (
      offs_button.draw_topbar_button(gfx_x+4,2, sprintf(#,"offs %.0f spls", g_offs));
      length_button.draw_topbar_button(gfx_x+4,2, sprintf(#,"%.0f spls", g_length));
    );

    lastclickcount = cfgp_clickcnt[]|0;

    clickcnt_button.draw_topbar_button(gfx_x+4,2,
      lastsync ?
       lastclickcount==0 ? "length: measure" : sprintf(#,"length: %d",lastclickcount)
       : sprintf(#,"click cnt: %d",lastclickcount)
    );

    lastclickcount>0||lastsync ? vclick_button.draw_topbar_button(gfx_x+4,2, lastvclickoffs>0 ? sprintf(#,"vclick: +%.1fmS",lastvclickoffs): "vclick: off");

    lastsync == 0 ?  gate_button.draw_topbar_button(gfx_x+4,2,cfgp_gate[] < g_infthreshdb ? "gate: -inf dB" : sprintf(#,"gate: %.0fdB",lastgate));

    latch_button.draw_topbar_button(gfx_x+4,2, (lastlatch=g_latchmode) ? "latch on" : "latch off");
    common_button.draw_topbar_button(gfx_x+4,2, (last_show_globals=g_show_globals) ? "Globals on" : "Globals off");
    advanced_button.draw_topbar_button(gfx_x+4,2, (last_show_advanced=g_show_advanced) ? "Advanced on" : "Advanced off");
    pulse_button.draw_topbar_button(gfx_x+4,2, (last_pulse=(g_sysex_period_rate>0)) ? "Pulse on" : "Pulse off");
  );

  (mouse_cap&1) && !(mouse_cap&2) ? (
    !(last_mouse_cap&1) ? (

      projsync_button.hit_topbar_button(mouse_x,mouse_y,-1) ? (
        cfgp_sync[] = (cfgp_sync[]+1)%3;
        g_slider_sync = cfgp_sync[];
        g_offs = 0;
      ) : latch_button.hit_topbar_button(mouse_x,mouse_y,-1) ? (
        // toggle
        cfgp_latch[] = g_latchmode = !g_latchmode;
      ) : common_button.hit_topbar_button(mouse_x,mouse_y,-1) ? (
        g_show_globals = !g_show_globals;
        mem_gen_cfg[23] = g_show_globals;
        sliderchange(-1); // persist to @serialize
        last_w = 0;       // force full redraw to show/hide Globals strip
      ) : advanced_button.hit_topbar_button(mouse_x,mouse_y,-1) ? (
        g_show_advanced = !g_show_advanced;
        mem_gen_cfg[24] = g_show_advanced;
        sliderchange(-1); // persist to @serialize
        last_w = 0;       // force full redraw to show/hide advanced controls
      ) : pulse_button.hit_topbar_button(mouse_x,mouse_y,-1) ? (
        g_sysex_period_rate = g_sysex_period_rate > 0 ? 0 : 1.0;
        mem_gen_cfg[29] = g_sysex_period_rate > 0;
        sliderchange(-1); // persist to @serialize
      ) : (
        (lastsync==0 && (gate_button.hit_topbar_button(mouse_x,mouse_y,cfgp_gate)||
                         length_button.hit_topbar_button(mouse_x,mouse_y,cfgp_length)||
                         offs_button.hit_topbar_button(mouse_x,mouse_y,cfgp_offs))
        ) ||
        clickcnt_button.hit_topbar_button(mouse_x,mouse_y,cfgp_clickcnt)||
        ((lastclickcount||lastsync)&&vclick_button.hit_topbar_button(mouse_x,mouse_y,cfgp_vclick))||
        fadesz_button.hit_topbar_button(mouse_x,mouse_y,cfgp_fade);
      );
    ) : (cap_mode >= mem_gen_cfg && cap_mode < mem_gen_cfg+mem_gen_sz && (dy = mouse_y - cap_last_y)) ? (
      cap_mode == cfgp_gate ? (
        cap_mode[0] = min(max(cap_mode[0]-dy*.2,g_infthreshdb),-1);
      ) : cap_mode == cfgp_fade ? (
        cap_mode[0] = min(max(cap_mode[0]-dy*0.05,0),500);
      ) : cap_mode == cfgp_length ? (
        t = g_length - dy*((mouse_cap&8)?4:100);
        (t=max(t|0,1)) != g_length ? (
          g_length = t;
          g_pos %= g_length;
          g_edgetrim_drawstate=1;
        );
      ) : cap_mode == cfgp_clickcnt ? (
        g_slider_click_cnt = (cap_mode[0] = min(max(cap_mode[0]-dy*0.05,0),64))|0;
      ) : cap_mode == cfgp_vclick ? (
        cap_mode[0] = min(max(cap_mode[0]-dy*0.05,0),100);
      ) : cap_mode == cfgp_offs ? (
        t = (dy*((mouse_cap&8)?4:100))|0;
        t ? (
          i = g_offs+g_length;
          g_offs = min(max(g_offs-t,0),i-1);
          t = (i-g_length) - g_offs;
          g_length = i - g_offs;
          g_pos = (g_pos + t) % g_length;
          g_edgetrim_drawstate=1;
        );
      );
      cap_last_y=mouse_y;
    );
  );

  // animated logo
  gfx_x=0;
  gfx_y=4;
  t=time_precise();
  s="Ultra<?printf("%d",nch)?>";
  i=0;
  loop(strlen(s),
    gfx_set(sin(t+i*0.2)*0.3+0.5, cos(t*.61+i*0.5)*.7+0.3, sin(t*2.1-i*0.6)*.3+0.7);
    gfx_drawchar(str_getchar(s,i));
    i+=1;
  );
);

function get_vclick_pos(latms) local(tmp)
(
  tmp=cfgp_sync[];
  (vclick_len = cfgp_clickcnt[]|0)<1 && tmp ? vclick_len=ts_num;
  vclick_len >= 1 && (
    tmp ? (
      (tmp!=2 && g_active_mask) || (play_state&1);
    ) : (
      g_active_mask && !g_firstrec
    );
  ) ? (
    tmp = g_pos - latms*srate*0.001;
    tmp < 0 ? tmp += g_length;
    (tmp >= 0) ? (
      floor(g_pos * vclick_len / g_length)
    ) : -1;
  ) : -1;
);

function draw_vclick(pos,clen) 
  global(gfx_w,gfx_h,gfx_x,gfx_y)
  local(sw,sh,str)
(
  str=sprintf(#,"%d",1 + pos);

  gfx_w > gfx_h * 2 ? (
    gfx_setfont(2,"Arial",gfx_h);
    gfx_measurestr(str,sw,sh);
    gfx_x = (gfx_w-sw*.8) * pos / clen;
    gfx_y = 0;
  ) : gfx_w < gfx_h * .5 ? (
    gfx_setfont(2,"Arial",gfx_w*.7);
    gfx_measurestr(str,sw,sh);
    gfx_y = (gfx_h-sh*.5) * pos / clen;
    gfx_x = gfx_w*.5 - sw*.5;
  ) : (
    gfx_setfont(2,"Arial",min(gfx_h,gfx_w)*.5);
    gfx_measurestr(str,sw,sh);
    gfx_x=gfx_w*.5 + ((pos&1)?sw*.3:-sw*1.3);
    gfx_y=gfx_h*.5 + ((pos&2)?0:-sh);
  );
  gfx_set(1);
  gfx_drawstr(str);
  gfx_setfont(0);
);

function draw_trim_waveform(xpos, ypos, w, h, chan, isend)
  global(g_length mem_stlist st_num st_dirty st_buf g_offs srate) 
  local(rec buf len maxl linepos xpos2 w2)
(
  rec = mem_stlist + chan*st_num;
  gfx_set(0.25);
  gfx_rect(xpos,ypos,w,h);
  
  gfx_set(1);
  len = (w * 0.0005 * srate)|0; // 0.5ms/pixel
  xpos2 = xpos;
  w2=w;

  isend ? (
    buf = g_offs + g_length - len*.8;
  ) : (
    buf = g_offs - len*.2;
  );

  buf < 0 ? (
    xpos2 -= buf*w/len;
    len += buf;
    w2 -= xpos2-xpos;
    buf = 0;
  );
  
  g_length && rec[st_dirty] ? 
    draw_waveform(xpos2,ypos+h*.5,w2,h*.25,rec[st_buf],buf,len,chan);
    
  gfx_set(0,.5,.7,.5);
  xpos += (w*(isend?.8:.2))|0;
  gfx_line(xpos,ypos,xpos,ypos+h);
);

!(gfx_ext_flags&2) ? (
  gfx_clear=-1;

  // Global PR color defaults for this frame (§2.4 theme palette)
  PR.Color.Contour = "5060A0FF";
  PR.Color.Text    = "FFFFFFFF";
  PR.Color.Panel   = "252530FF";
  PR.Color.Shadow  = "00000080";

  vclick_pos = cfgp_vclick[]>0 ? get_vclick_pos(cfgp_vclick[]) : -1;

  last_vclick_pos != vclick_pos ? (
    last_w=0;
    last_vclick_pos=vclick_pos;
  );

  last_w != gfx_w || last_h != gfx_h ? (
    gfx_set(0.05, 0.05, 0.10);  // deep dark navy base (§2.4)
    gfx_rect(0,0,gfx_w,gfx_h);
  );

  draw_topbar(last_w != gfx_w || last_h != gfx_h);
  draw_position(15);
  draw(0, 40);
  
  gfx_x=0;
  gfx_y=gfx_h-8;
  gfx_set(0);
  gfx_rect(gfx_x,gfx_y,6*8,8);
  gfx_set(.3);
  g_peakvol < g_infthresh ? (
    gfx_printf("-inf");
  ) : (
    gfx_printf("%.0fdB",log10(g_peakvol)*20);
    g_peakvol *= 0.93;
  );
  
  g_lastmsg>=0 && g_lastmsg_draw!=g_lastmsg ? (
    g_lastmsg_t = format_note(#str,g_lastmsg);
    gfx_x=gfx_w-g_lastmsg_w;
    g_lastmsg_w = (strlen(#str) + (g_lastmsg_t?3:0)) * 8;
    gfx_x = min(gfx_x, gfx_w-g_lastmsg_w);
    gfx_y=gfx_h-8;
    gfx_set(0);
    gfx_rect(gfx_x,gfx_y,gfx_w-gfx_x,8);
    gfx_set(.3);
    gfx_x = gfx_w-g_lastmsg_w;
    gfx_printf("%s%s",g_lastmsg_t==1?"CC ":g_lastmsg_t?"PC ":"",#str);
    g_lastmsg_draw=g_lastmsg;
  );
  
  last_w = gfx_w;
  last_h = gfx_h;
  last_mouse_cap = mouse_cap;
  g_mon_changed ? (
    sliderchange(-1);
    g_mon_changed = 0;
    last_w = 0; // force redraw so mon icon updates
  );
  0 == (mouse_cap & 3) ? (
    cap_mode > 0 ? (
      sliderchange(-1);
    );
    cap_mode = 0;
  );
  
  vclick_pos >= 0 ? draw_vclick(vclick_pos,vclick_len);
  
  cap_mode == cfgp_offs || cap_mode == cfgp_length ? (
    g_edgetrim_drawstate>=0 ? (
      draw_trim_waveform(0,40,gfx_w,gfx_h-40, max(g_chan_selected,0), cap_mode == cfgp_length);
      g_edgetrim_drawstate=1;
    );
  ) : (
    g_edgetrim_drawstate>0 ? (
      last_w=-1;
      g_edgetrim_drawstate=0;
    );  
  );
); // !(gfx_ext_flags&2)


function export()  local(rec, flag, tidx, idx, ster, l)
(
  rec = mem_stlist;
  flag=1<<16; // go to end of project
  flag|=2<<16; // use tempo from next parameter
  tidx = idx = 0;
  g_length > 0 ? loop(g_nchan,
    !(idx&1) || get_linked_rec(idx)<0 ? (
      ster = get_linked_rec(idx);
      rec[st_state] ? (
        l = (g_length / rec[st_div])|0;
        export_buffer_to_project(rec[st_buf]+g_offs%l,l, ster>=0 ? 2 : 1,srate,tidx, flag,
          flag?(cfgp_sync[] ? tempo : estbpm(g_length)),
          ster>=0 ? ster[st_buf] - rec[st_buf] : 0
        );
        flag=0; // only go to end/set tempo for first item
      );
      tidx += 1;
    );
    idx += 1;
    rec+=st_num;
  );
);

strlen(#mainthread_todo) > 0 ? (
  mtc = str_getchar(#mainthread_todo,0);
  strcpy_substr(#mainthread_todo,#mainthread_todo,1);

  mtc == 'r' ? reset() :
  mtc == 'h' ? adjustsizes(0.5,1) :
  mtc == 'd' ? adjustsizes(2,1) :
  mtc == 'D' ? adjustsizes(2,0) :
  mtc == 'e' ? export() :
  mtc == 'x' ? adjustsizes(1, 0);
);
