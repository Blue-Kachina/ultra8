@init

// constants
g_nchan = <? printf("%d",nch) ?>;
g_max_alloc = __memtop(); // JSFX memory available
g_latchq_len = 1024; // 1024 midi events queueable for latch mode
g_maxlen = ((g_max_alloc - 4096 - g_latchq_len*3)/(g_nchan*3))|0; // one-third each: active buffer, undo snapshot, redo snapshot
g_infthreshdb = -120;
g_infthresh = 10^(g_infthreshdb/20);
g_latchmode=0;

// per-channel state/configuration record (mem_stlist)
st_monmode = 0; // mirrors chX.monmode
st_note_recply = 1; // mirrors chX.note/chX.note2/chX.note3/chX.note4
st_note_plystp = 2;
st_note_sel = 3;
st_note_rev = 4; // reverse note
st_note_clr = 17; // clear lane
st_note_undo = 18; // undo lane
st_note_mon = 19; // monitor two-state toggle

st_state = 5; // 0=off, 1=play, 2=recording
st_buf   = 6; // pointer to audio buffer
st_dirty = 7;  // set if buffer is dirty, and also may indicate how much of it
               // is using max(mem_stlist[st_dirty],chX.dirty_top+1)
st_lastd = 8; // UI flags for mode + monitor + dirty
st_lastpkupd = 9; // time of last peak drawin
st_peak_in = 10;
st_rdc = 11; // msec, chX.rdc is samples
st_div = 12; // subdiv, 1=normal, chX.div is 1/this
st_fade_size = 13; // fadeout size
st_midichan  = 14; // per-lane MIDI channel for common-mode routing (1–16)
st_undo_buf  = 15; // pointer to pre-allocated undo snapshot buffer
st_undo_len  = 16; // samples stored in snapshot (0 = no snapshot available)
st_redo_buf  = 20; // pointer to pre-allocated redo snapshot buffer (Unit 2.1)
st_redo_len  = 21; // samples stored in redo snapshot (0 = no redo available)
// ── Flex Mode per-lane length metadata (Phase 1) ─────────────────────────────
st_loop_len      = 22; // committed loop length in samples (0 = empty / not yet set)
st_undo_loop_len = 23; // loop length saved alongside the undo audio snapshot
st_redo_loop_len = 24; // loop length saved alongside the redo audio snapshot
st_loop_phase    = 25; // g_flex_pos value at which this lane's buffer position 0 begins
// ─────────────────────────────────────────────────────────────────────────────
st_disp_mult     = 26; // display amplitude multiplier (computed after recording; 1.0 = no boost)
st_num = 27;
MAX_DISPLAY_MULT = 20.0; // waveform display boost cap (20x ~= +26 dB)

// ── Command dispatch constants (Phase 2) ─────────────────────────────────────
// CMD_* — logical looper actions, independent of how they were triggered.
// Pass to execute_lane_command(cmd, lane_idx, source).
CMD_RECPLY    = 1;  // REC/PLY toggle
CMD_PLYSTP    = 2;  // PLY/STP toggle
CMD_CLR       = 3;  // clear lane(s)
CMD_UNDO_REDO = 4;  // UNDO if no redo available, REDO otherwise
CMD_REV       = 5;  // reverse toggle
CMD_MON       = 6;  // two-state monitor toggle
CMD_SEL       = 7;  // select lane (special: translates to per-lane inject)
CMD_PLAY_ALL  = 8;  // play-all / stop-all

// SRC_* — where the command originated. Reserved for future logging / throttling.
SRC_MIDI_COMMON = 1;  // common-mode MIDI dispatch (channel-per-lane)
SRC_MIDI_LANE   = 2;  // per-lane MIDI assignment
SRC_UI          = 3;  // mouse click in @gfx
SRC_LATCH       = 4;  // dequeued from the latch queue
// ─────────────────────────────────────────────────────────────────────────────


function recalc_fades() (
  g_fadespeed = exp(-1/(srate * 0.002));  // fade speed for monitoring
  g_slope_recin = 1/(srate * 0.001); // fade length for starting rec
  g_slope_recout = -1/(srate * 0.030); // fade length for ending rec
  g_slope_playin = 1/(srate * 0.050); // fade length for starting playback
  g_slope_playout = -1/(srate * 0.050); // fade length for ending playback
);

recalc_fades();

function get_section(s) local(r) ( s?(r=s):r; );

function alloc(sz) ( (this.top+=sz)-sz; );

function updatefromrec() instance(rec)
(
  this.note  = rec[st_note_recply];
  this.note2 = rec[st_note_plystp];
  this.note3 = rec[st_note_sel];
  this.note4 = rec[st_note_rev];
  this.note5 = rec[st_note_clr];
  this.note6 = rec[st_note_undo];
  this.note7 = rec[st_note_mon];
  this.monmode = rec[st_monmode];
  this.rdc =(rec[st_rdc]*.001*srate+.5)|0;
  this.div = 1 / rec[st_div];
);

function init(x, n1,n2,n3)
  instance(idx rec buf monvol fpos fpos2 fpos_slope fpos2_slope dirty_top)
(
  idx = x;
  fpos_slope = monvol = fpos = fpos2 = fpos2_slope = 0;
  dirty_top = -1;
  buf = alloc(g_maxlen);

  rec = mem_stlist + x*st_num;
  rec[st_note_recply] = n1;
  rec[st_note_plystp] = n2;
  rec[st_note_sel] = n3;
  rec[st_note_rev] = 128;
  rec[st_note_clr] = 128; // CLR default off
  rec[st_note_undo] = 128; // UNDO default off
  rec[st_note_mon] = 128; // MON default off
  rec[st_state]=0;
  rec[st_lastd]=-1;
  rec[st_dirty]=0;
  rec[st_monmode] = 1;
  rec[st_buf] = buf;
  rec[st_peak_in] = 0;
  rec[st_rdc] = 0;
  rec[st_div] = 1;
  rec[st_fade_size] = 0;
  rec[st_midichan] = x + 1; // default: lane 0 → ch1, lane 1 → ch2, etc.
  rec[st_undo_buf] = 0;     // set by post-init alloc loop
  rec[st_undo_len] = 0;     // no snapshot initially
  rec[st_redo_buf] = 0;     // set by post-init alloc loop (Unit 2.1)
  rec[st_redo_len] = 0;     // no redo available initially
  // Flex Mode length metadata — all zero until a Flex recording commits (Phase 1)
  rec[st_loop_len]      = 0;
  rec[st_undo_loop_len] = 0;
  rec[st_redo_loop_len] = 0;
  rec[st_loop_phase]    = 0;
  rec[st_disp_mult]     = 0; // no boost until first recording commits

  this.updatefromrec();
);

// clearing the buffer when starting recording on a particular channel
function set_need_zero(dt) global(g_maxlen) instance(need_zero nz_0) (
  need_zero = max(need_zero, min(g_maxlen,dt+1));
  nz_0 = -1;
);
function process_need_zero(p1, p2) global()
  instance(need_zero nz_0 nz_0e nz_1 nz_1e nz_2 buf)
  local(sz)
(
  nz_0 === -1 ? (
    // three write pointers:  0..p1 p1..p2 p2..need_zero
    nz_0 = 0;
    nz_0e = nz_1 = min(p1,p2);
    nz_1e = nz_2 = max(p1,p2);
  );

  (sz = min(8, nz_0e-nz_0)) > 0 ? ( memset(buf + nz_0, 0, sz); nz_0 += sz; );
  (sz = min(8, nz_1e-nz_1)) > 0 ? ( memset(buf + nz_1, 0, sz); nz_1 += sz; );
  (sz = min(8, need_zero-nz_2)) > 0 ? ( memset(buf + nz_2, 0, sz); nz_2 += sz; );
  nz_2 >= need_zero && nz_1 >= nz_1e && nz_0>=nz_0e ? need_zero=0;
);


function get_linked_rec(idx) (
  cfgp_link[]&(1<<(idx>>1)) ? mem_stlist+st_num*(idx~1) : -1;
);

function is_chan_selected(idx) (
  g_chan_selected == idx ||
    ((cfgp_link[]&(1<<(idx>>1))) && g_chan_selected == idx~1);
);

// ── Pair helper functions ─────────────────────────────────────────────────────
// Returns non-zero if idx belongs to a linked pair.
function is_linked_idx(idx) (
  cfgp_link[] & (1 << (idx >> 1));
);

// Returns the owner (even-numbered) lane index for any lane in a linked pair,
// or idx itself when not linked.
function pair_owner_idx(idx) (
  is_linked_idx(idx) ? (idx & -2) : idx;
);

// Returns the partner lane index (idx XOR 1) when linked, -1 otherwise.
function pair_partner_idx(idx) (
  is_linked_idx(idx) ? (idx ~ 1) : -1;
);

// Returns a pointer to the owner lane's state record.
function pair_owner_rec(idx) (
  mem_stlist + pair_owner_idx(idx) * st_num;
);

// Returns true only for laneB (odd index) in a linked pair.
// Overlay controls are drawn on laneB's iteration so laneA cannot be
// overwritten by laneB panel/waveform draws that come after laneA.
function should_draw_pair_overlay(idx) (
  is_linked_idx(idx) && (idx & 1);
);

// Returns a pointer to the partner lane's state record, or -1 when unlinked.
function pair_partner_rec(idx) local(p) (
  p = pair_partner_idx(idx);
  p >= 0 ? mem_stlist + p * st_num : -1;
);

// Returns non-zero if either lane of the pair has recorded content (st_dirty > 0).
// Checks both owner and partner so PLY/STP guards correctly on linked pairs.
function pair_has_content(idx) local(oidx pidx orec prec has) (
  oidx = pair_owner_idx(idx);
  pidx = pair_partner_idx(oidx);
  orec = mem_stlist + oidx * st_num;

  has = orec[st_dirty] > 0;

  pidx >= 0 ? (
    prec = mem_stlist + pidx * st_num;
    has |= prec[st_dirty] > 0;
  );

  has;
);
// ─────────────────────────────────────────────────────────────────────────────

// ── Flex Mode helpers (Phase 1 / Phase 2) ────────────────────────────────────

// Returns non-zero when Flex Mode is active.
function is_flex_mode() ( g_flex_enabled != 0; );

// Returns non-zero when a base quantum has been established.
function has_flex_base() ( g_flex_base_len > 0; );

// Returns the committed loop length for the given lane, resolving through the
// pair owner when lanes are linked.  Returns 0 when the lane is empty.
function get_effective_loop_len(idx) local(oidx orec) (
  oidx = pair_owner_idx(idx);
  orec = mem_stlist + oidx * st_num;
  orec[st_loop_len];
);

// Sets st_loop_len on both the owner and the partner lane (when linked).
function set_effective_loop_len(idx, len) local(oidx pidx orec prec) (
  oidx = pair_owner_idx(idx);
  pidx = pair_partner_idx(oidx);
  orec = mem_stlist + oidx * st_num;
  orec[st_loop_len] = len;
  pidx >= 0 ? (
    prec = mem_stlist + pidx * st_num;
    prec[st_loop_len] = len;
  );
);

// Returns the Flex recording-start phase for lane idx (via pair owner).
// Phase = the g_flex_pos value at which buffer position 0 was recorded.
function get_effective_loop_phase(idx) local(oidx orec) (
  oidx = pair_owner_idx(idx);
  orec = mem_stlist + oidx * st_num;
  orec[st_loop_phase];
);

// Sets st_loop_phase on both the owner and the partner lane (when linked).
function set_effective_loop_phase(idx, phase) local(oidx pidx orec prec) (
  oidx = pair_owner_idx(idx);
  pidx = pair_partner_idx(oidx);
  orec = mem_stlist + oidx * st_num;
  orec[st_loop_phase] = phase;
  pidx >= 0 ? (
    prec = mem_stlist + pidx * st_num;
    prec[st_loop_phase] = phase;
  );
);

// Returns the effective playback length for lane idx:
//   Flex Mode + lane has content  → get_effective_loop_len(idx)
//   Flex Mode + lane empty        → g_flex_base_len (or g_length fallback)
//   Non-Flex Mode                 → g_length
function get_lane_play_len(idx) local(ll) (
  is_flex_mode() ? (
    ll = get_effective_loop_len(idx);
    ll > 0 ? ll : (g_flex_base_len > 0 ? g_flex_base_len : g_length);
  ) : (
    g_length;
  );
);

// Returns the effective playback position for lane idx:
//   Flex Mode (steady-state, g_firstrec==0) → (g_flex_pos - lane_phase) modulo the lane's own play length
//   Flex Mode (first-rec, g_firstrec>0)     → g_pos (avoids g_pos%g_pos=0 trap)
//   Non-Flex                                → g_pos
// The per-lane phase (st_loop_phase) stores the g_flex_pos at which buffer
// position 0 was recorded.  Subtracting it ensures that a lane recorded
// starting mid-session plays back from the correct buffer offset.
function get_lane_play_pos(idx) local(ll phase pos) (
  is_flex_mode() && g_firstrec == 0 ? (
    ll = get_lane_play_len(idx);
    ll > 0 ? (
      phase = get_effective_loop_phase(idx);
      pos = (g_flex_pos - phase) % ll;
      pos < 0 ? pos += ll;
      pos;
    ) : (
      0;
    );
  ) : (
    g_pos;
  );
);

// Returns the playback progress of lane idx as a fraction in 0.0 ... 1.0.
// Empty lanes (st_dirty == 0) return 0 so they never show misleading progress.
// Non-Flex mode: all lanes track the global g_pos / g_length, matching the top bar.
// Flex mode: each lane reports progress through its own (possibly longer) loop,
//   so a 1x lane and a 4x lane each complete one full cycle in their own time.
function get_lane_progress_frac(idx) local(rec lane_len lane_pos frac) (
  rec = mem_stlist + idx * st_num;
  rec[st_dirty] <= 0 ? (
    frac = 0;
  ) : (
    lane_len = get_lane_play_len(idx);
    lane_pos = get_lane_play_pos(idx);
    frac = lane_len > 0 ? lane_pos / lane_len : 0;
    frac = min(1, max(0, frac));
  );
  frac;
);

// Returns the waveform display length (in samples) for lane idx (ultra_redesign.md Phase 3).
// This is the number of samples that draw_waveform() should treat as one full loop.
// Flex mode + committed lane: use st_loop_len so longer recordings are compressed to fit.
// Flex mode + lane still recording (st_loop_len == 0): fall back to g_length so the
//   waveform keeps moving rather than freezing at zero.
// Classic mode: always g_length (unchanged behaviour).
// rec[st_div] is applied after picking the base length, preserving subdivision display.
function get_lane_waveform_display_len(idx, rec) local(wl) (
  wl = 0;
  is_flex_mode() ? (
    rec[st_loop_len] > 0 ? (
      wl = rec[st_loop_len];
    ) : (
      wl = g_length;
    );
  ) : (
    wl = g_length;
  );
  rec[st_div] > 0 && wl > 0 ? (
    wl = floor(wl / rec[st_div] + 0.5);
  );
  wl;
);

// Returns the waveform start-offset (in samples) for lane idx.
// In classic mode: g_offs % wl (matches the legacy Super8 behavior).
// In Flex mode:    0 — each lane's playback uses st_loop_phase, not g_offs,
//                      so offsetting the waveform by g_offs would be incorrect.
// wl = the waveform display length (e.g. from get_lane_waveform_display_len).
function get_lane_waveform_start_offset(wl) (
  is_flex_mode() ? 0 : (wl > 0 ? g_offs % wl : 0);
);

// Scan srclen samples at bptr and return a display amplitude multiplier.
// Returns clamp(1 / peak, 1.0, MAX_DISPLAY_MULT) so quiet recordings
// fill the waveform area visually without altering audio.
// Called once per lane after recording commits (lazy, from @gfx draw loop).
function compute_disp_mult(bptr, srclen)
  local(peak v i)
(
  peak = 0;
  i = 0;
  loop(srclen,
    v = bptr[i]; v < 0 ? v = -v;
    v > peak ? peak = v;
    i += 1;
  );
  peak > 0 ? min(1.0 / peak, MAX_DISPLAY_MULT) : 1.0;
);

// Returns the committed length multiple relative to the Flex base.
// Returns 0 for empty lanes or when no base exists.
function get_lane_length_multiple(idx) local(ll) (
  (g_flex_base_len > 0 && (ll = get_effective_loop_len(idx)) > 0) ?
    (ll / g_flex_base_len + 0.5) | 0 : 0;
);

// Validates and repairs per-lane Flex metadata for internal consistency.
// Call after clear, reset, or @serialize restore to ensure the Flex
// invariants hold before audio processing resumes:
//   1. st_loop_len must be 0 for empty lanes (st_dirty == 0).
//   2. st_loop_phase must be 0 for empty lanes.
//   3. st_loop_len must be <= g_maxlen.
//   4. Undo/redo loop lengths are clamped to g_maxlen.
// This function does NOT call recalc_flex_base_len() — callers must do that
// afterward if base length may have changed.
function validate_flex_state() local(lp) (
  lp = mem_stlist;
  loop(g_nchan,
    // Rule 1/2: empty lane must have zeroed Flex metadata.
    lp[st_dirty] == 0 ? (
      lp[st_loop_len]   = 0;
      lp[st_loop_phase] = 0;
    );
    // Rule 3: clamp loop length to buffer capacity.
    lp[st_loop_len] > g_maxlen ? lp[st_loop_len] = g_maxlen;
    // Rule 4: clamp undo/redo loop lengths.
    lp[st_undo_loop_len] > g_maxlen ? lp[st_undo_loop_len] = 0;
    lp[st_redo_loop_len] > g_maxlen ? lp[st_redo_loop_len] = 0;
    lp += st_num;
  );
);

// Re-derive g_flex_base_len from the minimum non-zero st_loop_len across all
// lanes.  Call after any clear that may have removed the current base lane.
function recalc_flex_base_len() local(lp) (
  g_flex_base_len = 0;
  lp = mem_stlist;
  loop(g_nchan,
    (lp[st_loop_len] > 0 && (g_flex_base_len == 0 || lp[st_loop_len] < g_flex_base_len)) ? (
      g_flex_base_len = lp[st_loop_len];
    );
    lp += st_num;
  );
);

// ── Flex Mode recording helpers (Phase 5 quantization) ───────────────────────

// Quantize a raw recorded length to the nearest musical multiple of g_flex_base_len.
// Rules (see flex_mode.md §Quantization Rules):
//   1. Default: ceiling — round UP to the next whole multiple.
//   2. Late-stop tolerance: if the raw length is within g_flex_late_tolerance_smpls
//      samples PAST the nearest lower boundary, snap DOWN to that boundary.
//   3. Minimum committed multiple = 1.
//   4. Maximum committed length = largest whole multiple ≤ g_maxlen.
// Returns 0 on invalid input (no base, base == 0, raw_len == 0).
function quantize_flex_record_len(raw_len) local(base, nearest_boundary, lateness, mult, max_mult, committed) (
  base = g_flex_base_len;
  (base <= 0 || raw_len <= 0) ? (
    0;  // degenerate — caller should treat 0 as a failure
  ) : (
    // Late-stop tolerance: snap down to nearest_boundary if within tolerance.
    nearest_boundary = (raw_len / base + 0.5) | 0;  // round to nearest integer multiple
    nearest_boundary = max(1, nearest_boundary) * base;
    lateness = raw_len - nearest_boundary;
    (lateness > 0 && lateness <= g_flex_late_tolerance_smpls) ? (
      committed = nearest_boundary;
    ) : (
      // Ceiling: round up to the next whole multiple.
      mult = max(1, ceil(raw_len / base));
      committed = mult * base;
    );

    // Clamp to maximum safe multiple within the per-lane buffer.
    max_mult = floor(g_maxlen / base);
    max_mult < 1 ? max_mult = 1;
    committed > max_mult * base ? committed = max_mult * base;

    committed;
  );
);

// Commit a Flex empty-lane recording: quantize, pad silence, set state metadata.
// raw_len = number of samples actually recorded into buf.
// Operates on both lanes of a pair.
// Caller must follow up with setstate_pair(idx, 1) to enter playback.
function flex_commit_empty_lane_recording(idx, raw_len)
  local(oidx pidx orec prec committed pad_start buf)
(
  committed = quantize_flex_record_len(raw_len);
  committed <= 0 ? committed = raw_len;  // fallback: use raw if quantize fails

  oidx = pair_owner_idx(idx);
  pidx = pair_partner_idx(oidx);

  // Owner lane
  orec = mem_stlist + oidx * st_num;
  buf  = orec[st_buf];
  pad_start = min(raw_len, committed);
  pad_start < committed ? memset(buf + pad_start, 0, committed - pad_start);
  orec[st_dirty]    = committed;
  orec[st_loop_len] = committed;

  // Partner lane (linked stereo pair)
  pidx >= 0 ? (
    prec = mem_stlist + pidx * st_num;
    buf  = prec[st_buf];
    pad_start < committed ? memset(buf + pad_start, 0, committed - pad_start);
    prec[st_dirty]    = committed;
    prec[st_loop_len] = committed;
