<? nch < 1 ? nch = 8 ?>
<? maxmem < 8 ? maxmem = 256 ?>
<?
  loop(x=0;nch,printf("in_pin:input %d\n",x+=1));
  loop(x=0;nch,printf("out_pin:output %d\n",x+=1));
?>
out_pin:monitor output
out_pin:click output

config: nch "Channels" 8 1 2 4 8="8 (namesake)" 12 16 24 32 48
config: maxmem "Memory Size -preserve-config" 256 64="64MB - max length 0:23 for 8 channels @ 44.1kHz" 128="128MB - max length 0:47 for 8 channels @ 44.1kHz" 256="256MB (default) - max length 1:35 for 8 channels @ 44.1kHz" 512="512MB - max length 3:10 for 8 channels @ 44.1kHz" 1024="1GB - max length 6:20 for 8 channels @ 44.1kHz"

options: maxmem=<? printf("%d",maxmem*1024*128); ?> no_meter gfx_idle prealloc=* 

slider1:g_slider_sync=0<0,2,1{off,project,playback}>-Sync
slider4:g_slider_click_cnt=0<0,64,1>-Click count/length

@init

// constants
g_nchan = <? printf("%d",nch) ?>;
g_max_alloc = __memtop(); // JSFX memory available
g_latchq_len = 1024; // 1024 midi events queueable for latch mode
g_maxlen = ((g_max_alloc - 4096 - g_latchq_len*3)/(g_nchan*2))|0; // half per active buffer, half reserved for undo snapshots
g_infthreshdb = -120;
g_infthresh = 10^(g_infthreshdb/20);
g_latchmode=0;

// per-channel state/configuration record (mem_stlist)
st_monmode = 0; // mirrors chX.monmode
st_note1 = 1; // mirrors chX.note/chX.note2/chX.note3/chX.note4
st_note2 = 2;
st_note3 = 3;
st_note4 = 4; // reverse note
st_note5 = 17; // clear lane
st_note6 = 18; // undo lane
st_note7 = 19; // monitor two-state toggle

st_state = 5; // 0=off, 1=play, 2=recording
st_buf   = 6; // pointer to audio buffer
st_dirty = 7;  // set if buffer is dirty, and also may indicate how much of it
               // is using max(mem_stlist[st_dirty],chX.dirty_top+1)
st_lastd = 8; // UI flags for mode + monitor + dirty
st_lastpkupd = 9; // time of last peak drawin
st_peak_in = 10;
st_rdc = 11; // msec, chX.rdc is samples
st_div = 12; // subdiv, 1=normal, chX.div is 1/this
st_fade_size = 13; // fadeout size
st_midichan  = 14; // per-lane MIDI channel for common-mode routing (1–16)
st_undo_buf  = 15; // pointer to pre-allocated undo snapshot buffer
st_undo_len  = 16; // samples stored in snapshot (0 = no snapshot available)
st_num = 20;

function recalc_fades() (
  g_fadespeed = exp(-1/(srate * 0.002));  // fade speed for monitoring
  g_slope_recin = 1/(srate * 0.001); // fade length for starting rec
  g_slope_recout = -1/(srate * 0.030); // fade length for ending rec
  g_slope_playin = 1/(srate * 0.050); // fade length for starting playback
  g_slope_playout = -1/(srate * 0.050); // fade length for ending playback
);

recalc_fades();

function get_section(s) local(r) ( s?(r=s):r; );

function alloc(sz) ( (this.top+=sz)-sz; );

function updatefromrec() instance(rec)
(
  this.note  = rec[st_note1];
  this.note2 = rec[st_note2];
  this.note3 = rec[st_note3];
  this.note4 = rec[st_note4];
  this.note5 = rec[st_note5];
  this.note6 = rec[st_note6];
  this.note7 = rec[st_note7];
  this.monmode = rec[st_monmode];
  this.rdc =(rec[st_rdc]*.001*srate+.5)|0;
  this.div = 1 / rec[st_div];
);

function init(x, n1,n2,n3)
  instance(idx rec buf monvol fpos fpos2 fpos_slope fpos2_slope dirty_top)
(
  idx = x;
  fpos_slope = monvol = fpos = fpos2 = fpos2_slope = 0;
  dirty_top = -1;
  buf = alloc(g_maxlen);

  rec = mem_stlist + x*st_num;
  rec[st_note1] = n1;
  rec[st_note2] = n2;
  rec[st_note3] = n3;
  rec[st_note4] = 128;
  rec[st_note5] = 128; // CLR default off
  rec[st_note6] = 128; // UNDO default off
  rec[st_note7] = 128; // MON default off
  rec[st_state]=0;
  rec[st_lastd]=-1;
  rec[st_dirty]=0;
  rec[st_monmode] = 1;
  rec[st_buf] = buf;
  rec[st_peak_in] = 0;
  rec[st_rdc] = 0;
  rec[st_div] = 1;
  rec[st_fade_size] = 0;
  rec[st_midichan] = x + 1; // default: lane 0 → ch1, lane 1 → ch2, etc.
  rec[st_undo_buf] = 0;     // set by post-init alloc loop
  rec[st_undo_len] = 0;     // no snapshot initially

  this.updatefromrec();
);

// clearing the buffer when starting recording on a particular channel
function set_need_zero(dt) global(g_maxlen) instance(need_zero nz_0) (
  need_zero = max(need_zero, min(g_maxlen,dt+1));
  nz_0 = -1;
);
function process_need_zero(p1, p2) global()
  instance(need_zero nz_0 nz_0e nz_1 nz_1e nz_2 buf)
  local(sz)
(
  nz_0 === -1 ? (
    // three write pointers:  0..p1 p1..p2 p2..need_zero
    nz_0 = 0;
    nz_0e = nz_1 = min(p1,p2);
    nz_1e = nz_2 = max(p1,p2);
  );

  (sz = min(8, nz_0e-nz_0)) > 0 ? ( memset(buf + nz_0, 0, sz); nz_0 += sz; );
  (sz = min(8, nz_1e-nz_1)) > 0 ? ( memset(buf + nz_1, 0, sz); nz_1 += sz; );
  (sz = min(8, need_zero-nz_2)) > 0 ? ( memset(buf + nz_2, 0, sz); nz_2 += sz; );
  nz_2 >= need_zero && nz_1 >= nz_1e && nz_0>=nz_0e ? need_zero=0;
);

function setstate(st) instance(fpos_slope, fpos2_slope, rec) local(dt)
(
  rec[st_state] ? (
    st==0 ? (
      g_active_mask &= -(1<<this.idx + 1);
    ) : g_length > 0 ? (
      g_firstrec = 0;
      g_prevent_processing &= 0xe;
      this.extra_recording = (g_pos == 0 || g_pos == g_length) ? (0|min(srate*.5, g_maxlen-g_length)) : 0;
    );
  ) : (
    st>0 ? (
      st == 2 && (dt = max(rec[st_dirty], this.dirty_top+1)) > 0 ? (
        this.set_need_zero(dt);
        this.dirty_top=-1;
        rec[st_dirty]=0;
      );

      (g_active_mask |= (1<<this.idx)) == (1<<this.idx) ? (
        st == 2 ? (
          cfgp_gate[] > g_infthreshdb && cfgp_sync[] == 0 ? (
            g_recstart_gate = 10^(cfgp_gate[]/20);
            g_prevent_processing |= 1;
          ) : (
            g_prevent_processing &= 0xe;
          );

          cfgp_sync[] == 0 ? (
            g_pos = g_offs = g_length = 0;
            g_firstrec = 1+this.idx;
          );
        );
      );
    );
  );
  rec[st_state] = st;
  rec[st_dirty] = max(max(rec[st_dirty],this.dirty_top+1),st==2);

  st == 2 ? (
    fpos_slope = g_slope_recin;
    fpos2_slope = g_slope_playin;
  ) : (
    fpos_slope = g_slope_recout;
    fpos2_slope = st > 0 ? g_slope_playin :
                  (rec[st_fade_size]>0) ? -1/(rec[st_fade_size]*g_length) :
                  g_slope_playout;
  );
  g_sysex_dirty = 1; // Unit 3.4: schedule a snapshot on the next @block
);

function get_linked_rec(idx) (
  cfgp_link[]&(1<<(idx>>1)) ? mem_stlist+st_num*(idx~1) : -1;
);

function is_chan_selected(idx) (
  g_chan_selected == idx ||
    ((cfgp_link[]&(1<<(idx>>1))) && g_chan_selected == idx~1);
);

// ── Pair helper functions ─────────────────────────────────────────────────────
// Returns non-zero if idx belongs to a linked pair.
function is_linked_idx(idx) (
  cfgp_link[] & (1 << (idx >> 1));
);

// Returns the owner (even-numbered) lane index for any lane in a linked pair,
// or idx itself when not linked.
function pair_owner_idx(idx) (
  is_linked_idx(idx) ? (idx & -2) : idx;
);

// Returns the partner lane index (idx XOR 1) when linked, -1 otherwise.
function pair_partner_idx(idx) (
  is_linked_idx(idx) ? (idx ~ 1) : -1;
);

// Returns a pointer to the owner lane's state record.
function pair_owner_rec(idx) (
  mem_stlist + pair_owner_idx(idx) * st_num;
);

// Returns a pointer to the partner lane's state record, or -1 when unlinked.
function pair_partner_rec(idx) local(p) (
  p = pair_partner_idx(idx);
  p >= 0 ? mem_stlist + p * st_num : -1;
);

// Returns non-zero if either lane of the pair has recorded content (st_dirty > 0).
// Checks both owner and partner so PLY/STP guards correctly on linked pairs.
function pair_has_content(idx) local(oidx pidx orec prec has) (
  oidx = pair_owner_idx(idx);
  pidx = pair_partner_idx(oidx);
  orec = mem_stlist + oidx * st_num;

  has = orec[st_dirty] > 0;

  pidx >= 0 ? (
    prec = mem_stlist + pidx * st_num;
    has |= prec[st_dirty] > 0;
  );

  has;
);
// ─────────────────────────────────────────────────────────────────────────────

function setstate_for_rec(rec, state) (
  rec = (rec-mem_stlist)/st_num;
  <? loop(x=0;nch, printf("rec == %d ? ch%d.setstate(state) :\n",x,x+1); x+=1) ?> 0;
);

// ── Pair-aware command wrappers ───────────────────────────────────────────────
// Apply a state transition to both lanes of a pair (or just the one if unlinked).
// Resolves idx to the pair owner before dispatching.
function setstate_pair(idx, state) local(oidx pidx) (
  oidx = pair_owner_idx(idx);
  pidx = pair_partner_idx(oidx);
  setstate_for_rec(mem_stlist + oidx * st_num, state);
  pidx >= 0 ? setstate_for_rec(mem_stlist + pidx * st_num, state);
);

// Save pre-overdub undo snapshot for both lanes of a pair.
function snapshot_pair(idx) local(oidx pidx orec prec) (
  oidx = pair_owner_idx(idx);
  pidx = pair_partner_idx(oidx);
  orec = mem_stlist + oidx * st_num;
  orec[st_state] == 1 && orec[st_dirty] > 0 && orec[st_dirty] <= g_maxlen ? (
    memcpy(orec[st_undo_buf], orec[st_buf], orec[st_dirty]);
    orec[st_undo_len] = orec[st_dirty];
  );
  pidx >= 0 ? (
    prec = mem_stlist + pidx * st_num;
    prec[st_state] == 1 && prec[st_dirty] > 0 && prec[st_dirty] <= g_maxlen ? (
      memcpy(prec[st_undo_buf], prec[st_buf], prec[st_dirty]);
      prec[st_undo_len] = prec[st_dirty];
    );
  );
);

// Canonicalize g_chan_selected to the pair owner when linked.
function select_pair(idx) (
  g_chan_selected = pair_owner_idx(idx);
);

// ── Common-mode action helpers ────────────────────────────────────────────────
// REC/PLY: recording→play; stopped/empty→record; playing→record/overdub.
// Saves a pre-overdub undo snapshot when entering record from an existing loop.
function common_recply_pair(idx) local(oidx orec newstate) (
  oidx = pair_owner_idx(idx);
  orec = mem_stlist + oidx * st_num;

  newstate = orec[st_state] == 2 ? 1 : 2;

  newstate == 2 ? snapshot_pair(oidx);
  setstate_pair(oidx, newstate);
  select_pair(oidx);
);

// PLY/STP: recording→play; playing→stop; stopped+content→play; empty→no-op.
// Uses pair_has_content so the empty-lane guard covers both lanes of a linked pair.
function common_plystp_pair(idx) local(oidx orec newstate) (
  oidx = pair_owner_idx(idx);
  orec = mem_stlist + oidx * st_num;

  orec[st_state] == 2 ? (
    // Recording → commit and enter playback.
    newstate = 1;
  ) : orec[st_state] == 1 ? (
    // Playing → stop.
    newstate = 0;
  ) : (
    // Stopped → play only when the pair has recorded content; otherwise no-op.
    newstate = pair_has_content(oidx) ? 1 : 0;
  );

  newstate != orec[st_state] ? (
    setstate_pair(oidx, newstate);
    select_pair(oidx);
  );
);

// ─────────────────────────────────────────────────────────────────────────────

function play_or_stop_all() local(want_state rec i)
(
  want_state = 0;
  i = 0;
  rec = mem_stlist;
  loop(g_nchan,
    // Skip partner lanes when evaluating desired play state
    !(is_linked_idx(i) && (i & 1)) ? (
      rec[st_state] != 1 && rec[st_dirty]>0 ? want_state = 1;
    );
    rec += st_num;
    i += 1;
  );
  i = g_nchan;
  loop(g_nchan,
    i -= 1;
    rec -= st_num;
    // Apply via setstate_pair; skip partner lanes to avoid double-apply
    !(is_linked_idx(i) && (i & 1)) ? (
      rec[st_state] != want_state && (rec[st_dirty]>0||rec[st_state]) ? setstate_pair(i, want_state);
    );
  );
);

function process_rev(buf)
  instance(rev_state, rev_pos, rev_p0, rev_p1, rev_p2,
           rev_fade_pos, rev_fade_slope, l_length, l_pos, l_offs)
  local(tmpo old)
  global(srate)
(
  // if the user reverses right after starting recording, shrug
  this.need_zero > 0 ? this.process_need_zero(l_offs+l_length,l_offs+l_length);

  // process reverse ahead of the read pointer
  // if l_pos is more than halfway, then we go until the end, then the mirror of the original l_pos+1
  // if l_pos is less than halfway, we go until the halfway point, then to the mirror of the original l_pos+1
  rev_pos === -1 ? (
    rev_pos = (l_length/2)|0; // number of samples we need to reverse, also the halfway point
    rev_fade_slope = 1.0/(srate * 0.030);
    rev_fade_pos = 0;
    rev_p0 = l_pos;
    rev_p1 = l_pos < rev_pos ? rev_pos+1 : l_length;
    rev_p2 = l_length - 1 + 1 - l_pos;
  );
  loop(min(20, rev_pos), // a 10s loop will take 500ms to reverse
    tmpo = buf + l_length - 1 - rev_p0;
    old=buf[rev_p0];
    buf[rev_p0] = tmpo[];
    tmpo[] = old;
    (rev_p0 += 1) == rev_p1 ? rev_p0 = rev_p2;
    rev_pos -= 1;
  );
  rev_fade_pos = min(rev_fade_pos + rev_fade_slope, 1);
  rev_pos == 0 && rev_fade_pos == 1 ? rev_state=0;
  buf[l_pos] * rev_fade_pos + buf[l_length - 1 - l_pos] * (1-rev_fade_pos);
);

function process(s)
  instance(fpos, fpos2, monvol, monmode, rec, peak_in, div, l_length, l_pos)
  local(r,wrpos,buf,l_offs, sc)
(
  g_prevent_processing===0 ? (
    fpos = min(max(0,fpos+this.fpos_slope),1);
    sc = sqr(fpos2 = min(max(0,fpos2+this.fpos2_slope),1));
  ) : (
    fpos = fpos2 = sc = 0;
  );
  peak_in = max(abs(s),peak_in);

  l_length = g_length;
  l_pos = g_pos;
  l_offs = g_offs;
  div < 1 ? (
    l_length = max((l_length*div+0.5)|0,1);
    g_firstrec === 0 ? (
      l_pos %= l_length;
      l_offs %= l_length;
    );
  );
  wrpos = l_pos;
  buf = this.buf + l_offs;
  g_firstrec === 0 ? (
    this.extra_recording > 0 ? (
      buf[l_length + l_pos] = s; // write past the end of the loop (in case we want to trim later)
      this.dirty_top = max(this.dirty_top,l_length + l_pos + l_offs);
      this.extra_recording -= 1;
    );

    this.rdc < l_length ? (
      wrpos -= this.rdc;
      wrpos < 0 ? wrpos += l_length;
    );
  );
  this.need_zero > 0 ? this.process_need_zero(l_offs+wrpos,l_offs+l_pos);

  r = this.rev_state!==0 ? this.process_rev(buf)*sc : sc > 0.0001 ? buf[l_pos]*sc;
  monmode === 0 ? (
    // no monitoring
    fpos > 0.0001 ? (
      this.dirty_top = max(this.dirty_top,wrpos + l_offs);
      buf[wrpos] += s*fpos;
    );
    r;
  ) : (
    this.monmode_sel ? (
      monvol = 1 + (monvol-1)*g_fadespeed;
    ) : (
      monvol *= g_fadespeed;
    );

    fpos > 0.0001 ? (
      this.dirty_top = max(this.dirty_top,wrpos + l_offs);
      wrpos == l_pos ? (
        buf[l_pos] += s*fpos;
        r + s*max(fpos*sc, monvol);
      ) : (
        buf[wrpos] += s*fpos;
        r + s * monvol;
      );
    ) : (
      r + s*monvol;
    );
  );
);

function rev_stop() instance (rec)
(
  atomic_set(this.rev_requested,0);
  this.rev_state=0;
);

function reverse() instance(rec) local(l)
(
  atomic_add(this.rev_requested,1);
  l = (g_length * this.div)|0;
  rec[st_dirty] = this.dirty_top = max(rec[st_dirty],max(this.dirty_top,l));
  rec[st_lastd] = -1;
);

// Reverse both lanes of a pair (or just the one if unlinked).
// Defined here (after reverse + rev_stop) to avoid forward-reference errors.
function reverse_pair(idx) local(oidx pidx) (
  oidx = pair_owner_idx(idx);
  <? loop(x=0;nch, printf("oidx == %d ? ch%d.reverse() :\n",x,x+1); x+=1;) ?> 0;
  (pidx = pair_partner_idx(oidx)) >= 0 ? (
    <? loop(x=0;nch, printf("pidx == %d ? ch%d.reverse() :\n",x,x+1); x+=1;) ?> 0;
  );
);

// Clear both lanes of a pair: stop, zero buffer, drop undo snapshot.
// Defined here (after rev_stop) to avoid forward-reference errors.
function clear_pair(idx) local(oidx pidx orec prec) (
  oidx = pair_owner_idx(idx);
  pidx = pair_partner_idx(oidx);
  orec = mem_stlist + oidx * st_num;
  // Clear owner
  <? loop(x=0;nch, printf("oidx == %d ? (ch%d.setstate(0); ch%d.rev_stop(); ch%d.dirty_top=-1;) :\n",x,x+1,x+1,x+1); x+=1;) ?> 0;
  orec[st_dirty] > 0 ? memset(orec[st_buf], 0, orec[st_dirty]);
  orec[st_dirty] = 0;
  orec[st_undo_len] = 0;
  // Clear partner when linked
  pidx >= 0 ? (
    prec = mem_stlist + pidx * st_num;
    <? loop(x=0;nch, printf("pidx == %d ? (ch%d.setstate(0); ch%d.rev_stop(); ch%d.dirty_top=-1;) :\n",x,x+1,x+1,x+1); x+=1;) ?> 0;
    prec[st_dirty] > 0 ? memset(prec[st_buf], 0, prec[st_dirty]);
    prec[st_dirty] = 0;
    prec[st_undo_len] = 0;
  );
);

function onmsg(m1,m2,m3) instance(rec,note,note2,note3,note4,note5,note6,note7)
  local(newstate)
(
   newstate = -1;
   (m2 == note && (m2 != note2 || rec[st_state]==0)) || m2 == 1024+rec+st_note1 ? (
     newstate = (rec[st_state] == 2 && g_was_firstrec==0) ? 1 : 2;
   ) : m2 == note2  || m2 == 1024+rec+st_note2 ? (
     newstate = rec[st_state] == 2 || (rec[st_state]==0 && g_length) ? 1 : 0
   ) : (m2 == note3 || m2 == 1024+rec+st_note3) ? (
     g_chan_selected = is_chan_selected(this.idx) ? -1 : pair_owner_idx(this.idx);
   ) : m2 == note4 || m2 == 1024+rec+st_note4 ? (
     reverse_pair(this.idx);
   ) : m2 == note5 || m2 == 1024+rec+st_note5 ? (
     g_lane_clear_req = this.idx + 1;
   ) : m2 == note6 || m2 == 1024+rec+st_note6 ? (
     g_lane_undo_req = this.idx + 1;
   ) : m2 == note7 || m2 == 1024+rec+st_note7 ? (
     g_lane_mon_req = this.idx + 1;
   );
   newstate >= 0 ? (
     setstate_pair(this.idx, newstate);
     select_pair(this.idx);
   );
);

function redraw_channels() local(p)
(
  p=mem_stlist+st_lastd;
  loop(g_nchan,
    p[0] = -1;
    p+=st_num;
  );
);

function repeatbuf(buf,osz, nsz) local(p,s)
(
  p=buf+osz;
  while (p < buf+nsz)
  (
    s = min(buf+nsz-p,osz);
    memcpy(p,buf,s);
    p+=s;
  );
);

function xfadebuf(buf, osz, nsz) local(fsz,s,ds)
(
  fsz = (0.001*cfgp_fade[]*srate)|0;
  s=0;
  osz>0 && osz == nsz ? osz += fsz;
  fsz = min(fsz,osz-nsz)|0;
  ds=1/fsz;
  // fade buf[0..fsz] with buf[nsz..nsz+fsz]
  loop(fsz,
    buf[0] = buf[0] * s + buf[nsz]*(1-s);
    s+=ds;
    buf+=1;
  );

);

function adjustsizes(scale, repup) local(nlen,olen, lp, l, offs, nlen2)
(
  olen = g_length;
  nlen = (olen*scale)|0;
  nlen >= 1 && nlen < g_maxlen ? (
    lp=mem_stlist;
    loop(g_nchan,
      lp[st_dirty] ? (
        l = max(floor(olen / lp[st_div] + 0.5),1);
        nlen2 = max(floor(nlen / lp[st_div] + 0.5),1);
        offs = g_offs%l;
        nlen2 > l ? (
          repup ? repeatbuf(lp[st_buf] + offs,l,nlen2);
          nlen2+offs > lp[st_dirty] ? lp[st_dirty] = nlen2+offs;
        ) : (
          xfadebuf(lp[st_buf] + offs,l,nlen2);
        );
      );
      lp += st_num;
    );
    g_length = nlen;
    g_pos %= nlen;

    cfgp_sync[] ? (
      g_slider_click_cnt = g_click_int = cfgp_clickcnt[] = ((((cfgp_clickcnt[]|0) > 0 ? cfgp_clickcnt[] : ts_num) |0)*scale)|0;
    );

    redraw_channels();
  );
);

function updatechfromrec()
(
  <? loop(x=0;nch,printf("ch%d.updatefromrec();\n",x+=1)) ?>
);

// Restore the undo snapshot for both lanes of a pair.
// Defined here (after updatechfromrec) to avoid a forward-reference error.
function undo_pair(idx) local(oidx pidx orec prec) (
  oidx = pair_owner_idx(idx);
  pidx = pair_partner_idx(oidx);
  orec = mem_stlist + oidx * st_num;
  orec[st_undo_len] > 0 ? (
    memcpy(orec[st_buf], orec[st_undo_buf], orec[st_undo_len]);
    orec[st_dirty] = orec[st_undo_len];
    <? loop(x=0;nch, printf("oidx == %d ? ch%d.dirty_top = orec[st_undo_len] - 1 :\n",x,x+1); x+=1;) ?> 0;
  );
  pidx >= 0 ? (
    prec = mem_stlist + pidx * st_num;
    prec[st_undo_len] > 0 ? (
      memcpy(prec[st_buf], prec[st_undo_buf], prec[st_undo_len]);
      prec[st_dirty] = prec[st_undo_len];
      <? loop(x=0;nch, printf("pidx == %d ? ch%d.dirty_top = prec[st_undo_len] - 1 :\n",x,x+1); x+=1;) ?> 0;
    );
  );
  updatechfromrec();
  g_sysex_dirty = 1; // Unit 3.4: undo restores content; schedule snapshot
);

// MON: two-state toggle — disabled (0) ↔ always-monitor (2).
// Auto/selected (1) is treated as "not always" — next press promotes it to always.
// Mirrors the new mode to the linked partner lane when applicable.
// Defined here (after updatechfromrec) to avoid a forward-reference error.
function common_mon_pair(idx) local(oidx pidx orec prec newmode) (
  oidx = pair_owner_idx(idx);
  pidx = pair_partner_idx(oidx);
  orec = mem_stlist + oidx * st_num;

  newmode = orec[st_monmode] == 2 ? 0 : 2;

  orec[st_monmode] = newmode;

  pidx >= 0 ? (
    prec = mem_stlist + pidx * st_num;
    prec[st_monmode] = newmode;
  );

  updatechfromrec();
  g_mon_changed = 1;
  g_sysex_dirty = 1; // Unit 3.4: monmode changed; schedule snapshot
);

function reset() local(lp)
(
  g_chan_selected=-1;
  // setstate() will latch dirty_top to st_dirty
  <? loop(x=0;nch, x+=1; printf("ch%d.setstate(0); ch%d.rev_stop(); ch%d.dirty_top=-1;\n",x,x,x)) ?>
  lp = mem_stlist;
  loop(g_nchan,
    lp[st_dirty] > 0 ? (
      memset(lp[st_buf], 0, lp[st_dirty]);
      lp[st_dirty] = 0;
    );
    lp += st_num;
  );
  g_firstrec=g_offs=g_length=g_pos=0;
);


function estbpm(len) local(bpm, tsnum) global(ts_num, srate, cfgp_clickcnt)
(
  bpm = 240.0 * srate / len;
  (tsnum = (cfgp_clickcnt[]|0)) < 2 ? tsnum = ts_num;
  tsnum >= 2 ? bpm *= tsnum * .25;

  while (bpm < 60) ( bpm*=2; );
  while (bpm > 240) ( bpm/=2; );
  bpm;
);


// ── SysEx Snapshot Builder — Protocol v0.1 (Unit 3.3) ───────────────────────
//
// build_sysex_snapshot()
//   Fills g_sysex_buf[0..32] with a complete 33-byte v0.1 SysEx packet using the
//   current Ultra8 state. Does NOT increment the sequence counter or send MIDI.
//   Packet layout: docs/protocol_sysex_v0_1.md
//
// emit_sysex_snapshot()
//   Increments g_sysex_seq (14-bit, wraps at 16383), calls build_sysex_snapshot(),
//   then sends via midisend_buf(). Optionally printf-dumps each packet when
//   g_sysex_debug_enabled == 1. All SysEx output must go through this function.
//
// Initialization (inside ext_noinit guard, below):
//   g_sysex_enabled       — master gate: set to 0 to silence without removing code
//   g_sysex_debug_enabled — print each packet to Reaper console (for verification)
//   g_sysex_seq           — 14-bit counter, starts at 0; first emitted packet = seq 1
//   g_sysex_buf           — 33-float alloc block; each slot holds one packet byte
//   g_sysex_dirty         — set by setstate/undo_pair/common_mon_pair; @block emits
//                           one snapshot per block when set, then clears it

function build_sysex_snapshot()
  local(i, rec, lane_state, lane_dirty, lane_sel, lane_monmode, lane_flags, loop_phase)
(
  // ── Header (bytes 0–3) ──────────────────────────────────────────────────────
  g_sysex_buf[0] = 0xF0;   // SysEx start
  g_sysex_buf[1] = 0x7D;   // Non-commercial / educational manufacturer ID
  g_sysex_buf[2] = 0x55;   // Ultra8 NANO4 protocol identifier
  g_sysex_buf[3] = 0x01;   // Protocol version 1

  // ── Sequence number (bytes 4–5) — 14-bit counter, split into two 7-bit bytes ─
  g_sysex_buf[4] = g_sysex_seq & 0x7F;          // seq_lo: bits 6:0
  g_sysex_buf[5] = (g_sysex_seq >> 7) & 0x7F;   // seq_hi: bits 13:7

  // ── Global flags (byte 6) — bit 0 = any_active ─────────────────────────────
  g_sysex_buf[6] = (g_active_mask != 0) ? 1 : 0;

  // ── Selected lane (byte 7) — 0x7F = no selection ───────────────────────────
  g_sysex_buf[7] = (g_chan_selected >= 0 && g_chan_selected < g_nchan)
                   ? g_chan_selected : 0x7F;

  // ── Eight lane blocks (bytes 8–31, 3 bytes each) ────────────────────────────
  i   = 0;
  rec = mem_stlist;
  loop(g_nchan,
    lane_state = rec[st_state];

    // st_state==2 means "recording" in Ultra8 but covers two protocol states:
    //   RECORDING (2)  = first-pass, g_firstrec > 0 (loop length not yet set)
    //   OVERDUBBING (3) = subsequent pass, g_firstrec == 0 (loop length is fixed)
    lane_state == 2 ? (
      lane_state = (g_firstrec > 0) ? 2 : 3;
    );

    // Safety: map any unknown/out-of-range value to STOPPED (safe fallback)
    (lane_state < 0 || lane_state > 3) ? lane_state = 0;

    lane_dirty   = rec[st_dirty] > 0 ? 1 : 0;
    lane_sel     = (g_chan_selected == i) ? 1 : 0;
    lane_monmode = rec[st_monmode] & 0x03;
    // Reverse bit (bit 6): always 0 in v0.1.
    // chX.rev_state is an instance variable not mirrored in mem_stlist; adding it
    // requires a protocol version bump (see docs/protocol_sysex_v0_1.md §Future).

    lane_flags = (lane_state   & 0x03)         // bits 1:0 — state enum
               | ((lane_dirty   & 0x01) << 2)  // bit 2    — dirty
               | ((lane_sel     & 0x01) << 3)  // bit 3    — selected
               | ((lane_monmode & 0x03) << 4); // bits 5:4 — monmode
    // bit 6 = 0 (reverse, deferred), bit 7 = 0 (7-bit MIDI safety)

    // Loop phase 0–127: fractional position through the loop.
    // 0 when lane is stopped or no loop length exists yet.
    loop_phase = (g_length > 0 && rec[st_state] != 0)
                 ? min(127, g_pos / g_length * 127 | 0)
                 : 0;

    g_sysex_buf[8 + i*3]     = i;           // lane_index (sanity-check byte)
    g_sysex_buf[8 + i*3 + 1] = lane_flags;
    g_sysex_buf[8 + i*3 + 2] = loop_phase;

    rec += st_num;
    i   += 1;
  );

  // ── SysEx end (byte 32) ─────────────────────────────────────────────────────
  g_sysex_buf[32] = 0xF7;
);

function emit_sysex_snapshot()
  local(di)
(
  // Advance sequence counter (14-bit, wraps 16383 → 0)
  g_sysex_seq = (g_sysex_seq + 1) & 0x3FFF;

  build_sysex_snapshot();
  midisend_buf(0, g_sysex_buf, 33);

  // Console hex dump — leave enabled during Unit 3.3 verification; set
  // g_sysex_debug_enabled = 0 in production (generates ~120 chars per packet)
  g_sysex_debug_enabled ? (
    printf("U8 SYSEX seq=%d: ", g_sysex_seq);
    di = 0;
    loop(33,
      printf("%02X ", g_sysex_buf[di] | 0);
      di += 1;
    );
    printf("\n");
  );
);
// ─────────────────────────────────────────────────────────────────────────────

// ── SysEx Assignment Message Builder/Emitter (Unit 6.3) ─────────────────────
//
// decode_assignment(raw, out_buf, offset)
//   Decodes a packed Ultra8 assignment integer into the two protocol bytes
//   (msg_type + msg_number) and writes them at out_buf[offset..offset+1].
//   Packed encoding: 0–127 = Note, 128 = Off, 129–257 = CC (n−129),
//   258–386 = PC (n−258). See docs/ultra8_assignment_map.md §Packed Encoding.
//
// build_assign_snapshot()
//   Fills g_assign_buf[0..22] with a complete 23-byte v0.1 assignment message.
//   Does NOT increment the sequence counter or send MIDI.
//   Packet layout: docs/protocol_assignment_metadata_v0_1.md
//
// emit_assign_snapshot()
//   Increments g_assign_seq (14-bit, wraps at 16383), calls
//   build_assign_snapshot(), sends via midisend_buf(). Reuses
//   g_sysex_debug_enabled for optional console hex dump.
//
// Initialization (inside ext_noinit guard, below):
//   g_assign_seq — separate 14-bit counter from g_sysex_seq; 0 on boot
//   g_assign_buf — 23-float alloc block; one slot per MIDI byte

function decode_assignment(raw, out_buf, offset)
  local(atype, anum)
(
  raw >= 258 ? ( atype = 3; anum = raw - 258; ) :  // PC
  raw >= 129 ? ( atype = 2; anum = raw - 129; ) :  // CC
  raw == 128 ? ( atype = 0; anum = 0;         ) :  // Off
              ( atype = 1; anum = raw;         );   // Note
  out_buf[offset]     = atype & 0x7F;
  out_buf[offset + 1] = anum  & 0x7F;
);

function build_assign_snapshot()
(
  // ── Header (bytes 0–6) ──────────────────────────────────────────────────────
  g_assign_buf[0] = 0xF0;   // SysEx start
  g_assign_buf[1] = 0x7D;   // Non-commercial / educational manufacturer ID
  g_assign_buf[2] = 0x55;   // Ultra8 NANO4 protocol identifier
  g_assign_buf[3] = 0x02;   // msg_type: assignment message (0x01 = state snapshot)

  // Sequence number — 14-bit counter, split into two 7-bit bytes
  g_assign_buf[4] = g_assign_seq & 0x7F;          // seq_lo: bits 6:0
  g_assign_buf[5] = (g_assign_seq >> 7) & 0x7F;   // seq_hi: bits 13:7

  g_assign_buf[6] = 5;   // num_controls: always 5 in v0.1

  // ── Control blocks (bytes 7–21, 5 × 3 bytes) ───────────────────────────────
  // Format per block: [control_id, msg_type_byte, msg_number]
  // Source pointers: cfgp_common_rec/ply/clr/mon/undo[] (packed integer encoding)

  g_assign_buf[7]  = 0;   // Control 0: REC_PLY — control_id
  decode_assignment(cfgp_common_rec[], g_assign_buf, 8);

  g_assign_buf[10] = 1;   // Control 1: PLY_STP — control_id
  decode_assignment(cfgp_common_ply[], g_assign_buf, 11);

  g_assign_buf[13] = 2;   // Control 2: CLR — control_id
  decode_assignment(cfgp_common_clr[], g_assign_buf, 14);

  g_assign_buf[16] = 3;   // Control 3: MON — control_id
  decode_assignment(cfgp_common_mon[], g_assign_buf, 17);

  g_assign_buf[19] = 4;   // Control 4: UNDO — control_id
  decode_assignment(cfgp_common_undo[], g_assign_buf, 20);

  // ── SysEx end (byte 22) ─────────────────────────────────────────────────────
  g_assign_buf[22] = 0xF7;
);

function emit_assign_snapshot()
  local(di)
(
  // Advance sequence counter (14-bit, wraps 16383 → 0)
  g_assign_seq = (g_assign_seq + 1) & 0x3FFF;

  build_assign_snapshot();
  midisend_buf(0, g_assign_buf, 23);

  g_sysex_debug_enabled ? (
    printf("U8 ASSIGN seq=%d: ", g_assign_seq);
    di = 0;
    loop(23,
      printf("%02X ", g_assign_buf[di] | 0);
      di += 1;
    );
    printf("\n");
  );
);
